  "identifier": "S10353",
  "title": "Relates to discounted tolls on the Verrazano-Narrows bridge for residents of Kings county using a personal vehicle",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the Triborough bridge and tunnel authority to establish a reduced toll on the Verrazano-Narrows bridge for residents of the county of Kings using a personal vehicle of seventy per centum of the regular crossing fare imposed."
    }
