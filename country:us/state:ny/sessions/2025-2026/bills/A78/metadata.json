  "identifier": "A78",
  "title": "Relates to early literacy education",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires school districts to provide instructional programming and services in reading and literacy which are evidence based and aligned with state standards; requires teachers in grades pre-K through five to attend professional development courses in reading education."
    }
