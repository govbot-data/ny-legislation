  "identifier": "A10606",
  "title": "Establishes certification procedures for the profession of nurse anesthesia",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes certification procedures for the profession of nurse anesthesia; provides for the issuance of a certification to practice as a certified registered nurse anesthetist upon the filing of an application, having a license as a registered professional nurse, having the appropriate educational requirements and paying the fifty dollar initial certification fee and the triennial thirty dollar registration fee."
    }
  ],
