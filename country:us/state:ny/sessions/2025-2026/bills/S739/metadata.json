{
  "legislative_session": "2025-2026",
  "identifier": "S739",
  "title": "Relates to payroll records submitted by contractors and sub-contractors for public work contracts and the establishment of an online database of electronic certified payroll records",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to payroll records submitted by contractors and sub-contractors for public work contracts; extends the date the department of labor shall be required to develop and implement an online database of electronic certified payroll records until December 31, 2025; provides that the submission of certain electronic records shall satisfy certain requirements relating to the submission of payroll records."
    }
  ],
