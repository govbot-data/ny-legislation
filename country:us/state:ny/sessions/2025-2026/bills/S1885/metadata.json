{
  "legislative_session": "2025-2026",
  "identifier": "S1885",
  "title": "Requires a valid government issued photo identification card to be presented when casting a ballot",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires a New York state driver's license or non-driver ID, a United States passport, an identification card issued by a United States educational institution, a United States military identification card, a government issued medical card, or any identification card issued by the United States or the state of New York to be presented when casting a ballot."
    }
  ],
