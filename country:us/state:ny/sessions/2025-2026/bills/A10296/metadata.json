  "identifier": "A10296",
  "title": "Requires employers to provide a leave of absence for an employee to use for menopause",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires employers to provide leave of absence of at least five days for every 12 month period for an employee to use for menopause symptoms; requires the commissioner of labor, in consultation with the commissioner of health, to develop workplace guidance relating to menopause."
    }
  ],
