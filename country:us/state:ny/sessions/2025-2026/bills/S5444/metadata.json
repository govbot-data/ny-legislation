  "identifier": "S5444",
  "title": "Establishes protections for the rights of pregnant students, parenting students, and students with pregnancy-related conditions in schools",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes protections for the rights of pregnant students, parenting students, and students with pregnancy-related conditions in schools; requires schools to establish liaison officers for such students and to disseminate information relating to resources available to such students; directs that rules be established to administer such rights and to establish minimum periods of time for a leave of absence at the student's option."
    }
  ],
