  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits sellers of bicycles with electric assist, electric scooters, and limited use motorcycles from selling to persons less than sixteen years of age; requires valid proof of age at the point of purchase; establishes penalties for violations of this requirement."
    }
