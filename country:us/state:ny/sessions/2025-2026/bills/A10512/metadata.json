  "identifier": "A10512",
  "title": "Prohibits unregulated pregnancy centers from requiring clients to disclose certain information as a condition of service",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits unregulated pregnancy centers from requiring clients, as a condition of service, or making it reasonably appear to be a condition of service, to disclose certain information relating to their medical history, sexual history, relationship to the other parent of the potential baby, or insurance or financial information."
    }
  ],
