  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"prevention of damage to critical infrastructure act\"; prevents junk dealers and scrap processors from selling metals that are used by critical infrastructure providers; defines terms."
    }
