  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the sale of kratom to individuals under the age of twenty-one; imposes a civil penalty of not more than five hundred dollars for the sale or provision of kratom to any person under the age of twenty-one."
    }
  ],
