  "identifier": "S9962",
  "title": "Enacts the NYS ratepayer protection nuclear moratorium act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"NYS ratepayer protection nuclear moratorium act\" under which certain state funds and subsidies are prohibited from being expended for new, reopened or rebuilt closed nuclear power facilities and related entities; creates a nuclear assessment task force."
    }
  ],
