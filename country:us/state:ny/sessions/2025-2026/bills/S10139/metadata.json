  "identifier": "S10139",
  "title": "Relates to the number of judges in family court",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Increases the number of family court judges in the city of New York to seventy-two; provides for two additional family court judges for each of Westchester and Rockland counties and an additional family court judge for each of Erie and Niagara counties."
    }
  ],
