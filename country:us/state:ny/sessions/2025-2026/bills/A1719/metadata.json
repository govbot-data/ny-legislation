  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits charging a fee to obtain a certified copy or certified transcript of birth when the department of corrections and community supervision or a local correctional facility requests such for an individual under community supervision in connection with such individual's ongoing supervision in the community."
    }
