  "identifier": "A8583",
  "title": "Enacts the NY-PROTECT ACT; repealer",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Allows an organization included on the federal list of tax-exempt organizations under section 501(c)(3) of title 26 of the United States code on March first, two thousand twenty-five to automatically maintain their tax-exempt status for New York state purposes; provides for the repeal of such provisions upon the expiration thereof."
    }
  ],
