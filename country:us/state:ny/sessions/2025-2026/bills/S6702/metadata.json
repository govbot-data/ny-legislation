  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to eligibility for participants in the automotive 25 year/age 50 pension plan with more than 30 years of credited service who remain in active service after age 62 to receive a service retirement benefit equivalent to the standard service retirement benefit received by Tier IV members with the same age and service."
    }
  ],
