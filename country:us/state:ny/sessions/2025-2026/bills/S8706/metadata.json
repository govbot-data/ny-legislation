  "identifier": "S8706",
  "title": "Requires covered businesses to annually report to the department of labor regarding the impact of artificial intelligence on hiring and the nature of artificial intelligence use",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires covered businesses to annually report to the department of labor regarding the impact of artificial intelligence on hiring and the nature of artificial intelligence use for the previous year; requires the department of labor to file an annual report on the impact of artificial intelligence on hiring and the nature of artificial intelligence use in the state; establishes penalties for covered business that fail to submit such reports."
    }
  ],
