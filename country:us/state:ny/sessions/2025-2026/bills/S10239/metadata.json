{
  "legislative_session": "2025-2026",
  "identifier": "S10239",
  "title": "Relates to e-scooter mobile app disclosures",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits electric scooter service platforms operating a digital network from operating electric scooters in this state unless such platform displays a warning that persons under 18 years of age are not allowed to operate electric scooters through the platform; imposes a penalty for violations."
    }
  ],
