  "identifier": "S10468",
  "title": "Establishes confirmatory adoptions and allowing courts to grant the custody and support from more than two parents",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes confirmatory adoptions allowing adoption and parentage judgements for a child with more than two parents; recognizes functional parents as legal parents; allows \"de facto parents\" to get a court order confirming their parentage; grants all legal parents standing to seek visitation or custody of their children."
    }
  ],
