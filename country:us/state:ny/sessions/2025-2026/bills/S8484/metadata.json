{
  "legislative_session": "2025-2026",
  "identifier": "S8484",
  "title": "Regulates the use of artificial intelligence in the provision of therapy or psychotherapy services",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Regulates the use of artificial intelligence in the provision of therapy or psychotherapy services by prohibiting the use of artificial intelligence to assist in providing supplementary support where the session is recorded or transcribed unless the patient is informed of the specific purpose of such use and consents of such use; establishes penalties for violations of such provisions; excludes religious counseling, peer-support, and self-help materials and educational resources from such provisions."
    }
  ],
