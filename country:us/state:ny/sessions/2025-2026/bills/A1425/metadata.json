{
  "legislative_session": "2025-2026",
  "identifier": "A1425",
  "title": "Relates to electronic appearances for parking violations",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that persons charged with a parking violation shall be able to make an electronic court appearance unless a locality elects not to permit electronic appearances."
    }
  ],
