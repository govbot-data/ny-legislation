{
  "legislative_session": "2025-2026",
  "identifier": "A8537",
  "title": "Prohibits the sale of any children's product, upholstered furniture or mattress that contains textile fiberglass",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the sale of any children's product, upholstered furniture or mattress that contains textile fiberglass; prohibits any custom upholsterer from repairing, reupholstering, recovering, restoring or renewing upholstered furniture or reupholstered furniture using a replacement component that contains textile fiberglass, fibrous glass or glass wool."
    }
  ],
