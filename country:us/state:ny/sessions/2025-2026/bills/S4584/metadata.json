  "title": "Relates to reports and awards by the office of victim services",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the office of victim services to publicize programs offered by the office and to include certain information in annual reports to the governor and the legislature and to make such reports public on the office's website."
    }
  ],
