  "identifier": "A8549",
  "title": "Relates to joint spousal and non-spousal accounts and convenience accounts",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts provisions for the establishment and administration of joint accounts and non-survivorship accounts; provides for account agreements, payments during lifetime, and liability; provides for notice, competing claims, and court orders; defines terms; makes related provisions."
    }
  ],
