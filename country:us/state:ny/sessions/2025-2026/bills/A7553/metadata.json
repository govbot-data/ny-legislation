  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Expands coverage for developmentally disabled persons past twenty-six years of age; prohibits insurance companies from wrongfully terminating contracts of developmentally disabled persons; requires recertification of such developmentally disabled person's condition once every five years."
    }
  ],
