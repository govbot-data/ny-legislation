{
  "legislative_session": "2025-2026",
  "identifier": "A10958",
  "title": "Relates to permitting waiver of dental residency requirements for licensure in underserved areas under supervised practice",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that the department of education may waive the residency requirement for a license as a dentist for certain applicants who agree to practice in an underserved area of the state under the supervision of a dentist licensed and practicing in the state."
    }
  ],
