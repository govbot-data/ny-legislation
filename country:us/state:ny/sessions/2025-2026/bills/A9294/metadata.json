{
  "legislative_session": "2025-2026",
  "identifier": "A9294",
  "title": "Relates to the disclosure of tenant screening criteria",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that a landlord shall provide a prospective tenant a written disclosure of the tenant screening criteria used to evaluate rental applications prior to accepting any fee, deposit, or screening information from such prospective tenant."
    }
  ],
