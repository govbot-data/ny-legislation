  "title": "Enacts the \"End the Toll Trap: Real Relief for Drivers Act\"",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"End the Toll Trap: Real Relief for Drivers Act\" to address excess administrative costs incurred by public authorities for the collection of toll payments and to ensure repeat toll evaders pay such costs; creates the New York and New Jersey toll and fees reduction task force to examine and evaluate the efficacy of current payment processing procedures and systems, and to provide recommendations to increase efficacy and reduce tolls and administrative fees."
    }
  ],
