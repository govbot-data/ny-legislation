  "legislative_session": "2025-2026",
  "identifier": "S7612",
  "title": "Establishes a co-shelter toolkit",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a co-shelter toolkit of best practices, resources, case studies and other information deemed helpful to inform and encourage the implementation and sustenance of co-shelter models for victims of domestic violence and people experiencing homelessness with companion animals; makes related provisions."
    }
  ],
