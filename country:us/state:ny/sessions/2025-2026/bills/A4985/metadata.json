{
  "legislative_session": "2025-2026",
  "identifier": "A4985",
  "title": "Provides for the registration of professional nurse anesthetist",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the certification of registered nurse anesthetists; provides that for such certification an applicant shall file an application, be licensed as a registered professional nurse, have satisfactorily completed educational preparation for the administration of anesthesia by an accredited entity and pay a fee; specifies who may represent themself as a registered nurse anesthetist."
    }
  ],
