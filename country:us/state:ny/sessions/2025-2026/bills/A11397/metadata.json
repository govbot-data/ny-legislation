{
  "legislative_session": "2025-2026",
  "identifier": "A11397",
  "title": "Relates to the representation of individuals involved in guardianship proceedings pursuant to article 81 of the mental hygiene law",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that certain individuals who are involved in a guardianship proceeding pursuant to article 81 of the mental hygiene law shall have certain services obtained on their behalf if they are financially unable to obtain such services on their own, including the appointment of an individual to carry out the duties of a court evaluator or court examiner."
    }
  ],
