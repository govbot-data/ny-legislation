  "identifier": "A51",
  "title": "Relates to training of day care center employees in the administration of opioid antagonists",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires all employees of a family day care center, group family day care center, school-aged child care program, and child day care center be trained in administering an opioid antagonist; requires a child day care to stock at least one opioid antagonist."
    }
  ],
