{
  "legislative_session": "2025-2026",
  "identifier": "S8890",
  "title": "Relates to the effect the death of a defendant has on a pending appeal",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that if a defendant dies when they have a pending appeal, such appeal shall be dismissed and the trial court's judgment shall remain in effect."
    }
  ],
