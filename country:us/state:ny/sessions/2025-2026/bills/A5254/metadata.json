{
  "legislative_session": "2025-2026",
  "identifier": "A5254",
  "title": "Enacts the \"New York open water data act\"",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"New York open water data act\"; directs certain agencies, under the leadership of conveners, to identify and integrate key water data sets; provides duties and an annual plan for data to be researched and reported."
    }
  ],
