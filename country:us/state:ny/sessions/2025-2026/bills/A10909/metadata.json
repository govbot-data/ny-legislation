  "legislative_session": "2025-2026",
  "identifier": "A10909",
  "title": "Enacts the \"Shirley Myers White Right To Reconciliation and Digital Identity Repair Act\"",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"Shirley Myers White Right To Reconciliation and Digital Identity Repair Act\"; establishes a right for individuals to have outdated, inaccurate, or incomplete public and digital narratives corrected once a legal matter is resolved; requires institutions to provide mechanisms for context, updates, and correction so that individuals are not permanently penalized by disproven or obsolete information in digital and automated systems."
    }
  ],
