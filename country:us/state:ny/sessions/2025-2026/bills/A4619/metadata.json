  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the taxation of vapor products; provides for the licensing of vapor products distributors; imposes certain tax return filing requirements on vapor products distributors; provides for enforcement powers."
    }
