  "title": "Limits prohibitions of advertising of cannabis products or services on billboards",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to requirements for advertising of cannabis licensees, products or services on billboards; limits information that may appear on billboards; prohibits billboard advertising by a cannabis licensee is a city with a population of one million or more."
    }
  ],
