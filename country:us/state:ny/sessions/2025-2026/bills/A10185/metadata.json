  "identifier": "A10185",
  "title": "Establishes a municipal exemption from commercial driver's license requirements",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a municipal exemption from commercial driver's license requirements when the vehicle utilized is owned or leased by a city, town, village, or county when such vehicle is operated by a municipal employee solely for intrastate governmental purposes."
    }
  ],
