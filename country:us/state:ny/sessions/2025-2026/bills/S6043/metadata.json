  "identifier": "S6043",
  "title": "Requires an annual report on individuals who are the primary caregiver for an older adult",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires a report on individuals who are the primary caregiver for an older adult, including the number of individuals who are primary caregivers for an older adult, the average age of a primary caregiver, the cost to an individual to provide care to an older adult, and the economic value and savings to the state of such individual's services."
    }
  ],
