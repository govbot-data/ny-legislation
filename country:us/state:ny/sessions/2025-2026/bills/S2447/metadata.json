{
  "legislative_session": "2025-2026",
  "identifier": "S2447",
  "title": "Clarifies the standard for intentional discrimination or retaliation claims",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Clarifies the standard for intentional discrimination or retaliation claims by requiring a person or persons prove that an unlawful motivation was a motivating factor and not \"the sole motivating factor\" or a \"but-for cause\" of the challenged treatment."
    }
  ],
