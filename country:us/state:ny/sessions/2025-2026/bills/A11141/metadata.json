  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"renewable natural gas standard act\"; requires the public service commission to establish a program to require that gas corporations procure renewable natural gas from third-parties, including affiliates of the gas corporation, for distribution to natural gas customers."
    }
