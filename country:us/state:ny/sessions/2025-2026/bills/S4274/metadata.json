  "legislative_session": "2025-2026",
  "identifier": "S4274",
  "title": "Requires the board of elections in a city with a population of one million or more to provide certain notices prior to a change of polling place",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the board of elections in a city with a population of one million or more to notify by mail state and county party committees and certain elected officials prior to a change of polling place."
    }
  ],
