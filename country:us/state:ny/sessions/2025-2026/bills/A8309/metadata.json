{
  "legislative_session": "2025-2026",
  "identifier": "A8309",
  "title": "Requires certain public authorities to develop a feasibility study to promote bicycle and pedestrian access on bridges",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the New York state bridge authority, the Thousand Islands bridge authority, the Nassau county bridge authority, the Ogdensburg bridge authority, and the New York state thruway authority to develop a feasibility study to promote bicycle and pedestrian access on bridges and provide a report to the governor, temporary president of the senate, speaker of the assembly, and the public a copy of such plan."
    }
  ],
