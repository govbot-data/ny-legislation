{
  "legislative_session": "2025-2026",
  "identifier": "A98",
  "title": "Relates to local block anesthesia certificate",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that a dental hygienist shall not administer local block anesthesia without a certificate and except under the personal supervision of a dentist and in conjunction with the performance of dental hygiene procedures authorized by law and in accordance with regulations promulgated by the commissioner."
    }
  ],
