  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires health plan coverage to include generic drugs and biosimilars where the wholesale acquisition cost of such generic drugs or biosimilars is lower than the brand drug's wholesale acquisition cost."
    }
