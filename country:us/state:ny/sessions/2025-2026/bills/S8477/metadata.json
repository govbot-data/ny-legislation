  "identifier": "S8477",
  "title": "Relates to the provision of on-premises alcohol consumption licenses",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the provision of on-premises alcohol consumption licenses; provides such licenses may be provided if the owner or administrator of a school, church, or other place of worship affirmatively provides support for the issuance of such license and such license would have been denied only for the proximity to such buildings."
    }
  ],
