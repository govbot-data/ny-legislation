{
  "legislative_session": "2025-2026",
  "identifier": "S4470",
  "title": "Establishes \"DJ's law\" requiring training for police officers on discharging a firearm at a moving vehicle",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts \"DJ's law\" which requires training for police officers on discharging a firearm at a moving vehicle; requires the municipal police training council to develop and disseminate written policies and procedures regarding such force."
    }
  ],
