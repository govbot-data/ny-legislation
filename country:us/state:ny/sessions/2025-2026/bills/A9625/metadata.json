  "identifier": "A9625",
  "title": "Enacts the facilitating access to e-books for libraries act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Permits libraries and library systems to enter into cooperative purchasing agreements to purchase or license electronic literary materials; prevents contracts between publishers or aggregators and libraries or library systems from restricting the disclosure of certain information."
    }
