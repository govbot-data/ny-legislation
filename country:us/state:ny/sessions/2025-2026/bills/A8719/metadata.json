{
  "legislative_session": "2025-2026",
  "identifier": "A8719",
  "title": "Establishes a blue envelope program for persons with mental health disorders, behavioral disorders and persons who are neurodivergent",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a blue envelope program for persons with mental health disorders, behavioral disorders and persons who are neurodivergent to be provided with blue envelopes to keep their identification, vehicle registration, and other related documents to improve their safety during law enforcement interactions; requires the municipal police training council to promulgate rules and regulations requiring training and instruction for all police officers with respect to the blue envelope program."
    }
  ],
