{
  "legislative_session": "2025-2026",
  "identifier": "S6718",
  "title": "Relates to surcharges for the installation or use of certain appliances in housing accommodations subject to rent control and rent stabilization",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the imposition of any surcharge for the installation or use of a tenant-installed appliance where the tenant pays for electric utility service, under rent control, and rent stabilization laws."
    }
  ],
