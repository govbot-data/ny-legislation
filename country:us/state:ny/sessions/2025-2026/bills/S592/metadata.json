  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the New York state youth in agriculture and entrepreneurship summer employment program to provide students with the opportunity to be educated on the agricultural industry and alternative career paths and to provide agricultural work experience and entrepreneurship work experience."
    }
