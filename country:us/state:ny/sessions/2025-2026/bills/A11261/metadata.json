  "identifier": "A11261",
  "title": "Relates to eligibility for accidental disability benefits under the heart bill",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Allows a one-year window for application for a disability retirement for members of the New York state and local employees' retirement system or the New York state and local police and fire retirement system who retired from service on or after January 1, 2021 due to heart disease; provides for the repeal of such provisions upon the expiration thereof."
    }
  ],
