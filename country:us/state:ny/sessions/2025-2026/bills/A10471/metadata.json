  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that the continued existence of the charter commission and appointments to the commission is dependent on confirmation by the mayor who is in office on the first day of January of the following year; makes exception for certain mayors; provides for the repeal of certain provisions upon the expiration thereof."
    }
