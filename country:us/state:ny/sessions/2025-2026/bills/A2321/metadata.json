{
  "legislative_session": "2025-2026",
  "identifier": "A2321",
  "title": "Relates to requiring agencies to report information about FOIL inquiries to the committee on open government",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires all agencies to submit to the committee on open government a log of all freedom of information law requests for each year in which they received or have pending a request for records; requires the committee on open government to publish, on one webpage, all freedom of information law request logs it receives."
    }
  ],
