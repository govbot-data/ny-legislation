  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires bicycles with electric assist and electric scooters be registered with the department of motor vehicles, inspected and have liability insurance; and have a license plate affixed to such bicycle with electric assist or electric scooter."
    }
