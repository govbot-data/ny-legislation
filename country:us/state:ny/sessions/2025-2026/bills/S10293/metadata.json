{
  "legislative_session": "2025-2026",
  "identifier": "S10293",
  "title": "Enacts the \"deed theft eviction protection act\" in relation to prohibiting the eviction, removal, or dispossession of an owner of record from residential real property while title to such property is contested",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that in an action or proceeding to recover possession of residential real property, the court shall stay the issuance or execution of a warrant of eviction or removal where an owner of record demonstrates that title, ownership, deed validity, conveyance, heirship, inheritance interest, or the right to possess the property is contested in a court of competent jurisdiction, and such stay shall remain in effect until the court in which such interest in the property is contested issues a final judgment unless the court issuing such stay finds good cause to modify or lift such stay."
    }
  ],
