{
  "legislative_session": "2025-2026",
  "identifier": "S7651",
  "title": "Requires the commissioner of labor to develop instructional tools and materials for occupations at high-risk of tick exposures",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the commissioner of labor, in consultation with the commissioner of agriculture and markets, commissioner of health and the commissioner of environmental conservation, to develop instructional tools and materials for occupations at high-risk of tick exposures; requires such materials to provide information on the identification of ticks and tick removal, and protection from tick bites; requires such materials to be available to high-risk employers and employees at no charge."
    }
  ],
