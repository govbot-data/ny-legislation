  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the commissioner of education to conduct a survey regarding instruction on Asian American, Native Hawaiians and Pacific Islander history within the state; establishes an Asian American, Native Hawaiians and Pacific Islander history advisory committee; provides for the repeal of such provisions upon the expiration thereof."
    }
