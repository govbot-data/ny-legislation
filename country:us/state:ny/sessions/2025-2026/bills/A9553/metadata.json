  "identifier": "A9553",
  "title": "Relates to limiting audit and review of certain medical assistance program funds",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Limits the reimbursement amount of certain overpayment claims and reviews where such overpayment was due to the provider's submission of records which were not in accordance with program requirements at the time but which were in accordance with current requirements as a result of changes to guidelines or regulations."
    }
  ],
