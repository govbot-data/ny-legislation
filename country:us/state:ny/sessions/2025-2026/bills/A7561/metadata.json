  "identifier": "A7561",
  "title": "Relates to continuing education requirements for landscape architects",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to continuing education requirements for landscape architects; provides that adjustments to such requirements may be granted for health reasons, active duty, or other good cause; limits the number of credit hours that may carry over to the next registration period."
    }
  ],
