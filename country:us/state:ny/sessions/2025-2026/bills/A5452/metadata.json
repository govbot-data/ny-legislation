{
  "legislative_session": "2025-2026",
  "identifier": "A5452",
  "title": "Prohibits imprisonment for sleeping or camping in public spaces",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits imposing imprisonment or other penalties or fines for sleeping or camping in public spaces; prohibits involuntary admission to a hospital for observation, care and treatment or deeming a person as posing a substantial risk of physical harm to themself for failing to provide their own essential needs solely due to the fact that such person is sleeping in or upon publicly-owned property which is open to the public at such time."
    }
  ],
