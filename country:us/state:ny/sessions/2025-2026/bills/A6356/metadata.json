  "identifier": "A6356",
  "title": "Relates to admission to charter schools",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires parents of a child who qualifies for admission to a public school building in good standing with the department to provide a justification and educational-based reasoning to the superintendent of such school building prior to submitting an application to admission at a charter school."
    }
  ],
