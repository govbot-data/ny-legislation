{
  "legislative_session": "2025-2026",
  "identifier": "A2299",
  "title": "Relates to requiring the installation of intelligent speed assistance devices for repeated violation of maximum speed limits",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the installation of intelligent speed assistance devices if a driver accumulates eleven or more points on their driving record during a 24 month period, or receives 6 speed camera or red light camera tickets during a twelve month period."
    }
  ],
