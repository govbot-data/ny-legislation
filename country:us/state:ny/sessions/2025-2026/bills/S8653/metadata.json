  "identifier": "S8653",
  "title": "Creates a vacant property classification",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Creates a vacant property classification for vacant and blighted properties; allows for cities with a population of one million or more to levy an additional real property tax on vacant and blighted properties with funds raised from such taxes being used to address homelessness."
    }
  ],
