  "identifier": "S5551",
  "title": "Requires the recording and posting of certain public hearings",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires certain public hearings held by the New York state urban development corporation to be recorded and such recordings be posted to the corporation's website within forty-eight hours."
    }
