  "identifier": "A8174",
  "title": "Increases the number of commissioners of the public service commission",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the members of the public service commission; prohibits commissioners from having been employed within the last two years by an electric, gas, steam, telecommunications, or water utility that is regulated by the commission; requires that new appointments ensure that commissioners represent certain areas of education and training."
    }
