  "identifier": "S8599",
  "title": "Relates to certain crimes of interference with health care services or religious worship",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to certain crimes of interference with health care services or access to places of religious worship; expands interference to include groups of two or more people demonstrating or preparing to demonstrate twenty-five feet outside of reproductive health care facilities and places of religious worship."
    }
  ],
