  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the commissioner of corrections and community supervision to discipline certain employees for acts of serious misconduct; defines serious misconduct; establishes procedures for such disciplinary action; prohibits employees who have been removed for serious misconduct from being placed on the eligible list after such removal."
    }
