  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits public utilities from passing along the cost of site investigation and remediation efforts on to rate payers; requires each public utility with more than seventy-five thousand customers to submit to the public service commission an annual report containing a description of any expenses that may not be included or incorporated in the public utility's operating expenses."
    }
  ],
