{
  "legislative_session": "2025-2026",
  "identifier": "A9194",
  "title": "Directs the office for people with developmental disabilities to conduct a study on housing models that support independent living for people with intellectual and developmental disabilities",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the office for people with developmental disabilities to conduct a study on the feasibility of establishing, implementing and expanding additional housing models that support independent living for people with intellectual and developmental disabilities; requires the office to submit a report on such study to the governor, the temporary president of the senate and the speaker of the assembly."
    }
  ],
