{
  "legislative_session": "2025-2026",
  "identifier": "A10351",
  "title": "Provides that certain members of the United States Air Force Auxiliary Civil Air Patrol or the United States Coast Guard Auxiliary Pilots shall be granted leave from work with pay for air force assigned missions",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that public officers and employees of the state who are members of the United States Air Force Auxiliary Civil Air Patrol or the United States Coast Guard Auxiliary Pilots shall be granted leave from work with pay to participate in emergency services during certain air force assigned missions."
    }
  ],
