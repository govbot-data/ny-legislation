  "identifier": "S9948",
  "title": "Relates to the optional retirement of members employed as an emergency medical technician, critical care technician, advanced emergency medical technician, paramedic or supervisor",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides as an alternative retirement option from the current option, that any member employed as an emergency medical technician, critical care technician, advanced emergency medical technician, paramedic or supervisor of such titles upon an election by a participating fire district, not including those in a city with a population of one million or more, shall be eligible to retire."
    }
  ],
