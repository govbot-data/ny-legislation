  "identifier": "S6970",
  "title": "Relates to unsold instant lottery game tickets",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the return of unsold instant lottery game tickets to the division of the lottery when a licensed agent goes out of business, sells their business or if their license is suspended or revoked."
    }
  ],
