{
  "legislative_session": "2025-2026",
  "identifier": "S9120",
  "title": "Establishes the senior homeowner foreclosure and rehabilitation revolving loan program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the senior homeowner foreclosure and rehabilitation revolving loan program to permit the New York state mortgage agency to make low-interest loans, deferred payment loans, or forgivable loans, or a combination thereof, to eligible senior homeowners for eligible assistance; directs SONYMA to prioritize senior homeowners at imminent risk of foreclosure; properties with essential systems in need of immediate repair or replacement, including heating and boilers; and senior homeowners with documented financial hardship that limits their ability to maintain the property or make mortgage payments."
    }
  ],
