  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to protecting retiree health insurance benefits; provides that the health insurance benefits provided to retired officers, employees, and their dependents by the state and its political subdivisions shall not be diminished or impaired below the actuarial value of the benefits provided as of December thirty-first, two thousand twenty-one."
    }
