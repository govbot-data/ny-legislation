  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Phases out certain reimbursements for expenditures made by or on behalf of social services districts for medical assistance for needy persons, beginning with a 10% reduction for 2025, and ending with a 100% reduction for 2034, and remaining eliminated for each year thereafter."
    }
  ],
