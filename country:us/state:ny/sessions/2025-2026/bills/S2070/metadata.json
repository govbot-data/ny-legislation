{
  "legislative_session": "2025-2026",
  "identifier": "S2070",
  "title": "Requires the department of veterans' services to establish and maintain a database of resources available in the state for veterans, members of the uniformed services, and their families",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the department of veterans' services to establish and maintain, in consultation and collaboration with other state agencies, a searchable database on the department's website providing resources available in the state for veterans, members of the uniformed services, and their families."
    }
  ],
