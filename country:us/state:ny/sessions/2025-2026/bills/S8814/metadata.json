{
  "legislative_session": "2025-2026",
  "identifier": "S8814",
  "title": "Prohibits the sale of kratom to individuals under the age of twenty-one",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the sale of kratom to individuals under the age of twenty-one; prohibits the sale or dissemination of information recorded during transaction scans; imposes a civil penalty of not more than five hundred dollars for the sale or provision of kratom to any person under the age of twenty-one; repeals certain provisions relating thereto; repeals certain provisions requiring a study on kratom; relates to the effectiveness of a chapter of the laws of 2025 relating to prohibiting the sale of kratom to persons under the age of 21."
    }
  ],
