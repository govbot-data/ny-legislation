{
  "legislative_session": "2025-2026",
  "identifier": "A10934",
  "title": "Provides motor fuel tax exemption for sales of diesel motor fuel made to commercial fishermen",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Eliminates provisions of law that require the payment and subsequent refund of the ten cent diesel excise tax and sales tax on diesel motor fuel when sold to operators of commercial fishing vessels for use in the operation of such vessels."
    }
  ],
