  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the crime of package theft in the fourth, third, second and first degrees; designates such crimes as a class A misdemeanor, class E felony, class D felony, and class B felony, respectively; provides instances that are not a defense to such crimes; provides for certain defenses to such crimes."
    }
