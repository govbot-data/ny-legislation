{
  "legislative_session": "2025-2026",
  "identifier": "S7961",
  "title": "Relates to designating state university campuses as early voting sites and polling sites",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Designates campuses which are operated by the state university of New York with at least sixteen thousand enrolled students and an on campus dormitory as early voting sites and polling sites; provides that such designation requirements shall not apply where an early voting site or polling site is already designated within one mile of the geographic boundaries of such campus."
    }
  ],
