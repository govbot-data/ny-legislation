{
  "legislative_session": "2025-2026",
  "identifier": "A10569",
  "title": "Establishes a demonstration program for pediatric palliative care centers",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"pediatric palliative care center act\" to establish a demonstration program for pediatric palliative care centers for up to five not-for-profits to provide palliative care to individuals who are under twenty-one years of age, have been diagnosed with a chronic, complex, life-threatening illness that is expected to shorten their life expectancy, and is not expected to survive past twenty-one years of age; authorizes the establishment or approval of a rate methodology."
    }
  ],
