{
  "legislative_session": "2025-2026",
  "identifier": "S9800",
  "title": "Relates to requiring certain child passengers in a taxi or livery to be restrained by a child restraint system",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires that no person under four years of age shall be a passenger in a taxi or livery unless such person is restrained by a child restraint system; requires that no person four years of age or older but under age eight shall be a passenger in a taxi or livery unless such person is restrained in an appropriate child restraint system; establishes violations of such provisions shall be punished by a civil fine of up to fifty dollars."
    }
  ],
