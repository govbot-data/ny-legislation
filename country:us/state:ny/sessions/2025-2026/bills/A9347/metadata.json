{
  "legislative_session": "2025-2026",
  "identifier": "A9347",
  "title": "Relates to military duty of outside militias in New York state",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits organized militias from another state, territory, or district from entering into New York for the purpose of doing military duty without the express permission of the governor unless such militia has been called into federal service and is acting under authority of the president of the United States."
    }
  ],
