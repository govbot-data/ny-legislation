  "identifier": "S9325",
  "title": "Establishes a real property tax exemption for surviving spouses of correction officers who died in the line of duty",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a real property tax exemption of up to fifty percent of the assessed valuation of such real property for surviving spouses of state and county correction officers who died in the line of duty and such property constitutes the primary resident of such surviving spouse."
    }
  ],
