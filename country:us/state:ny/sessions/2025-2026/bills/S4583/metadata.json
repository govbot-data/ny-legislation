{
  "legislative_session": "2025-2026",
  "identifier": "S4583",
  "title": "Relates to the health, safety and human rights of incarcerated pregnant individuals, incarcerated birthing parents of children and their children",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the health, safety and human rights of incarcerated pregnant individuals, incarcerated birthing parents and their children; requires the commissioner of corrections and community supervision to establish rules and regulations relating to conditions in institutions and correctional facilities and the treatment and care of birthing parents in such institutions and facilities."
    }
  ],
