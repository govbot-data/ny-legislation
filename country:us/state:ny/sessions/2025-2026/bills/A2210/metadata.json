  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits issuance of certain search warrants relating to out-of-state investigations of abortion services provided in NYS; prohibits corporations domiciled in NYS from complying with certain out-of-state search warrants regarding abortion services provided in NYS."
    }
  ],
