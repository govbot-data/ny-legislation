  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that after an alternate juror has been substituted, the jury shall deliberate anew on all issues submitted to the jury at the outset of deliberations; exempts issues for which a verdict was already rendered."
    }
  ],
