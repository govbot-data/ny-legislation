{
  "legislative_session": "2025-2026",
  "identifier": "A8322",
  "title": "Relates to the determination of salary base for members of the New York city police pension fund",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the determination of salary base for members of the New York city police pension fund; provides that the salary base for members of the New York city police pension fund whose employment with the police department of the city of New York commenced on or after July 1, 2000 shall be determined in the same manner as members whose employment commenced prior to such date."
    }
  ],
