  "title": "Enacts the \"sustainable building materials act of 2025\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"sustainable building materials act\"; enacts into law components of legislation relating to reducing greenhouse gas emissions in construction; provides a sales tax exemption for certain low-carbon building materials (Part A); establishes a grant program for manufacturers of concrete for environmental product declarations (Part B)."
    }
