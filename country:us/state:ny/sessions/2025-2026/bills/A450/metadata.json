{
  "legislative_session": "2025-2026",
  "identifier": "A450",
  "title": "Relates to piggyback bus transportation contracts",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Eliminates the requirement that when the board of education enters into a piggyback contract with another school district that transports students pursuant to a contract with a private transportation contractor, the board finds that the entry into the piggyback contract will result in a cost savings to the school district."
    }
  ],
