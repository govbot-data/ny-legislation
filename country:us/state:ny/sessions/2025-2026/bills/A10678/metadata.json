  "identifier": "A10678",
  "title": "Enacts the planning approval predictability act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the planning board or other administrative body of a town, village or city authorized to designate, review and approve, approve with modifications, or disapprove site plans to develop a standardized form containing all requirements for such site plan review applications; makes related provisions."
    }
  ],
