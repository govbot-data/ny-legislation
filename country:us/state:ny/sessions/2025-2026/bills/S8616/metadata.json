{
  "legislative_session": "2025-2026",
  "identifier": "S8616",
  "title": "Establishes the \"protecting consumers and jobs from discriminatory pricing act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the use of electronic shelving labels, digital shelf display technology, and surveillance pricing in food retail establishments and drug retail establishments; provides injunctive relief and civil penalties."
    }
  ],
