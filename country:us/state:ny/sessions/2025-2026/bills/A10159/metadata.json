  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the managed long term care high acuity stabilization pool to support managed long term care plans that demonstrate high performance on quality measures established by the department and serve a disproportionately high share of members with complex long term care needs or high service utilization."
    }
