{
  "legislative_session": "2025-2026",
  "identifier": "S10290",
  "title": "Relates to restricting the use of electronic monitoring and automated employment decision tools",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Restricts the use by an employer or an employment agency of electronic monitoring or an automated employment decision tool to screen a candidate or employee for an employment decision unless such tool has been the subject of an impact assessment within the last year; requires notice to employment candidates of the use of such tools; provides remedies for violations."
    }
  ],
