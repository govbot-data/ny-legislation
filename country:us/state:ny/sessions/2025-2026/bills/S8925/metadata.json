  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the sale of products that contain 7-hydroxymitragynine at a level that exceeds 2% of total alkaloids or one milligram per serving; establishes fines for the sale of such products."
    }
  ],
