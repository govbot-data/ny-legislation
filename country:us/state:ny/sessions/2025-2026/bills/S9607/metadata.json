  "identifier": "S9607",
  "title": "Relates to certain reforms for agencies subject to the freedom of information law",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires agencies subject to FOIL requirements to promulgate rules and regulations regarding to whom a requestor may appeal a denial and how to request records from or appeal a denial; makes certain provisions relating to publication of contact information for FOIL requests and appeals."
    }
  ],
