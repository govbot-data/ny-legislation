{
  "legislative_session": "2025-2026",
  "identifier": "A8052",
  "title": "Relates to notices of non-renewal provided to a health care professional by a health care plan",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that notices of non-renewal provided by a health care plan to a health care professional shall include an explanation of the reasons for such non-renewal and information for the health care professional to respond to such determination."
    }
  ],
