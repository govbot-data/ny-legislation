  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Extends DEC's authority to regulate management of crabs; authorizes the department of environmental conservation to take any actions necessary to ensure any quota limiting the taking of horseshoe crabs does not exceed certain thresholds."
    }
  ],
