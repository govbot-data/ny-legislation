{
  "legislative_session": "2025-2026",
  "identifier": "S3734",
  "title": "Authorizes the public service commission to establish rules to limit a utility's ability to recover certain operating expenses",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes and directs the public service commission to establish rules to limit a utility's ability to recover its direct or indirect costs associated with its attendance in, participation in, preparation for, or appeal of any rate proceeding conducted before the commission."
    }
  ],
