{
  "legislative_session": "2025-2026",
  "identifier": "S8767",
  "title": "Requires operational safety plans to require employees to check in before taking action at an incident location; directs the office to make efforts to provide employees with operational safety plans",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that an operational safety plan developed by the office of parks, recreation and historic preservation shall require that any employee check in with the incident commander or safety officer for incident specific procedures prior to taking any action at the incident location; provides that when deployment occurs in coordination with one or more other entities, and the office of parks, recreation and historic preservation is not the lead response agency, the office of parks, recreation and historic preservation shall make reasonable efforts to ensure that employees are provided with the incident specific operational safety plan developed by the lead agency and/or incident commander."
    }
  ],
