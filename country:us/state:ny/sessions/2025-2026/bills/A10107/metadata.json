{
  "legislative_session": "2025-2026",
  "identifier": "A10107",
  "title": "Relates to preventing the wasting of assets subject to a potential civil action by a crime victim",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the office of victim services to immediately take such actions as are necessary to avoid the wasting of the assets until the expiration of all applicable statutes of limitation for a crime victim to bring a civil action to recover money or damages from such assets."
    }
  ],
