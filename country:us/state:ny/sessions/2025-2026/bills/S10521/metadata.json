  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides a tax exemption on real property owned by active auxiliary police officers in local law enforcement agencies in certain counties having a population of more than 1.38 million and less than 1.42 million, determined in accordance with the latest federal decennial census."
    }
