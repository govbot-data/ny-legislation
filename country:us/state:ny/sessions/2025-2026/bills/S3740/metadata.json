  "identifier": "S3740",
  "title": "Establishes the \"recovery ready workplace act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the \"recovery ready workplace act\" which provides for the certification of an employer to become a recovery ready workplace; defines terms; establishes the recovery-ready workplace program; provides criteria for employers to obtain certification as a recovery ready workplace; provides for employee involvement."
    }
  ],
