  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a tax on video streaming services; provides that the revenue from the tax is to be used to ensure that every resident in the state has access to modern communications networks; establishes the media arts technology and education fund."
    }
