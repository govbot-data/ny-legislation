{
  "legislative_session": "2025-2026",
  "identifier": "S6282",
  "title": "Relates to certain requirements for waivers issued under the hospital-home care-physician collaboration program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that health regulations may not be waived under the hospital-home care-physician collaboration program without publication and opportunity for public comment; prohibits waiver of an applicant's obligation to meet public need, character and competence, or financial feasibility requirements."
    }
  ],
