  "abstracts": [
    {
      "note": "",
      "abstract": "Provides for direct-pay tax abatement credits for solar electric generating systems and electric energy storage systems in connection with eligible buildings; provides such eligible properties shall include: 501(c)(3) corporations, associations, organizations or trusts and income-restricted affordable housing properties."
    }
