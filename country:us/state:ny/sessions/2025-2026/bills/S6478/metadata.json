  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the maximum contaminant level goals (MCLGs) for emerging contaminants; provides that the commissioner of health shall by regulation establish a maximum contaminant level goal (MCLG) for each emerging contaminant for which such commissioner has established; makes related provisions."
    }
  ],
