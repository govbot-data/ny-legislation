  "identifier": "A10042",
  "title": "Prohibits electric corporations and gas corporations from increasing charges due to legal or regulatory proceeding costs",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits electric corporations and gas corporations from passing along costs or increasing charges to ratepayers as a result of increased costs incurred due to legal or regulatory proceedings against such electric corporation, gas corporation, or utility, including settlements, attorneys' fees, penalties, fines or costs."
    }
