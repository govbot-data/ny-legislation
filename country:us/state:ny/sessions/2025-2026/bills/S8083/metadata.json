{
  "legislative_session": "2025-2026",
  "identifier": "S8083",
  "title": "Relates to staffing at state-operated facilities that deliver health care services",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires each state-operated facility that delivers health care services which is operated and licensed pursuant to the mental hygiene law, the education law, the correction law or section 504 of the executive law and which requires two or more registered nurses or licensed practical nurses to be present within the facility at any given time."
    }
  ],
