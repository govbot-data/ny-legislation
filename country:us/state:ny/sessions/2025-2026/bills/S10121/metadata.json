  "identifier": "S10121",
  "title": "Establishes a former foster youth priority program that reserves a proportion of units in applicable housing lotteries for eligible former foster youth",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a former foster youth priority program that reserves at least five percent of units in housing lotteries that are administered by the New York city department of housing preservation and development or the New York city housing development corporation for eligible former foster youth; authorizes the promulgation of rules, regulations and marketing handbooks and procedural guidelines; establishes reporting requirements."
    }
