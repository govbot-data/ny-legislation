  "identifier": "S6865",
  "title": "Relates to the creation of a \"ebony alert system\" for missing Black youth",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides for the creation of an ebony alert system to be activated on behalf of Black youth who are reported missing under unexplained or suspicious circumstances, at risk, developmentally disabled, or cognitively impaired, or who have been abducted."
    }
  ],
