  "legislative_session": "2025-2026",
  "identifier": "A8934",
  "title": "Relates to advanced transmission technologies",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs electric corporations and combination electric and gas corporations to file a cost-effectiveness and timetable analysis as part of any base rate proceeding with the public service commission; directs NYSERDA to conduct a study on the effectiveness of advanced transmission technologies."
    }
  ],
