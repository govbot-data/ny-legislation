  "identifier": "A5507",
  "title": "Relates to deadlines for special presidential ballot applications for military voters",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that an application for a military ballot from a military voter shall be received at least fifteen days before an election in order to entitle the applicant to vote at such election."
    }
  ],
