{
  "legislative_session": "2025-2026",
  "identifier": "S6853",
  "title": "Prohibits unsolicited telemarketing sales calls during certain declared states of emergency",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits unsolicited telemarketing sales calls during a declared state of emergency or disaster emergency where the declaration or proclamation of emergency includes a finding that unsolicited telemarketing sales calls would impair actions taken to limit, control, or mitigate the emergency; explains the basis of such finding; provides that such prohibition may not extend for a period of more than two weeks, subject to renewal for additional two-week periods by further findings of necessity made at the end of each two-week period."
    }
  ],
