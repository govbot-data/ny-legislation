  "abstracts": [
    {
      "note": "",
      "abstract": "Grants family leave benefits to persons who perform artistic and cultural work, including but not limited to, artistic and performing personnel, creative and design personnel, technical and production personnel, and front-of-house support personnel engaged in the production or operation of live theatrical or artistic performances."
