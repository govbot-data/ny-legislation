{
  "legislative_session": "2025-2026",
  "identifier": "S401",
  "title": "Establishes the \"tenant opportunity to purchase act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the \"tenant opportunity to purchase act\"; prevents the displacement of middle and lower-income tenants in New York and preserves affordable housing by providing an opportunity for tenants to own or remain renters in the properties in which they reside."
    }
  ],
