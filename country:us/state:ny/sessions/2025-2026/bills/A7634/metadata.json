{
  "legislative_session": "2025-2026",
  "identifier": "A7634",
  "title": "Relates to hotel and motel taxes in Saratoga county and the city of Saratoga Springs",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to hotel and motel taxes in Saratoga county and the city of Saratoga Springs; increases the allowable amount of tax imposed by the county; removes exemptions for properties having less than 4 units; relates to the disposition of tax revenues collected; eliminates an advisory committee."
    }
  ],
