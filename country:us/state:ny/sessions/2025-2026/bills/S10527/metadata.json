  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a program to conduct annual audits of commercial driver's license records maintained by the department of motor vehicles; requires the department of motor vehicles to notify licensees of deficiencies and provide an opportunity to cure such deficiencies; requires annual reporting to the governor and legislature; makes related provisions."
    }
