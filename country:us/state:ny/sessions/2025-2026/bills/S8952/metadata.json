{
  "legislative_session": "2025-2026",
  "identifier": "S8952",
  "title": "Relates to disclosures by sellers of digital goods",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits a seller of a digital good from advertising or offering for sale a digital good to a purchaser with the terms \"buy,\" \"purchase,\" or any other term which a reasonable person would understand to confer an unrestricted ownership interest in the digital good, or alongside an option for a time-limited rental, unless the seller receives at the time of each transaction an affirmative acknowledgment from the purchaser, or the seller provides to the consumer before executing each transaction a clear and conspicuous statement."
    }
  ],
