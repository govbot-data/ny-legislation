  "identifier": "S9626",
  "title": "Establishes certain contract requirements involving glazing work",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes certain contract requirements involving glazing work; provides that certain contracts over one million and five million dollars that include glazing work to be performed outside of a city with a population of one million or more shall require such work be performed by North American Contractor Certification (\"NACC\") certified companies; defines glazing work."
    }
  ],
