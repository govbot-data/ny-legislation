{
  "legislative_session": "2025-2026",
  "identifier": "S6977",
  "title": "Provides a tax exemption on real property owned by active auxiliary police officers in local law enforcement agencies in certain counties",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides a tax exemption on real property owned by active auxiliary police officers in local law enforcement agencies in certain counties having a population of more than three hundred thirty-eight thousand and less than three hundred forty thousand, determined in accordance with the latest federal decennial census."
    }
  ],
