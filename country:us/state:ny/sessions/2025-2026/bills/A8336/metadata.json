{
  "legislative_session": "2025-2026",
  "identifier": "A8336",
  "title": "Enacts the \"faithless servant reform act\"",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"faithless servant reform act\", creating a rebuttable presumption of retaliation or discrimination for certain actions of an employer; provides that the employer maintains the burden of proof in certain actions against an employee; limits an employer's remedy of forfeiture against an employee's compensation."
    }
  ],
