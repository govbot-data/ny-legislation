  "title": "Relates to the crimes of disruption or disturbance of a religious service, funeral, burial or memorial service in the first degree and second degree",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Designates the crime of disruption or disturbance of a religious service, funeral, burial or memorial service as disruption or disturbance of a religious service, funeral, burial or memorial service in the second degree and adds the crime of disruption or disturbance of a religious service, funeral, burial or memorial service in the first degree as a class E felony."
    }
