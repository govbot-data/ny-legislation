{
  "legislative_session": "2025-2026",
  "identifier": "A8634",
  "title": "Establishes maximum contaminant levels and a hazard index in drinking water for certain per- and polyfluoroalkyl substances (PFAS)",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes maximum contaminant levels in drinking water for certain per- and polyfluoroalkyl substances (PFAS); sets such levels at no higher than 4 parts per trillion (ppt) for perfluorooctane sulfonic acid (PFOS) and perfluorooctanoic acid (PFOA) and no higher than 10 parts per trillion (ppt) for perfluorononanoic acid (PFNA), perfluorohexane sulfonate (PFHxS), and hexafluoropropylene oxide dimer acid (HFPO-DA)."
    }
  ],
