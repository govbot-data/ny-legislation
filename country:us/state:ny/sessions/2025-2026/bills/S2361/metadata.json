  "identifier": "S2361",
  "title": "Relates to adolescent offenders authorized to be removed to family court",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Exempts adolescent offenders who displayed a shotgun, rifle or deadly weapon in furtherance of the underlying offense, or who were illegally in possession of a loaded firearm, from those authorized to be removed to family court."
    }
  ],
