  "identifier": "S4989",
  "title": "Requires utility service providers to disclose planned rate increases to consumers within a certain amount of time",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires utility service providers to disclose planned rate increases to consumers within thirty days before a planned price increase takes effect; requires utility providers to provide contact information and a mechanism to cancel service completely."
    }
  ],
