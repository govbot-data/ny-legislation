  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits money judgments arising from non-payment of facility items and services by a patient or patient guarantor that is brought by a facility; prohibits the enforcement of arbitration agreements or clauses with respect to non-payment of facility items and services by a patient or patient guarantor; relates to the collection of medical debt; requires transparency in hospital pricing."
    }
