{
  "legislative_session": "2025-2026",
  "identifier": "S2590",
  "title": "Requires nonpublic schools provide and maintain on-site automatic external defibrillators on school grounds",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires nonpublic schools provide and maintain on-site automatic external defibrillator (AED) equipment on school grounds and assure that AED equipment is available for off-site curricular events, extracurricular events or school-sponsored athletic events."
    }
  ],
