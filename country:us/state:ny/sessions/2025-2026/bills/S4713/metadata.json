  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Designates records and information relating to a patient who has been deceased for a period of fifty years or longer as historic records no longer subject to privacy protections; provides that such provisions shall not be construed as requiring a facility to retain records for any particular length of time."
    }
  ],
