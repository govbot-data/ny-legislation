{
  "legislative_session": "2025-2026",
  "identifier": "A9561",
  "title": "Relates to the distribution of road salt",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires that the department of transportation and every municipality, locality and public authority shall not spread road salt at a rate higher than three hundred pounds per lane mile on average during each snow and ice management season."
    }
  ],
