  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to reimbursement for anesthesia services; provides that an insurer may use a time related reimbursement methodology for anesthesia services if such methodology is based upon criteria established by an independent organization."
    }
