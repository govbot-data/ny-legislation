  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"who you gonna call? act\"; classifies vehicles of the office of chief medical examiner of the city of New York as an emergency vehicle; classifies any actual or potential scene where the New York city office of chief medical examiner has an official role as an emergency operation; authorizes vehicles of the office of chief medical examiner of the city of New York to affix vehicles with blue, red and white lights."
    }
  ],
