{
  "legislative_session": "2025-2026",
  "identifier": "S8527",
  "title": "Relates to the clergy property tax exemption",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Permits local governments to extend the existing clergy residential property tax exemption to include clergy residing in co-ops; clarifies that the clergy property tax exemption shall not affect eligibility for certain other tax abatements."
    }
  ],
