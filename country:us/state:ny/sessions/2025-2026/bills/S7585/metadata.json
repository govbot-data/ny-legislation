{
  "legislative_session": "2025-2026",
  "identifier": "S7585",
  "title": "Authorizes owners of mobile barber shops to obtain barber shop owner's licenses",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes owners of mobile barber shops to obtain barber shop owner's licenses provided that they can furnish proof of title, possession, registration and driver's license authorizing operation of the vehicle to be used to operate the mobile barber shop and proof of proper layout, adequate equipment for the shop, sanitary conditions in the shop and good moral character."
    }
  ],
