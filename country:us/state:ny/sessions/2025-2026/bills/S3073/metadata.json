{
  "legislative_session": "2025-2026",
  "identifier": "S3073",
  "title": "Establishes a civil remedy for the protection of animals denied proper care",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a civil remedy for the protection of animals denied proper care by creating a special proceeding in the supreme court that will hold owners and caretakers liable if such animals under their care are mistreated."
    }
  ],
