{
  "legislative_session": "2025-2026",
  "identifier": "S7491",
  "title": "Relates to the statute of limitations for certain deed theft actions, revives such actions otherwise barred by the existing statute of limitations, and grants trial preference to such actions",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the statute of limitations for certain deed theft actions; revives such actions otherwise barred by the existing statute of limitations and states who may bring such actions; grants trial preference to such actions; directs the chief administrator of the courts to promulgate rules for the timely adjudication of certain revived actions."
    }
  ],
