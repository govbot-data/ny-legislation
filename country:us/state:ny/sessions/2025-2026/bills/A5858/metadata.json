  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires third-party food delivery services to verify that limited-use motorcycles and motor vehicles operated by workers in the course of making deliveries for such third-party delivery service are legally registered; requires that a third-party food delivery service shall not sell, share, or allow access to such information."
    }
