  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts protections for private education loan borrowers and cosigners; requires certain notifications from creditors and debt collectors; prohibits acceleration; enacts provisions for cosigner release."
    }
  ],
