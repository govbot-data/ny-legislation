{
  "legislative_session": "2025-2026",
  "identifier": "S9888",
  "title": "Requires certain motion picture theaters to provide scheduled showings of motion pictures with open motion picture captioning",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires a motion picture theater that offers more than ten motion picture showings per week to provide scheduled showings of motion pictures with open motion picture captioning such that at least one quarter of all showings of a motion picture with four or more showings during a one-week time period shall have open motion picture captioning; provides exceptions and penalties for violations."
    }
  ],
