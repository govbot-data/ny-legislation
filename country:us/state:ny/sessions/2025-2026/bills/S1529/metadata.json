{
  "legislative_session": "2025-2026",
  "identifier": "S1529",
  "title": "Establishes a carbon farming tax credit for farmers",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the carbon farming certification committee for the purpose of developing a certification framework, determining qualified carbon removal practices eligible for the carbon farming tax credit, and promulgating certification standards for qualified carbon removal practices; provides for the development of educational materials to encourage carbon farming by promoting farming practices which reduce, sequester and mitigate greenhouse gas emissions on land used in support of a farm operation; establishes carbon farming tax credits."
    }
  ],
