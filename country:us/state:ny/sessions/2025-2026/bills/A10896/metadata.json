  "identifier": "A10896",
  "title": "Delays the zero-emission school bus mandate",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Delays the zero-emission school bus mandate for a period of five years; requires school districts to only purchase or lease zero-emission school buses by 2032 and requires school districts to only operate and maintain zero-emission school buses by 2040."
    }
  ],
