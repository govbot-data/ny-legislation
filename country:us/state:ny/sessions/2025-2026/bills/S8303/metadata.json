  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Increases the small purchase threshold for purchase contracts for supplies, materials or equipment involving an estimated expenditure in excess of the New York city school construction authority from ten thousand dollars to one hundred thousand dollars."
