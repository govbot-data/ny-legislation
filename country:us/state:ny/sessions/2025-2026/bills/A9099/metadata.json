{
  "legislative_session": "2025-2026",
  "identifier": "A9099",
  "title": "Relates to health care payment amounts",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires an insurance company which owns a health care provider to pay any health care provider which it does not own an amount that is no less than the amount that it pays a health care provider which it does own for a comparable service; prohibits an insurance company which is owned by a health care provider from paying any health care provider which does not own such insurance company an amount that is less than the amount that it pays a health care provider which does own such company for a comparable service."
    }
  ],
