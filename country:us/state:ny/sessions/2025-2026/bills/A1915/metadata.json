{
  "legislative_session": "2025-2026",
  "identifier": "A1915",
  "title": "Provides for primary care investment",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires health care plans and payors to have a minimum of twelve and one-half percent of their total expenditures on physical and mental health annually be for primary care services."
    }
  ],
