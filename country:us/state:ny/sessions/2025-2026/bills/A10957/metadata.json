  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a narcolepsy and sleep disorder education and awareness program to reduce stigma and promote screening, diagnosis, and management through evidence-based treatment and medication for narcolepsy and other sleep disorders."
    }
