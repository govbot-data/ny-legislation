{
  "legislative_session": "2025-2026",
  "identifier": "S8764",
  "title": "Relates to consideration of capital expenditures in rate proceedings",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires that any proposed capital expenditure to be considered in any matter affecting a major change in rates must be described by the utility on a per project basis and shall include the purpose and the need for each capital expenditure, total cost, and benefits to the ratepayers and the operation of the distribution system, and shall be posted on the PSC website."
    }
  ],
