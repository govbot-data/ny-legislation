  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that space be set aside in the capitol for the display of the Veteran Suicide Awareness and Remembrance Flag and plaque for the raising of awareness of veteran suicide; directs the commissioner of general services to place and maintain such flag and plaque."
    }
