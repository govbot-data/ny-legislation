{
  "legislative_session": "2025-2026",
  "identifier": "S5228",
  "title": "Directs the office of children and family services to establish a center for fatherhood initiatives",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the office of children and family services to establish a center for fatherhood initiatives to issue grants to initiatives regarding the promotion and advancement of fatherhood, including but not limited to all underserved fatherhood groups to help expand opportunities to improve parenting knowledge, attitudes, and self-efficacy."
    }
  ],
