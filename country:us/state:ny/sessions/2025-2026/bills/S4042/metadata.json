{
  "legislative_session": "2025-2026",
  "identifier": "S4042",
  "title": "Relates to enacting the \"traveling with dignity act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides for adult changing tables to be placed within an enclosed restroom facility or other similar private facility that is for use by persons with disabilities who need help with diapering at commercial places of public amusement and state-owned buildings open to the public."
    }
  ],
