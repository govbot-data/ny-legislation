  "identifier": "S8429",
  "title": "Relates to holders of certain operating certificates authorized to provide behavioral analysis services, or to employ or contract with applied behavior analysts and mental health counselors",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes holders of certain operating certificates for treatment of persons with developmental disabilities to provide behavioral analysis services, so long as the professional providing such services is operating within their scope of practice; authorizes holders of such operating certificates to employ or contract with applied behavior analysts and mental health counselors."
    }
  ],
