  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the transfer of funds from the tuition reimbursement account to the proprietary vocational school supervision account in the event that the net balance of the tuition reimbursement account is in excess of two million five hundred thousand dollars."
    }
