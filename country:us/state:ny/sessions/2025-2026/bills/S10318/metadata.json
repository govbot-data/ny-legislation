{
  "legislative_session": "2025-2026",
  "identifier": "S10318",
  "title": "Establishes a tax credit for same-sex couples re-recording their property deeds to reflect a change in status from tenants in common or joint tenants with right of survivorship to tenancy by the entirety",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a tax credit for same-sex couples who purchased residential property in the state prior to the legalization of same-sex marriage, were prohibited from recording the deed as tenants by the entirety, and who re-record the deed to reflect a change in status from tenants in common or joint tenants with right of survivorship to tenants by the entirety; provides for the repeal of such provisions upon the expiration thereof."
    }
  ],
