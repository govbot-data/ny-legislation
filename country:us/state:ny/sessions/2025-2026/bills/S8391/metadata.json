  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the right of publicity; amends the definitions of \"deceased performer\", \"deceased personality\" and \"digital replica\" in relation to the right of publicity; relates to the use of a deceased performer's digital replica without authorization by the applicable right holder."
    }
  ],
