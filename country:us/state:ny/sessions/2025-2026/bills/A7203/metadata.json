  "identifier": "A7203",
  "title": "Enacts the \"New York state nurse employment, enhancement and dignity act\"",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"New York state nurse employment, enhancement and dignity act\" to provide hazard pay to nurses during a state disaster emergency, an annual tax credit for nurses, a student loan forgiveness program for nurses, and preferential school admission for nurses."
    }
  ],
