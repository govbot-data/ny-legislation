  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes municipalities and the department of financial services to seek civil penalties for violations of the duty to maintain a foreclosed property in an amount of up to $500 per day for each day such violation persists after the judgement of foreclosure has been issued."
    }
  ],
