{
  "legislative_session": "2025-2026",
  "identifier": "S9762",
  "title": "Establishes civil liability for the deprivation of any rights, privileges, or immunities secured by the federal or state constitution",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that every person who, under color of any statute, ordinance, regulation, custom, or usage, of the United States, subjects or causes to be subjected any citizen of New York or other person within the jurisdiction thereof to the deprivation of any rights, privileges, or immunities secured by the federal or state constitution shall be liable to the injured party in an action at law, suit in equity, or other proper proceeding."
    }
  ],
