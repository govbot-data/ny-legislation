  "identifier": "S7242",
  "title": "Relates to the imposition of securing orders for certain crimes committed by individuals without permanent residency status",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the imposition of securing orders for offenses committed on a peace officer, police officer, firefighter, emergency medical services professional or uniformed worker by individuals without permanent residency status; provides such individuals shall be remanded to the custody of the sheriff for the entirety of the judicial proceedings related thereto."
    }
  ],
