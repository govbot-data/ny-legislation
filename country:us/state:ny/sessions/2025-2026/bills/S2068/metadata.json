{
  "legislative_session": "2025-2026",
  "identifier": "S2068",
  "title": "Establishes an active service exemption",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes municipalities to offer a real property tax exemption for active military service members who at any time during the taxable year performed active duty in the armed forces in a combat zone; defines terms; makes related provisions."
    }
  ],
