{
  "legislative_session": "2025-2026",
  "identifier": "S4066",
  "title": "Enacts the \"affordable clean energy (ACE) act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"affordable clean energy (ACE) act\"; exempts renewable energy systems from certain requirements related to energy facilities (Part A); directs the New York power authority to propose a minimum of two priority transmission projects to address the areas of highest need on the bulk transmission system (Part B); exempts payment in lieu of taxes revenue from property tax cap calculations (Part C)."
    }
  ],
