  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Permits certified handicapped individuals and senior citizens to use all-terrain vehicles on state land for certain hunting purposes; directs the department of environmental conservation to establish a senior game recovery permit program to allow use of all-terrain vehicles on state lands by senior hunters for the purpose of retrieving big game."
    }
