{
  "legislative_session": "2025-2026",
  "identifier": "A6484",
  "title": "Relates to copayment and coinsurance charged for physical and occupational therapy services",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that any copayment or coinsurance amount charged by an insurer to the insured for services rendered by a physical therapist or an occupational therapist shall not be more than twenty-five percent greater than the copayment or coinsurance amount imposed for an office visit to a licensed primary care physician or osteopath for the same or a similar diagnosed condition."
    }
  ],
