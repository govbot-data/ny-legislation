  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Permits licensed pharmacists and nurse practitioners to prescribe and order COVID-19 immunizations; permits physicians to issue non-patient specific orders to pharmacists for COVID-19 immunizations for patients two years of age and older; permits pharmacists to issue patient specific orders for COVID-19 immunizations for patients two years of age and older."
    }
