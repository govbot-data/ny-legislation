  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides additional documentation a tenant may provide to demonstrate that such tenant or a member of such tenant's household has been a victim of domestic violence for purposes of permitting the termination of residential lease by victims of domestic violence."
    }
