{
  "legislative_session": "2025-2026",
  "identifier": "A742",
  "title": "Requires certain owners of multiple dwellings in N.Y. city to designate a secure space for packages to be delivered to",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires owners of multiple dwellings with fifty or more units in cities with a population of one million or more to designate a secure, locked, monitored space, accessible only to staff, residents, or delivery people, for packages to be delivered to."
    }
  ],
