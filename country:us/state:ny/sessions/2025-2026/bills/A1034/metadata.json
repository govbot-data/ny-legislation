{
  "legislative_session": "2025-2026",
  "identifier": "A1034",
  "title": "Includes masking products within the definition of drug-related paraphernalia",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Includes masking products including but not limited to synthetic urine, human urine, a substance used or designed to be added to human urine or a substance used or designed to be added to a chemical test, within the definition of drug-related paraphernalia."
    }
  ],
