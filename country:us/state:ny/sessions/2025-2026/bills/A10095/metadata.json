{
  "legislative_session": "2025-2026",
  "identifier": "A10095",
  "title": "Enacts the \"licensed funeral arranger act\"",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"licensed funeral arranger act\" under which a \"licensed funeral arranger\" license allows a funeral arranger to perform all acts permitted to a funeral director except embalming or any preservation of the body of a deceased person requiring embalming; creates a registration process under which registered transporters facilitate the removal and transportation of the bodies of deceased persons."
    }
  ],
