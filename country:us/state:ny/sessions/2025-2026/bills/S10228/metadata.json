  "identifier": "S10228",
  "title": "Relates to the date of enrollment in the child health insurance plan program; repealer",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Eliminates the prospective enrollment waiting period for children under the age of nineteen enrolling in the child health insurance plan program by enrolling a child retroactively to the first day of the month in which they are approved for coverage under such program."
    }
  ],
