  "title": "Relates to protections for renters using certain housing subsidies or public assistance",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Protects renters using a housing subsidy or voucher, or receiving public assistance from discrimination by the housing provider based on such renters' income or use of such housing subsidy, voucher or public assistance."
    }
