  "title": "Authorizing the town of Fishkill and the village of Fishkill to adopt a local law to impose a hotel/motel occupancy tax",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the town of Fishkill to adopt a local law to impose a hotel/motel occupancy tax for hotels not located in the village of Fishkill; authorizes the village of Fishkill to adopt local laws to impose a hotel/motel occupancy tax in such village; provides for the repeal of such provisions upon expiration thereof."
    }
  ],
