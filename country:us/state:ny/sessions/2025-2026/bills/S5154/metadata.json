  "legislative_session": "2025-2026",
  "identifier": "S5154",
  "title": "Imposes a special tax on artwork, antique furniture, and antique jewelry sold at auction and establishes the art education fund",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Imposes a special tax of three-tenths of one percent or one dollar, whichever is greater, on the receipts from the sale of art, antique furniture or antique jewelry at auction; establishes the art education fund to provide assistance for art education and art supplies at the kindergarten through twelfth grade levels at Title I public schools."
    }
  ],
