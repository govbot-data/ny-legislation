  "legislative_session": "2025-2026",
  "identifier": "S2517",
  "title": "Relates to ignition interlock devices",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires proof of installation, maintenance and regular use of ignition interlock devices when use of such a device is ordered by a court; extends the period of suspension and revocation of a license until such proof is provided."
    }
  ],
