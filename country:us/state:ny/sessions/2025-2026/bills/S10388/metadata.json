{
  "legislative_session": "2025-2026",
  "identifier": "S10388",
  "title": "Defines satisfaction of judgment and authorizing satisfactions to be filed on affirmation",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Defines the term \"satisfaction\" in relation to the satisfaction of judgments; allows satisfaction of judgments to be filed by affirmation rather than after notarization; increases the time during which attorneys may file satisfaction of judgment from ten to twenty years; clarifies that the twenty-day time limit applicable to filing satisfactions of judgment is measured in business days."
    }
  ],
