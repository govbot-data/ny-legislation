  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"homeowner defense and anti-deed theft act\" in relation to establishing a homeowner defense and anti-deed theft program within the department of state for the purpose of defending homeowners against deed theft; establishes the county recording modernization fund and the title defense litigation fund."
    }
  ],
