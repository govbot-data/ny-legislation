  "title": "Relates to regulating the practice of naturopathic medicine",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Regulates the practice of naturopathic medicine; establishes a state board for naturopathic medicine; establishes requirements to receive a limited permit in naturopathic medicine; establishes mandatory continuing education for the practice of naturopathic medicine; requires licensed naturopathic doctors to report suspected child abuse."
    }
