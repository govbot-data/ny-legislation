{
  "legislative_session": "2025-2026",
  "identifier": "A8043",
  "title": "Prohibits octopus farming",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that no person shall engage in the operation of a marine hatchery or in the off-bottom or on-bottom culture of any species belonging to the order Octopoda unless for scientific or educational purposes for the purpose of human consumption."
    }
  ],
