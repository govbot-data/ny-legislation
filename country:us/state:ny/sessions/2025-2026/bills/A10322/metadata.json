{
  "legislative_session": "2025-2026",
  "identifier": "A10322",
  "title": "Relates to residential transition conferences and the placement of persons with developmental disabilities",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires covered operators to provide written notice of pending placement of persons with developmental disabilities to interested parties; specifies who may be considered an interested party; provides that a residential transition conference shall be held between the interested parties after notice has been given of the proposed placement to discuss the proposal."
    }
  ],
