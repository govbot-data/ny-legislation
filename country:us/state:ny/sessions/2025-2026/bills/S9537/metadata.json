  "identifier": "S9537",
  "title": "Relates to motor vehicle insurance fairness; repealer",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to motor vehicle insurance fairness; provides that insurance rates shall not be increased based on certain factors; sets forth processes for motor vehicle insurers to have rate increases approved; allows public access in relation to any proposed insurance rate increases; allows members of the public to request permission to intervene in proceedings related to rate increases; directs rules and regulations to be established."
    }
  ],
