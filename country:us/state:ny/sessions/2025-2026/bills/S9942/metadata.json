  "identifier": "S9942",
  "title": "Establishes the climate protection insurance act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the insure our communities act to implement climate leadership and community protection act targets for insurers; identifies and protects such communities; relates to affordability of insurance rates; assesses covered insurance companies' record of performance at meeting insurance needs; requires covered insurance companies to file statistical reports, including information on insurance coverage in specific assessment areas and disadvantaged communities."
    }
  ],
