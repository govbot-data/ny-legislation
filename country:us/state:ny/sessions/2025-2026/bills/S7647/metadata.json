  "identifier": "S7647",
  "title": "Requires a statement of the full sales price of real property being conveyed and proof of such sales price to be submitted to the recording officer",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"deed theft: proof of sale price act\" requiring a statement of the full sales price of real property being conveyed and proof of such sales price to be submitted to the recording officer in order for such officer to record or accept for recording the conveyance of real property."
    }
  ],
