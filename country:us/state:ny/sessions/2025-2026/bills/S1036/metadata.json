{
  "legislative_session": "2025-2026",
  "identifier": "S1036",
  "title": "Provides that a voter may register to vote at any residence to which the voter maintains a continuous connection with an intent to remain",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that a voter may register to vote at any residence to which the voter maintains a continuous connection with an intent to remain, including a second home or a vacation home or a home where a student lives while attending a college or university."
    }
  ],
