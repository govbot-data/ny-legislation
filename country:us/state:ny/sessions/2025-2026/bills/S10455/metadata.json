  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Expands the definition of professional misconduct to include refusing to provide professional services to a person referred for treatment by a United States Department of Veterans Affairs facility or provider because such person declines elective services during the course of treatment."
    }
