  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Increases the length of the term of office for members of the legislature from two to four years with no member serving more than sixteen years; imposes term limits on the governor, lieutenant-governor, comptroller, and attorney-general."
    }
  ],
