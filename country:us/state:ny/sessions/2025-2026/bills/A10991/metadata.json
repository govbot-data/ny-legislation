  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the tenant power act; authorizes the establishment of tenant unions and sets forth the powers and duties of such organizations; establishes the statewide tenant association; provides for the enforcement of such provisions; establishes the statewide tenant association fund; makes an appropriation therefor."
    }
