{
  "legislative_session": "2025-2026",
  "identifier": "A6388",
  "title": "Relates to the establishment of local comprehensive emergency management plans",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the inclusion of local and municipal animal shelters, any duly incorporated society for the prevention of cruelty to animals and veterinary services when establishing local comprehensive emergency management plans; requires that information to the public include the communication accommodation needs of persons with vision or hearing impairments and information on which temporary housing and other necessary facilities are designated as animal-friendly."
    }
  ],
