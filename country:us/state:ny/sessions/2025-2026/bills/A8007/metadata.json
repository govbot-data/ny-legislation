{
  "legislative_session": "2025-2026",
  "identifier": "A8007",
  "title": "Relates to requiring food service establishments to permit the use of reusable beverage and food containers provided by customers",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires food service establishments to permit the use of reusable beverage and food containers provided by customers when requesting a beverage refill or requesting leftovers from a partially consumed meal to be packaged and post signs to inform customers that they are permitted to do so."
    }
  ],
