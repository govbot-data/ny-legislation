  "identifier": "S10393",
  "title": "Enacts the New York mosquito surveillance act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the commissioner of environmental conservation to establish a New York mosquito surveillance task force to study and assess the future of mosquito surveillance in the state; directs a plan to be submitted after one year of effectiveness; directs counties to develop and submit plans of action to begin, continue, or expand mosquito surveillance."
    }
