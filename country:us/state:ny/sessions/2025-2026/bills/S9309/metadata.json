{
  "legislative_session": "2025-2026",
  "identifier": "S9309",
  "title": "Enacts the \"deed protection act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"deed protection act\" in relation to prohibiting a mortgage banker or mortgage loan servicer from commencing, maintaining, or proceeding with a foreclosure action on a mortgage loan where such mortgage banker or mortgage loan servicer knows or has reason to know that the mortgage securing such loan is dependent on a deed, conveyance, or other instrument affecting title to residential real property that was procured by fraud, forgery, or other unlawful means."
    }
  ],
