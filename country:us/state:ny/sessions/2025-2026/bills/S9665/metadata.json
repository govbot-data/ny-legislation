  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to prohibiting the acquisition or transfer of agricultural land by foreign adversaries after January 1, 2026; provides that such prohibition will not apply to any interest in agricultural land held by a foreign adversary prior to such date or any federally recognized Indian tribe or its government units and enterprises; defines terms."
    }
  ],
