  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the topics of the course required to be taken by practitioners certifying patients as eligible for medical cannabis; establishes the endocannabinoid system awareness program; requires the office of cannabis awareness and the department of health to publish information about the endocannabinoid system awareness program on their websites."
    }
