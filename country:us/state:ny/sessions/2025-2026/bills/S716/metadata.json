  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the passing of stopped school buses on divided highways; provides that vehicles traveling in the opposite direction of a school bus on such highway shall not have to stop if a physical barrier is present between the different directions of travel."
    }
  ],
