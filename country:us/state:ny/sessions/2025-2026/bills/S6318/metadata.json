{
  "legislative_session": "2025-2026",
  "identifier": "S6318",
  "title": "Requires instruction in arts and music education to be incorporated into curriculums for all public school students",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires instruction in arts and music education to be incorporated into curriculums for all public school students; requires school districts to ensure that appropriately certified teachers are providing such education; authorizes rules and regulations consistent with such provisions."
    }
  ],
