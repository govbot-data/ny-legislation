{
  "legislative_session": "2025-2026",
  "identifier": "A11560",
  "title": "Enacts the responsible data center development act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Places a one year moratorium on the issuance of data center permits; requires utilities to establish an independent classification of service for large data centers; sets energy efficiency goals for data centers; provides for benefits for host communities; sets labor standards for the construction of data centers."
    }
  ],
