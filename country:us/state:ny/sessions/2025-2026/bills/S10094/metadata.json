{
  "legislative_session": "2025-2026",
  "identifier": "S10094",
  "title": "Relates to winter road maintenance data collection and monitoring",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a standardized statewide system for collecting, recording, and monitoring winter road maintenance operational data in order to improve efficiency, enhance transparency, and support the protection of water resources in the state of New York; requires calibration of all deicing material application equipment used for winter highway maintenance on public roads."
    }
  ],
