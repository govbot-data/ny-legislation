  "abstracts": [
    {
      "note": "",
      "abstract": "Provides a legacy credit to the children and siblings of veterans who were killed in the line of duty including veterans who were disabled as a result of their service, exposed to toxic substances, or presumptive conditions determined by the department of veterans affairs."
