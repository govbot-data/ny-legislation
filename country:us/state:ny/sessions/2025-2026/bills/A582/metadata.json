{
  "legislative_session": "2025-2026",
  "identifier": "A582",
  "title": "Provides for elder abuse prevention training",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the office for the aging to develop and provide elder abuse prevention training to train senior service centers and entities that contract with the office for the aging and the office of children and family services to provide services to elderly persons in the detection and reporting of elder abuse in consultation with the office of children and family services."
    }
  ],
