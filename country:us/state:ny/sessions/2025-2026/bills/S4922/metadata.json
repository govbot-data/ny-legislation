{
  "legislative_session": "2025-2026",
  "identifier": "S4922",
  "title": "Relates to the sale and possession of self-defense spray devices in the state; repealer",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the sale and possession of self-defense spray devices in the state; removes the requirement that only authorized dealers and pharmacists could sell such devices; provides that no more than two self-defense spray devices may be sold at any one time to a single purchaser; repeals certain provisions of law relating thereto."
    }
  ],
