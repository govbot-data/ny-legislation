  "identifier": "S7904",
  "title": "Enacts the \"safe haven baby box act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"safe haven baby box act\" to provide a defense to endangering the welfare of a child; defines \"safe haven baby box\" to mean a secure, climate-controlled device installed at a facility staffed twenty-four hours per day, seven days per week, including but not limited to hospitals, police stations, fire stations, and emergency medical service facilities."
    }
  ],
