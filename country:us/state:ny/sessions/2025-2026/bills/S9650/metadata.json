  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits landlords from including incorrect information relating to rent decontrol in certain leases and renewals thereof; imposes a violation punishable by a fine of $1000 for a violation by a landlord; requires the standardization of certain notices pertaining to units subject to the Affordable New York Housing Program."
    }
