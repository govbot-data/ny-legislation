{
  "legislative_session": "2025-2026",
  "identifier": "S8062",
  "title": "Requires certain utility corporations and the Long Island power authority to establish a meter usage monitor program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires certain utility corporations and the Long Island power authority to establish a meter usage monitor program for the purposes of notifying residential customers when energy usage exceeds a cost or usage threshold in a given billing period determined by the residential customer."
    }
  ],
