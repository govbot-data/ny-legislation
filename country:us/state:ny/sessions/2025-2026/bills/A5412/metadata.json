  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the statewide fibroid study program to study fibroids, the treatment of fibroids, potential barriers to the access of treatment for fibroids, and differences in symptoms and access to treatment for women of color."
    }
  ],
