{
  "legislative_session": "2025-2026",
  "identifier": "S9366",
  "title": "Establishes a uniform effective date for health insurance benefit mandates",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a uniform effective date for health insurance benefit mandates by requiring that every law that adds provisions to or amends provisions of sections 3216, 3221, and 4303 of the insurance law requiring a policy of health insurance to provide coverage for a new health care service, treatment, or benefit, or that otherwise mandates coverage under such policy shall take effect no earlier than the first of January next succeeding the date on which it shall have become a law and shall apply to policies and contracts issued, renewed, modified, altered or amended on or after such effective date."
    }
  ],
