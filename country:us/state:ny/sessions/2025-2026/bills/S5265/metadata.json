  "identifier": "S5265",
  "title": "Requires screening incarcerated individuals for eligibility for public benefits prior to release",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires screening incarcerated individuals for eligibility for public benefits prior to release and assistance in applying for such programs; requires officials to seek waivers from the USDA for eligibility for such program."
    }
  ],
