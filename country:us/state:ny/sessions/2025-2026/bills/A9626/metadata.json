  "identifier": "A9626",
  "title": "Relates to absentee ballot drop boxes",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires a board of elections to establish at least one ballot drop-off location in its jurisdiction; requires the ballot drop boxes to be placed 45 days before the election."
    }
