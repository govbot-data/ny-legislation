  "identifier": "S9741",
  "title": "Enacts the \"bird safe buildings act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"bird safe buildings act\" directing the commissioner of general services to incorporate practices and strategies to reduce bird fatality resulting from collisions with certain state-owned or state-leased buildings, and for other purposes; requires the commissioner to develop a design guide that includes features, methods and strategies, and best practices for reducing bird fatalities."
    }
  ],
