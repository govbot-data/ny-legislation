  "identifier": "S7787",
  "title": "Relates to host counties and host municipalities of commercial gaming facilities",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that host counties and host municipalities of commercial gaming facilities receive no reduction in appropriated aid after gaming facilities licensed under title two-A of article 13 of the racing, pari-mutuel wagering and breeding law have commenced gaming operations."
    }
  ],
