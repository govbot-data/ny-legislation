{
  "legislative_session": "2025-2026",
  "identifier": "S336",
  "title": "Relates to grand jury proceedings",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that in grand jury proceedings when following submission to a grand jury of a criminal charge or charges, the grand jury dismisses all charges presented or directs the district attorney to dismiss all charges or directs the DA to file in a local criminal court an application for disclosure of certain materials; authorizes the court to limit disclosure of certain items where there is a reasonable likelihood that such disclosure may lead to the identity of a witness who is not a public servant or expert witness; makes related provisions."
    }
  ],
