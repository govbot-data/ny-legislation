{
  "legislative_session": "2025-2026",
  "identifier": "S7532",
  "title": "Enacts the restriction of anticoagulant pesticide transactions for online and retail stores act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the restriction of anticoagulant pesticide transactions for online and retail stores act to prohibit any person from selling, offering for sale or use, or distributing within the state, any second-generation anticoagulant rodenticide; prohibits the use of either a first-generation anticoagulant rodenticide or a second-generation anticoagulant rodenticide within five hundred feet of a wildlife habitat area."
    }
  ],
