  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the department of health to establish and administer a program for the certification, operation, and oversight of two prescribed pediatric extended care centers to provide supportive services to medically stable and medically complex children who require continual care."
    }
