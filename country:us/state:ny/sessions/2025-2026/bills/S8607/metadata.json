{
  "legislative_session": "2025-2026",
  "identifier": "S8607",
  "title": "Relates to the calculation of statewide greenhouse gas emission limits; repealer",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Amends the definition of \"carbon dioxide equivalent\" to provide that such term be calculated based on a 100-year time frame after emission; provides for rules and regulations to amend the statewide greenhouse gas emissions limit; repeals provisions of law relating to statewide greenhouse gas emissions reductions."
    }
  ],
