  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides for loan forgiveness for social workers who commit to work in counties with less than two hundred thousand population, or towns which have a population of less than one hundred fifty persons per square mile for the duration of the award."
    }
