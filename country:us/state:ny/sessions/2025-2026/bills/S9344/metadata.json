  "title": "Prohibits the issuing of major renewable energy and major electric transmission facility siting permits in designated grassland bird conservation centers",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the issuing of major renewable energy and major electric transmission facility siting permits in designated grassland bird conservation centers including, but not limited to, three such centers in Jefferson county, one center in Saint Lawrence county, the Oak-Orchard-Iroquois center, the Washington County Grasslands center, the Finger Lakes National Forest center and the Shawangunk Grasslands."
    }
  ],
