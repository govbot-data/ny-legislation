  "identifier": "S2000",
  "title": "Relates to mandatory health insurance coverage for follow-up screening or diagnostic services for lung cancer",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires that health insurance policies shall provide coverage for follow-up screening or diagnostic services for lung cancer; provides that no patient cost sharing shall be imposed for follow-up screening or diagnostic services for lung cancer."
    }
  ],
