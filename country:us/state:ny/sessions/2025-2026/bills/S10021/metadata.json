  "identifier": "S10021",
  "title": "Relates to contributions made to certain municipally chartered organizations",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires covered entities to publicly disclose contributions in the amount of, or having a fair market value of, $2,000 or more in a single transaction or $5,000 in aggregate from the same contributor in any calendar year; requires an annual financial report to be filed with the county clerk; makes related provisions."
    }
