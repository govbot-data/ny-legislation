  "legislative_session": "2025-2026",
  "identifier": "S5159",
  "title": "Relates to providing additional duties of the community gardens task force",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the community gardens task force to conduct an assessment of all community gardens located on publicly owned land in the state to facilitate each garden's designation as a critical environmental area."
    }
  ],
