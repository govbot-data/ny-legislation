{
  "legislative_session": "2025-2026",
  "identifier": "S843",
  "title": "Establishes minimum staffing levels for certain local board of elections",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires a board of elections in a county with over ten thousand active registered voters to employ a minimum of four full-time employees which may include the commissioner and deputies if such positions are full time."
    }
  ],
