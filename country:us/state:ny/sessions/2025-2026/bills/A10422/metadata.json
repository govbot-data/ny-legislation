  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires that any sanction or civil penalty imposed by the public service commission be returned to the rate payers by means of a direct bill credit, as soon as practically feasible or no later than ninety days."
    }
