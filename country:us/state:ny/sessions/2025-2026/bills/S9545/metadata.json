  "identifier": "S9545",
  "title": "Relates to unclaimed winnings and refunds and the remittance of taxes",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires a regional off-track betting corporation that is comprised in the capital district to distribute unclaimed winnings and refunds to participating counties comprising the capital district corporation; provides penalties for late distributions; provides for the remittance of pari-mutuel wagering taxes."
    }
  ],
