{
  "legislative_session": "2025-2026",
  "identifier": "S8619",
  "title": "Requires fiscal notes to be included on bills imposing mandated benefits under insurance plans and under the Medicaid fee-for-service program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires fiscal notes to be included on any bill which imposes a new mandated insurance benefit or service; expands an existing mandated insurance benefit or service, or adds, expands or requires coverage of any benefit or service under the Medicaid fee-for-service program; requires such fiscal notes to include an actuarial analysis of the potential impact on insurance premiums as a result of such new or expanded mandated insurance benefit or service."
    }
  ],
