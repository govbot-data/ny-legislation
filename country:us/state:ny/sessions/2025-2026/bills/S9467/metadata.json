{
  "legislative_session": "2025-2026",
  "identifier": "S9467",
  "title": "Establishes procedures to be followed when the body scan of an incarcerated individual, employee or visitor to a correctional facility displays alleged abnormalities",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes procedures to be followed when the body scan of an incarcerated individual, employee or visitor to a correctional facility displays alleged abnormalities; requires staff discipline for staff who have wrongfully denied visitation to a visitor or entry to an employee based on a body scan; requires the collection and reporting of certain information relating to visitation and entry denials based on body scans; requires such law to be posted in visitor processing areas of correctional facilities."
    }
  ],
