{
  "legislative_session": "2025-2026",
  "identifier": "S372",
  "title": "Establishes the \"no severance ultimatums act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the \"no severance ultimatums act\", which prevents employers from giving coercive ultimatums to employees or former employees relating to severance agreements."
    }
  ],
