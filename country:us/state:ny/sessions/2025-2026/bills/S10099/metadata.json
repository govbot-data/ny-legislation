  "identifier": "S10099",
  "title": "Relates to residential solar tax credits",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that for purposes of the solar energy system equipment credit, the definition of \"solar energy system equipment\" includes a portable solar generation device defined as a photovoltaic system and associated equipment that is designed to be connected to a residential building's electrical system through a standard electrical outlet."
    }
