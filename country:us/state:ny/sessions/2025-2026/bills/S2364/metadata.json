  "identifier": "S2364",
  "title": "Designates the Honor and Remember Flag as the official state flag for recognizing armed services members",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Designates the \"Honor and Remember Flag\" as the official state flag for recognizing armed service members who have died as a result of serving the United States in any war or conflict the nation has been involved in since its inception."
    }
  ],
