{
  "legislative_session": "2025-2026",
  "identifier": "A199",
  "title": "Regulates pistol converters and convertible pistols",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Makes it illegal for certain persons to possess or sell a pistol converter or a converted pistol; directs the superintendent of the state police to publish a list of pistols that the superintendent has determined to be convertible pistols."
    }
  ],
