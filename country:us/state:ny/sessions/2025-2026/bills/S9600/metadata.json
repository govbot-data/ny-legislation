{
  "legislative_session": "2025-2026",
  "identifier": "S9600",
  "title": "Relates to off-track betting maintenance of effort payment requirements",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires an off-track betting corporation that accepts wagers on the simulcasts of thoroughbred races from out-of-state or out-of-country to pay to its regional harness track or tracks an amount equal to three percent of handle generated from the acceptance of such wagers from out-of-state or out-of-country thoroughbred tracks after 7:30 P.M."
    }
  ],
