{
  "legislative_session": "2025-2026",
  "identifier": "A9466",
  "title": "Extends paid family leave benefits to certain construction employees",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Extends paid family leave benefits to certain construction employees who shall be eligible for family leave benefits if they were employed for at least twenty-six of the last thirty-nine weeks by any covered employer which is signatory to a collective bargaining agreement; relates to the effectiveness thereof."
    }
  ],
