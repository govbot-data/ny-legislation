  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits utility corporations and municipalities from increasing a bill previously rendered to a small non-residential customer after twelve months from the date service was provided; provides limited exceptions to such prohibition; requires the utility corporation or municipality to provide notice regarding the late billing."
    }
