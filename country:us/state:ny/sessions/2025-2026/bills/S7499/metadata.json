{
  "legislative_session": "2025-2026",
  "identifier": "S7499",
  "title": "Relates to the definition and term of real estate listing agreements",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the definition and term of real estate listing agreements; provides that no real estate broker shall be a party to a listing agreement if such agreement is for a period longer than two years; provides that a listing agreement shall not be enforceable if the agreement is for a period longer than two years."
    }
  ],
