  "abstracts": [
    {
      "note": "",
      "abstract": "Permits an eligible retirement system member to receive, in lieu of an ordinary death benefit, a death benefit such member would otherwise be entitled to receive provided such member is a state-paid judge or justice of the unified court system or a housing judge of the civil court of the city of New York."
    }
