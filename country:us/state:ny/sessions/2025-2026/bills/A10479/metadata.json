  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to artist preferences in housing; provides that giving occupancy preference to individuals who are involved in artistic activities is not an unlawful discriminatory practice provided that such preference is implemented or authorized by an agency or the state of New York."
    }
