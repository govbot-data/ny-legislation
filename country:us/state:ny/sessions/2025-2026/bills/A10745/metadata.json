  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Freezes the assessed value of real property owned by persons aged 65 or over, for the purposes of determining taxes owed on such property, beginning on the date all of such persons reach the age of 65, regardless of the actual assessed value of the property at the time of taxation."
    }
