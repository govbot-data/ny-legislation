{
  "legislative_session": "2025-2026",
  "identifier": "A1191",
  "title": "Requires the division of criminal justice services to study the technological viability of personalized firearms",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"safer weapons, safer homes act\"; requires the division of criminal justice services to study the technological viability of personalized firearms; defines personalized firearms; requires the division to report to the governor and the legislature on the results of the study."
    }
  ],
