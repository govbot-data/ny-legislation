  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides for local input for the dissolution of a fire district by requiring the governing body of the fire district enact a resolution calling for a referendum on the proposed dissolution by the electors in the fire district."
    }
