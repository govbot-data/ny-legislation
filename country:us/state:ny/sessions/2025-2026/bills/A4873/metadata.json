{
  "legislative_session": "2025-2026",
  "identifier": "A4873",
  "title": "Prohibits the operation of N.Y. city transit authority subways or trains without a conductor on board",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the operation of NYC transit authority subways or trains without at least one conductor on board; requires a conductor on any subway or train operated by such authority whenever the subway or train has more than two cars attached to the engine."
    }
  ],
