{
  "legislative_session": "2025-2026",
  "identifier": "S5998",
  "title": "Establishes \"Kyra's Law\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the court to consider a child's health and safety when making a decision regarding child custody and visitation; directs the court to review certain information as it relates to allegations of child abuse, domestic violence and child safety."
    }
  ],
