    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a minimum threshold of five hundred dollars for recovery of overpayment of wages; provides an employee who is alleged to have been overpaid notice and an opportunity to respond to such allegation prior to the state seeking such recovery."
    }
