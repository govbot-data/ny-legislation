  "identifier": "A6559",
  "title": "Establishes a veterans' bill of rights",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a veterans' bill of rights; provides sample language for such bill of rights; requires the department of veterans' services to establish and distribute a veterans' bill of rights and to make such bill of rights available on the department's website."
    }
  ],
