  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the metropolitan transportation authority to post signage over mass transit seats indicating that individuals should give up their seats for the elderly, pregnant and disabled; provides such signage shall be conspicuously posted and visible from all seats; provides costs and expenses to be paid through appropriated funds."
    }
