  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the division of criminal justice to create and disseminate to police departments a video on bicycles with electric assist and electric scooters including information on classification and definitions, legal operation, speed limits and enforcement, helmet and age requirements, and a review of legal operation of such devices."
    }
