  "identifier": "S10086",
  "title": "Relates to residential foreclosure actions",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Clarifies provisions governing when foreclosure actions are deemed abandoned for failure of a plaintiff to timely seek a default judgment; governs when foreclosure actions are deemed terminated for purposes of the savings clause permitting actions to be recommenced following termination of a prior action and be deemed timely; governs the finality of dismissed or discontinued residential foreclosure actions."
    }
  ],
