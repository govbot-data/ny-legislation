  "identifier": "S10101",
  "title": "Establishes an annual food tax holiday exempting sales taxes on certain currently taxable food items in November or December",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes an annual food tax holiday exempting sales taxes on certain currently taxable food items, including hot and cold prepared foods intended for immediate consumption, and any other ready-to-eat item sold in a grocery store, deli or food counter, meals purchased at a restaurant including takeout and delivery orders, in November or December."
    }
  ],
