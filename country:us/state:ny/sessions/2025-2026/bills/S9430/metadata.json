  "identifier": "S9430",
  "title": "Relates to priority applicants and inspection of units under the housing access voucher pilot program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to priority applicants and inspection of units under the housing access voucher pilot program; provides that priority shall be given both to applicants who are homeless and who are at risk of losing their federal rental subsidy; provides that housing access voucher local administrators shall inspect units for which a housing assistance payment contract is established."
    }
  ],
