  "title": "Prohibits trustees and members of a board of education from voting on matters before the board which affect a family member of the trustee or board member",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits trustees and members of a board of education from voting on matters before the board which affect a family member of the trustee or board member who is either employed by the board of education or school district or who would be financially impacted by such vote."
    }
  ],
