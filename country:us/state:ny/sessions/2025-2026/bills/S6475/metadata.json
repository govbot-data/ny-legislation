  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a senior housing task force for the purposes of conducting a state-wide assessment of senior housing needs taking into consideration the various geographical areas and different needs of the seniors in those areas and resources available in those different areas."
    }
