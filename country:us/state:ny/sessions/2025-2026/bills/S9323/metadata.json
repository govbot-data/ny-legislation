{
  "legislative_session": "2025-2026",
  "identifier": "S9323",
  "title": "Establishes pediatric palliative care centers",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"pediatric palliative care act\" to establish pediatric palliative care centers to provide palliative care to individuals who are under twenty-one years of age, have been diagnosed with a chronic, complex, life-threatening illness that is expected to shorten their life expectancy, and is not expected to survive past twenty-one years of age."
    }
  ],
