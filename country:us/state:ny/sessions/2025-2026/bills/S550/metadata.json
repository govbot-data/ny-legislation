{
  "legislative_session": "2025-2026",
  "identifier": "S550",
  "title": "Relates to the administration of the statewide central register of child abuse and maltreatment",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires a caller making a report of suspected child abuse or maltreatment to the central register to leave their name and contact information; prohibits the office of children and family services from releasing information identifying a person who made such a report."
    }
  ],
