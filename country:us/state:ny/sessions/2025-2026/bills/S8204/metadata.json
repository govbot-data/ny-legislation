  "identifier": "S8204",
  "title": "Relates to the definition of the term prospective relative guardian",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that no person shall be precluded from being deemed a \"prospective relative guardian\" based on whether such person's relationship with the child was established before or after such child's placement into foster care."
    }
  ],
