{
  "legislative_session": "2025-2026",
  "identifier": "S9448",
  "title": "Adds Down syndrome to the definition of developmental disability and expands such definition to include certain individuals below the age of ten",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Adds Down syndrome to the definition of developmental disability for the purpose of making Down syndrome an automatic qualifier for Medicaid; expands the definition of developmental disability to include certain individuals below the age of ten who cannot demonstrate that their disability constitutes a substantial handicap to their ability to function in a normal society, but that have a high probability of meeting such criteria later in life; expands the definition of developmental disability to include certain individuals below the age of four."
    }
  ],
