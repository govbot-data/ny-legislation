  "identifier": "A10190",
  "title": "Establishes a pilot overnight residential parking system in the village of Hempstead",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the village board of trustees of the village of Hempstead to provide for a pilot overnight residential parking permit system and fix and require the payment of fees applicable to parking within the area in which such parking system is in effect."
    }
  ],
