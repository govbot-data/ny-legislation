{
  "legislative_session": "2025-2026",
  "identifier": "S1129",
  "title": "Prohibits the use of unencapsulated foam flotation in docks, buoys and floating structures",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the sale, offer for sale, or distribution of foam flotation docks, buoys and floating structures in the state where such foam flotation is not fully encapsulated to prevent degradation into the environment."
    }
  ],
