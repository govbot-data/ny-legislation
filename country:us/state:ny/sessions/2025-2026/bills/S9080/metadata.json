  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"protect our most vulnerable act\" under which utility companies and municipalities are prohibited from discontinuing electric, gas, and water services to elderly customers making good faith payments between five and fifteen percent of their monthly incomes."
    }
  ],
