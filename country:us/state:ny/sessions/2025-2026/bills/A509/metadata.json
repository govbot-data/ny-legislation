{
  "legislative_session": "2025-2026",
  "identifier": "A509",
  "title": "Authorizes camp operators and employees to administer medications and treatment to children under certain circumstances",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Allows camp employees who are 18 years of age or older to administer medications and treatment to children, under parent or guardian consent and authorization, pursuant to a patient specific order and in compliance with regulations."
    }
  ],
