  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Expands eligibility for the disabled homeowners' exemption to certain surviving spouses; provides that if a person is eligible for the exemption and predeceases their spouse, such surviving spouse shall be eligible for the exemption, provided that all other requirements are satisfied."
    }
  ],
