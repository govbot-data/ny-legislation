{
  "legislative_session": "2025-2026",
  "identifier": "A7833",
  "title": "Relates to workplace safety equipment for social services employees",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires every city or county social services district to provide a wearable or mobile phone-based panic button to each employee whose job responsibilities necessitate direct interaction with clients in a client's home."
    }
  ],
