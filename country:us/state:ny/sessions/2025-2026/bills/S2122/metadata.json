{
  "legislative_session": "2025-2026",
  "identifier": "S2122",
  "title": "Authorizes municipalities and the department of financial services to seek civil penalties for violations of the duty to maintain a foreclosed property",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes municipalities and the department of financial services to seek civil penalties for violations of the duty to maintain a foreclosed property in an amount of up to $650 per day for each day such violation persists after the judgement of foreclosure has been issued."
    }
  ],
