  "identifier": "A9443",
  "title": "Requires certain kratom products to include a warning label",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires certain kratom products to include a warning label with disclosures including, but not limited to, that kratom may be addictive and to keep it out of reach of children."
    }
  ],
