{
  "legislative_session": "2025-2026",
  "identifier": "A860",
  "title": "Establishes the \"Maternal Health, Dignity and Consent act\"",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits drug, cannabis or alcohol testing of pregnant or postpartum individuals and newborns unless the individual consents and it is within the scope of medical care, or the testing is necessary for a medical emergency."
    }
  ],
