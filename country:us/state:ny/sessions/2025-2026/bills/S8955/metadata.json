  "identifier": "S8955",
  "title": "Enacts the \"fair pay for home care act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"fair pay for home care act\" relating to minimum wages applicable to home care aides; provides for a minimum wage of 150% of the applicable statewide or regional minimum wage."
    }
  ],
