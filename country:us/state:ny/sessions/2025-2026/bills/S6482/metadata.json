  "title": "Relates to license requirements for professional geologists; repealer",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that the education requirements to be licensed as a professional geologist may be partially substituted by practical experience; relates to the issuance of an identification card as a geologist in training."
    }
