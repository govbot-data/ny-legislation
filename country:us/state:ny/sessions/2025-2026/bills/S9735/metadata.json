  "identifier": "S9735",
  "title": "Enacts the \"home utility weatherization jobs act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"home utility weatherization jobs act\"; requires each gas corporation, electric corporation, or combination gas or electric corporation to submit to the public service commission for review and approval at least one and up to ten neighborhood scale weatherization and electrification-ready projects."
    }
  ],
