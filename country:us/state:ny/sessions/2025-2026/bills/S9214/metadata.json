  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes an affordable independent senior housing assistance program which shall provide grants within amounts appropriated or otherwise available therefor to affordable independent senior housing properties to establish and operate resident assistance programs."
