  "abstracts": [
    {
      "note": "",
      "abstract": "Allows new buildings where new parking is provided to have an optional, charger-agnostic, power-based allocation method alternative to certain electric vehicle charging infrastructure requirements; requires the department of state division of building standards and codes to promulgate rules and regulations relating to such alternative."
    }
