{
  "legislative_session": "2025-2026",
  "identifier": "S4571",
  "title": "Establishes a floating solar incentive and education program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the New York state energy research and development authority to establish a floating solar incentive and education program to provide information and resources including technical assistance, access to industry standards, and financing available through the authority or other public or private sector sources, to municipalities, developers, builders, design professionals, and potential owners for the construction of floating solar."
    }
  ],
