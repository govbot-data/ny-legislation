{
  "legislative_session": "2025-2026",
  "identifier": "S10152",
  "title": "Relates to mechanisms authorized sports bettors may utilize to fund their mobile sports wagering accounts",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that only automated clearing houses or electronic funds transfers from such authorized sports bettor's personal bank account, wire transfers from an authorized sports bettor's personal bank account, personal checks delivered to the operator, a debit card issued by a financial institution that draws directly from such authorized sports bettor's personal bank account only and not a prepaid debit card, or in-person cash deposits at a casino or other approved location, may be used to fund mobile sports wagering accounts."
    }
  ],
