{
  "legislative_session": "2025-2026",
  "identifier": "A1590",
  "title": "Allows certain members of a public body to be counted as present for quorum purposes at meetings attended remotely",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Allows members of a public body who cannot physically attend a meeting due to a disability to be counted as present for quorum purposes at meetings attended remotely; makes provisions of law relating to permitting videoconferencing and remote participation in public meetings under certain circumstances permanent."
    }
  ],
