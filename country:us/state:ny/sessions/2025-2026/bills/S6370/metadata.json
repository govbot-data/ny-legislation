  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the commissioner of transportation to submit a minimum twenty-year forecast period, assessing the long-range needs during such period on the pavement and bridge conditions of the state and local highways and bridges under the jurisdiction of such commissioner."
    }
  ],
