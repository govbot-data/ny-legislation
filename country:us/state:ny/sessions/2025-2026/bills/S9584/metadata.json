  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Designates materially misleading digital representations in real estate listings as an unfair, deceptive or abusive act or false advertising; provides that a licensed real estate broker or salesperson shall be subject to suspension or revocation of their license for a violation of such provisions."
    }
