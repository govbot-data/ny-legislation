  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that certain institutions of higher education shall meet certain standards or adopt rules that do not infringe upon academic freedom; provides that academic freedom shall be defined by the 1940 Statement of Principles on Academic Freedom and Tenure with 1970 Interpretive Comments; establishes courses of action that may be taken int the event of alleged violations of academic freedom."
    }
  ],
