{
  "legislative_session": "2025-2026",
  "identifier": "A752",
  "title": "Relates to policies regarding maximum temperatures in school buildings and facilities",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires policies regarding maximum temperatures in school buildings and facilities to include a plan to remove students and staff from occupied spaces where practicable when educational and support services spaces reach eighty-eight degrees Fahrenheit."
    }
  ],
