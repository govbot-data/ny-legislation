{
  "legislative_session": "2025-2026",
  "identifier": "S6990",
  "title": "Requires exit surveys for employees resigning from state civil service",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires each agency to conduct exit surveys for employees resigning from state civil service; directs the state civil service commission to create an annual report on such surveys; exempts individual responses to exit surveys from the freedom of information law."
    }
  ],
