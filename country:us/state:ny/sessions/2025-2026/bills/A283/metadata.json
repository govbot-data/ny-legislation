{
  "legislative_session": "2025-2026",
  "identifier": "A283",
  "title": "Relates to a review of reimbursement adequacy for early intervention services",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the commissioner of health to contract with an independent entity to conduct a comprehensive assessment of the existing methodology used to determine payment for early intervention screenings, evaluations, services and service coordination; directs recommendations on reimbursement methodology as well as needs under the program."
    }
  ],
