{
  "legislative_session": "2025-2026",
  "identifier": "S9930",
  "title": "Relates to the handling of certain unclaimed human remains",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits unclaimed human remains from being buried, cremated, or otherwise finally disposed of unless such remains have first been entered into the National Missing and Unidentified Persons System, and for a period of time thereafter as specified by the commissioner of health."
    }
  ],
