  "identifier": "S6976",
  "title": "Establishes the New York road salt reduction council and the New York road salt reduction advisory committee",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the New York road salt reduction council and the New York road salt reduction advisory committee to provide a mechanism for interagency cooperation and coordination to implement the recommendations of the report of the Adirondack road salt reduction task force."
    }
  ],
