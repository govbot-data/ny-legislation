  "identifier": "S10424",
  "title": "Enacts the \"fair authorized investment returns act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"fair authorized investment returns act\"; sets a default authorized return on equity equal to the ten year US Treasury rate plus two hundred basis points; provides such default authorized return shall reset annually; establishes a competitive equity auction through which the cost of equity for a covered utility may be determined on a market basis, whether initiated by the utility or ordered by the commission."
    }
  ],
