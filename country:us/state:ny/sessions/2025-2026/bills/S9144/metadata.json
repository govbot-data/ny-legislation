{
  "legislative_session": "2025-2026",
  "identifier": "S9144",
  "title": "Imposes a moratorium on data center permit issuance; and relates to data center rate impacts",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Imposes a moratorium on the issuance of permits for new data centers; requires the public service commission to issue an order or orders to minimize the impact of new data centers on electricity and gas rates for residential, commercial, and industrial users; clarifies that certain provisions are applicable to the Long Island power authority."
    }
  ],
