  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes income eligibility requirements that a tenant shall have income not to exceed one hundred twenty-five percent of the area median income to be eligible to occupy certain rent-regulated housing accommodations."
