{
  "legislative_session": "2025-2026",
  "identifier": "A1361",
  "title": "Relates to restrictive covenants between employers and employees with respect to agreements not to compete",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Allows employers to request or require a prospective or current employee to execute a restrictive covenant not to engage in specified acts in competition with the employer after termination of the employment relationship as a condition of employment, continued employment, or with respect to severance pay."
    }
  ],
