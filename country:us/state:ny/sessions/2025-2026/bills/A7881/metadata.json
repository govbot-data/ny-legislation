  "identifier": "A7881",
  "title": "Requires the department of environmental conservation, after consultation with the environmental facilities corporation and the department of state, to submit an annual agency stormwater expenditure report",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the department of environmental conservation, after consultation with the environmental facilities corporation and the department of state, to submit an annual agency stormwater expenditure report containing a comprehensive estimate and summary of funds needed and funds spent on stormwater projects under the department of environmental conservation, the environmental facilities corporation, the department of state and other applicable agencies or state authorities."
    }
  ],
