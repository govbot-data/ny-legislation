  "identifier": "S2103",
  "title": "Relates to aggravated harassment of a police officer",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the crime of aggravated harassment of a police officer where a person causes such police officer to come into contact with blood, seminal fluid, urine, feces, or the contents of a toilet bowl, by throwing, tossing or expelling such fluid or material."
    }
  ],
