  "legislative_session": "2025-2026",
  "identifier": "S7792",
  "title": "Relates to protecting the communication rights of individuals with disabilities",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to protecting the communication rights of individuals with disabilities; provides that each person with a disability has the right to autonomously communicate in their preferred manner and utilize any validated communication supports that meet their needs."
    }
  ],
