  "identifier": "S7236",
  "title": "Prohibits the purchase of ammunition if such purchaser failed a background check",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the purchase of ammunition if such purchaser failed a background check, is prohibited by federal law or is subject to a temporary or extreme risk protection order issued pursuant to article sixty-three-A of the civil practice law and rules."
    }
  ],
