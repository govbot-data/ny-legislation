  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes certain persons in an optional twenty year retirement plan of the police and fire retirement system to receive credit for previous service as a uniformed court officer title series employed by the Unified Court System or a correction officer employed by a county, a municipality or the state."
    }
