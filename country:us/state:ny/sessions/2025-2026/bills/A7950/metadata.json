  "identifier": "A7950",
  "title": "Relates to the penalty for the abandonment of animals",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that the penalty for the abandonment of animals is a misdemeanor, punishable by imprisonment for not more than one year, or by a fine of not less than five hundred dollars nor more than one thousand dollars, or by both."
    }
  ],
