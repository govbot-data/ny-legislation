{
  "legislative_session": "2025-2026",
  "identifier": "S9419",
  "title": "Authorizes the department of motor vehicles to accept certain documentation issued to veterans of the military as acceptable proofs of identity when applying for a driver license or state identification card",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the department of motor vehicles to accept a certificate of release or discharge from active duty issued by the United States department of defense (DD form 214), a veteran identification card issued by the United States department of veterans affairs, or a veterans health identification card issued by the United States department of veterans affairs from veterans of the military as acceptable proofs of identity when applying for a driver license or state identification card."
    }
  ],
