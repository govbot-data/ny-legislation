  "identifier": "S8648",
  "title": "Relates to training stipends paid by the office of fire prevention and control to volunteer firefighters",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the office of fire prevention and control to pay training stipends in specific amounts to volunteer firefighters for completion of certain firefighter trainings; provides that if a volunteer fire company pays training stipends to volunteer firefighters in an amount below what is otherwise required to be paid by OFPC, OFPC shall pay the remaining amount."
    }
  ],
