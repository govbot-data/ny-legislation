  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Adds to the crime of criminal possession of a controlled substance in the third degree the possession, within any facility owned or operated by the state or upon school grounds, of any controlled substance or hazardous substance which has the potential to cause significant injury or death, with the intent to sell or distribute such substance."
    }
