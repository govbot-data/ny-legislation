  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to school session days; adds general election day to the list of days when school will not be in session; allows a school district to elect to require staff attendance on a general election day or to schedule a professional development day."
    }
  ],
