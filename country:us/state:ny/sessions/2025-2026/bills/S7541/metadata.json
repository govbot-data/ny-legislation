{
  "legislative_session": "2025-2026",
  "identifier": "S7541",
  "title": "Establishes transparency guidelines for condominiums and cooperative housing units",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires that when a buyer enters into a contract to purchase a condominium or cooperative housing unit, the property management company or board of managers shall provide the buyer with records of the most recent inspection and engineering reports and permits for the subject property."
    }
  ],
