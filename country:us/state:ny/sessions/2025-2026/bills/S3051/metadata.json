  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the commissioner of the office of mental health, and the office of addiction services and support to jointly establish a single set of licensing standards and requirements for the construction, operation, reporting and surveillance of integrated behavioral health services."
    }
