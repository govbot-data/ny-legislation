{
  "legislative_session": "2025-2026",
  "identifier": "S6882",
  "title": "Relates to carport-mounted solar energy system siting",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits local governments from prohibiting the construction, installation, or operation of carport-mounted solar energy systems with a nameplate capacity of five megawatts or less, in any non-residential zoning district or mixed commercial and residential zoning district of any such city, town or village, provided however, if the zoning district is a certified agricultural district the agricultural impacts of the projects shall be minimized to the extent practicable."
    }
  ],
