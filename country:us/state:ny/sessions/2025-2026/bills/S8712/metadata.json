{
  "legislative_session": "2025-2026",
  "identifier": "S8712",
  "title": "Requires the office of renewable energy siting and electric transmission to establish and/or amend rules and regulations pertaining to standards related to siting major renewable energy facilities",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the office of renewable energy siting and electric transmission to establish and/or amend rules and regulations pertaining to standards related to the siting, design, construction and operation of major renewable energy facilities; requires such rules and regulations to include information relating to farmland protection and application procedures; provides for the repeal of such provisions upon expiration thereof."
    }
  ],
