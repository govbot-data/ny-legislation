{
  "legislative_session": "2025-2026",
  "identifier": "S10534",
  "title": "Relates to required training for school district officials",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that in each term for a trustee or voting member of a board of education of a school district or a board of cooperative educational services, elected or appointed, such trustee or member shall complete certain training and file a certificate of completion with a sworn statement of completion within the first year of such term; provides that failure to comply shall disqualify such trustee or member to serve."
    }
  ],
