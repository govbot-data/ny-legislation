{
  "legislative_session": "2025-2026",
  "identifier": "S10274",
  "title": "Relates to access to fair and transparent real estate listings",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires timely public advertising or marketing of listed residential properties on platforms accessible to the general public; permits non-public marketing only where the seller gives informed, written direction after receiving a standardized state disclosure that clearly explains the risks and tradeoffs of withholding a listing from public marketing."
    }
  ],
