  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a pilot program for schools with active aging programs or specializations in place; creates a curriculum team that shall identify areas that are most relevant to persons working with older adults currently, and/or represent emerging and evidenced-based practices and create a suggested syllabus template for an advanced-year practice class in the field of aging; creates the workforce development center for professional development in gerontological/geriatric education."
    }
  ],
