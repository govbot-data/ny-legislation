  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes criminal offenses related to cruelty to and the killing of animals; provides for enhanced sentencing and victim statements; requires landlords to check the animal abuser registry; establishes the New York state animal abuser registry; makes conforming changes; repeals provisions relating to aggravated cruelty to animals."
    }
  ],
