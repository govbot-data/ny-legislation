  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires courts to consider whether an individual poses a risk or threat of physical danger to the safety of any person or the community when imposing a securing order; makes stalking in the second and third degree a qualifying offense; makes related provisions."
    }
  ],
