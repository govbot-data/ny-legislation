{
  "legislative_session": "2025-2026",
  "identifier": "A1607",
  "title": "Relates to the provision of breast pumps to certain incarcerated birth parents and allowing children to remain with their incarcerated birth parent for a period of time",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the provision of breast pumps and related collection and storage materials to certain incarcerated nursing birth parents who are confined in or committed to an institution or local correctional facility with or without their child subject to specific time limitations; requires institutions and local correctional facilities to provide pumps and related materials to such incarcerated birth parents; requires the commissioner of corrections and community supervision to issue an annual report on data relating to incarcerated birth parents."
    }
  ],
