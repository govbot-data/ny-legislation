  "identifier": "S8606",
  "title": "Relates to the length of time orders issued to set the rate of gas and electricity are in effect",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that beginning January 1, 2027, any order issued to set the rate of gas and electricity, not including surcharges or tariffs, shall be in effect for three years."
    }
