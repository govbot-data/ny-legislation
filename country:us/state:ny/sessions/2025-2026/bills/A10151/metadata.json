  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits law enforcement officers from arresting a person solely based on certain characteristics including race or ethnicity, language or accent, location where found, or type of job; establishes a penalty for officers who have violated such provisions."
    }
