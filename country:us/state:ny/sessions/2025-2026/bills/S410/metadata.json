{
  "legislative_session": "2025-2026",
  "identifier": "S410",
  "title": "Relates to certain jury awards in employment discrimination actions",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that the court shall not reduce jury awards as excessive in employment discrimination actions unless the court finds exceptional circumstances which compel the conclusion that the jury was influenced by partiality, prejudice, mistake or corruption."
    }
  ],
