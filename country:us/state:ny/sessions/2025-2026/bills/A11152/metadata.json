  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the department of public service to assign an administrative law judge to oversee the process in policy proceedings before the public service commission; provides that the department of public service shall be considered a party in policy proceedings."
    }
