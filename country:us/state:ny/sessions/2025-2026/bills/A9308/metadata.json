  "identifier": "A9308",
  "title": "Relates to the electric school bus mandate; prohibits a mandate requiring school districts to purchase, operate or maintain any certain type of school buses; repeals certain provisions relating to electric buses",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Removes references to the electric school bus mandate; provides that there shall be no mandate requiring school districts to purchase, operate or maintain any certain type of school buses and that the superintendent of each school district shall have the sole authority to determine the types of school buses such school district will purchase, operate and maintain; repeals certain provisions of law relating to electric school buses."
    }
  ],
