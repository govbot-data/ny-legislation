  "title": "Includes \"people with disabilities\" within the definition of \"minority\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the definition of \"minority\" to include \"people with disabilities\" pursuant to the Human Rights law in order for such people with disabilities to be eligible for state contract set asides."
    }
