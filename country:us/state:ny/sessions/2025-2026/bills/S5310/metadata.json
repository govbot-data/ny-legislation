  "identifier": "S5310",
  "title": "Permits a waiver of the diligent effort requirement in limited circumstances for certain insurance coverage to be placed by licensed excess line brokers with unauthorized insurers",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Permits a waiver of the diligent effort requirement in limited circumstances for certain insurance coverage to be placed by licensed excess line brokers with unauthorized insurers where a retail producing insurance broker seeks to procure or place commercial lines insurance through an unaffiliated wholesale excess line insurance broker."
    }
  ],
