  "identifier": "A1923",
  "title": "Prohibits the trade of farmed fur products",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the trade of farmed fur products if any of the fur was sourced from an animal that was raised, maintained, kept, or housed for all or part of its life on a fur farm."
    }
  ],
