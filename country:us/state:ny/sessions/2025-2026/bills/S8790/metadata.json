{
  "legislative_session": "2025-2026",
  "identifier": "S8790",
  "title": "Establishes the combat zone service exemption",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes municipalities to offer a real property tax exemption for combat zone service members who at any time during the taxable year performed active duty in the armed forces in a combat zone; defines terms; makes related provisions."
    }
  ],
