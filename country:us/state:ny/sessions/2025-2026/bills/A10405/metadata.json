  "identifier": "A10405",
  "title": "Relates to removing residency requirements for Ulster county assistant district attorneys",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Removes residency requirements for persons holding the office of assistant district attorney for the county of Ulster; provides that a person holding such office may reside in Ulster county or an adjoining county within the state."
    }
  ],
