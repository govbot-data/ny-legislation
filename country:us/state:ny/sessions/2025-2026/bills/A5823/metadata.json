  "identifier": "A5823",
  "title": "Ensures public safety announcements are accessible to visually impaired individuals",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires that the state system for warning populations who are or may be endangered includes audible alerts for all announcements to ensure that information is accessible to visually impaired individuals."
    }
