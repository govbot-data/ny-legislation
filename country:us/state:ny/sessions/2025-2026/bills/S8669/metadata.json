  "identifier": "S8669",
  "title": "Establishes the thriving reliable inexpensive versatile energy council; repealer",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Repeals the New York state climate leadership and community protection act and establishes the nineteen member common sense energy council which will prepare and approve recommendations for achieving affordable and attainable statewide greenhouse gas reductions; requires a statewide greenhouse gas emissions report by the department of environmental conservation; makes technical corrections thereto."
    }
  ],
