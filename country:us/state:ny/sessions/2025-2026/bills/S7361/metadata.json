{
  "legislative_session": "2025-2026",
  "identifier": "S7361",
  "title": "Relates to medical treatment for certain workers' compensation claimants",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that where an employer or insurance carrier elects to controvert the right to compensation and such claimant holds a valid insurance policy, the employer or insurance carrier shall provide medical treatment to the injured claimant and payment to health care providers without regard to such controversy."
    }
  ],
