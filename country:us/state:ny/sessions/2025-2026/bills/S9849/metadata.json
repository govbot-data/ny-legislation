{
  "legislative_session": "2025-2026",
  "identifier": "S9849",
  "title": "Relates to the administration of certain immunizations",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes a licensed pharmacist to administer any recommendations made by the commissioner of health pertaining to a vaccine that has been authorized by the federal Food and Drug Administration; relates to insurance coverage for immunizations; removes the requirement to follow the advisory committee on immunization practices of the centers for disease control and prevention recommendation for immunization against meningococcal disease."
    }
  ],
