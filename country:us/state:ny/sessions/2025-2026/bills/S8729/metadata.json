{
  "legislative_session": "2025-2026",
  "identifier": "S8729",
  "title": "Establishes the \"right to home inspection act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the right to inspection of homes by buyers; provides for a 10-day inspection period where the buyer has the right to have a home inspected and cancel the contract if the buyer is not satisfied with the inspection results; makes related provisions."
    }
  ],
