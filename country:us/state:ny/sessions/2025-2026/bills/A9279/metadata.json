  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"climate accountability and loss recovery act\"; provides that the attorney general may bring a civil action against a covered entity for recovery of certain costs and assessments arising from a climate disaster."
    }
  ],
