  "identifier": "A10102",
  "title": "Enacts the low impact landscaping rights act",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the low impact landscaping rights act, preventing homeowners' associations from adopting or enforcing any rules or regulations that would effectively prohibit, or impose unreasonable limitations on, the installation or maintenance of low impact landscaping."
    }
  ],
