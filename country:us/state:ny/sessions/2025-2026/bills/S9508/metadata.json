  "identifier": "S9508",
  "title": "Requires certain security features and warning labels on baby monitors",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the manufacture, distribution, sale, or offering for sale of a baby monitor that broadcasts audio or video through an internet connection unless it includes certain security features to prevent unauthorized access; requires a written warning label; provides penalties."
    }
  ],
