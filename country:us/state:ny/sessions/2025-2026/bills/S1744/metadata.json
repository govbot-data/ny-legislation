{
  "legislative_session": "2025-2026",
  "identifier": "S1744",
  "title": "Imposes certain requirements on institutions housing a defendant due to mental disease or defect prior to the discharge of such defendant",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires each appropriate institution housing a defendant due to mental disease or defect to assign a critical time intervention care management team to the defendant and make a single point of access referral for the defendant prior to such defendant's discharge."
    }
  ],
