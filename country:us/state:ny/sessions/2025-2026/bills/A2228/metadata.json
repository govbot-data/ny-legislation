  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires a criminal history background check for the purchase of a three-dimensional printer capable of creating firearms; prohibits sale to a person who would be disqualified on the basis of criminal history from being granted a license to possess a firearm."
    }
