  "abstracts": [
    {
      "note": "",
      "abstract": "Requires sellers of catalytic converters to provide certain information to potential buyers; requires buyers to maintain records of such purchases; makes any violations a class A misdemeanor; imposes a fine of up to $5,000."
    }
