{
  "legislative_session": "2025-2026",
  "identifier": "S2076",
  "title": "Requires that notice of initial determination for unemployment benefits be provided",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires that notice of initial determinations for unemployment benefits be provided to claimants within 30 days of such claimant furnishing all necessary documentation, and if the commissioner is unable to issue a determination within such time frame they shall inform the claimant of the new estimated time frame for the issuance of a determination."
    }
  ],
