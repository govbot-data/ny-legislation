  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Adds hazardous air quality to the state definition of a disaster; requires explicit inclusion of air quality emergency preparedness in local comprehensive emergency management plans with an action plan and annual inventory of air quality emergency resources."
    }
