{
  "legislative_session": "2025-2026",
  "identifier": "S6570",
  "title": "Enacts the accelerate solar for affordable power (ASAP) act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the accelerate solar for affordable power (ASAP) act to set a new target for distributed solar energy capacity and direct the public service commission to advance reforms to the utility interconnection process to ensure timely and cost-effective integration of new distributed energy resources."
    }
  ],
