{
  "legislative_session": "2025-2026",
  "identifier": "A5079",
  "title": "Relates to training for school security guards",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"school security guard training enhancement act\"; provides that annual training where a security guard is employed or contracted by a school in this state shall require the completion of school specific-training."
    }
  ],
