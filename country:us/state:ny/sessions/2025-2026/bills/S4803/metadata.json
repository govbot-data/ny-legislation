  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a municipal group insurance technical assistance program for the purpose of assisting persons and municipalities with access to indemnity insurance and employee compensation pursuant to the volunteer firefighter's benefit law."
