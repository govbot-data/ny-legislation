  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the office of global public health and international cooperation within the department of health to coordinate cooperation with international public health institutions for purposes related to public health; requires such office to submit an annual global health risk and preparedness report to the governor, the temporary president of the senate, the speaker of the assembly and the chairs of the senate and assembly health committees."
    }
  ],
