  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the delivery of the good faith deposit following award of the bonds to the successful bidder; provides that a municipality, school district or district corporation may require that such deposit be made as a condition precedent to the consideration of a bid for the bonds."
    }
