  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the work opportunity tax credit for businesses with fifty employees or less for hiring a long term unemployed person; provides a credit shall be allowed of up to $2,400; provides the total amount of credit provided statewide shall not exceed fifteen million dollars."
    }
