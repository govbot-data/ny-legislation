  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the administration of reversible progestin-only contraceptive injections; provides that no pharmacist shall administer reversible progestin-only contraceptive injections without receiving training satisfactory to the commissioner of education and the commissioner of health."
    }
  ],
