  "identifier": "S10541",
  "title": "Relates to custom farm operators",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Includes \"custom farm operators\" within the definition of \"eligible farmer\"; defines such term as an independent contractor who performs specific agricultural tasks including, but not limited to, tilling, planting, spraying, or harvesting, using their own machinery and labor for a set fee, typically without taking ownership of the crop."
    }
  ],
