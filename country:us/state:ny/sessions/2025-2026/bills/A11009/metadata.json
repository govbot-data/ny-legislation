  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to liability of the state for damages caused by reported defects and potholes if the report was made fourteen days or more before the damage occurred; establishes an interactive website for reporting defects and potholes on the state highway system and thruway."
    }
