  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the office of children and family services to promulgate regulations for training requirements for child protective services workers assigned to a multidisciplinary investigative team; amends the effectiveness of certain provisions relating thereto."
