  "identifier": "S10631",
  "title": "Relates to energy efficiency and weatherization",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs NYSERDA to issue a request for proposals to identify cities, towns, or villages that are interested in participating in municipal-level energy efficiency and weatherization pilot projects to help decrease residential energy usage and reduce future capital costs for utilities; directs NYSERDA to identify three pilot areas focusing on the ability to replicate projects elsewhere and the costs and benefits to ratepayers both in the affected area and in the rest of the utility service territory."
    }
  ],
