  "abstracts": [
    {
      "note": "",
      "abstract": "Increases the statewide energy storage capacity to six gigawatts by the year 2030, twelve gigawatts of statewide energy storage capacity by 2040, and seventeen gigawatts of statewide energy storage capacity by 2050."
