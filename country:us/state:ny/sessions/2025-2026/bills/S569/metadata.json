{
  "legislative_session": "2025-2026",
  "identifier": "S569",
  "title": "Authorizes county boards of elections to establish county-wide polling places",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes county boards of elections to establish county-wide polling places where any person entitled to vote in such county by personal appearance may so vote on the day of a primary election or general election, subject to approval by the state board of elections."
    }
  ],
