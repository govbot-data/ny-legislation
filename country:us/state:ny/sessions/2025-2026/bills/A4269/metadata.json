  "identifier": "A4269",
  "title": "Relates to being absent from full time day instruction for the purpose of sounding Taps at a military honors funeral held in this state",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that a minor from six to sixteen years being absent from full time day instruction for the purpose of sounding \"Taps\" at a military honors funeral held in this state for a deceased veteran shall be excused from school."
    }
  ],
