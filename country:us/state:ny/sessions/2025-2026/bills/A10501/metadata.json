  "identifier": "A10501",
  "title": "Relates to criminal impersonation by electronic communication and emergency disclosure of caller-identification routing information",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the crimes of criminal electronic impersonation and aggravated criminal electronic impersonation; requires certain voice-over internet, call-routing and electronic communication services to preserve certain call routing and originating connection records and to provide such records to law enforcement upon request."
    }
