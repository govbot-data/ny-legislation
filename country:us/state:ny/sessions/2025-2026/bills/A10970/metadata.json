  "title": "Relates to authorization for boycott-based adverse actions by affected state entities and public retirement systems",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that no affected state entity or public retirement system shall take any boycott-based adverse action or compile, maintain or publish any list of persons or entities for purposes of such action unless expressly authorized by the legislature."
    }
