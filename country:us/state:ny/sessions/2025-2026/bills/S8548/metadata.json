{
  "legislative_session": "2025-2026",
  "identifier": "S8548",
  "title": "Relates to the payment of property taxes to municipalities by any nonprofit organization",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the payment of property taxes to municipalities by any nonprofit organization; requires nonprofit organizations that would typically be exempt from property taxes based on nonprofit status to pay 75 percent of its annual property taxes to the municipality in which it sits in order to offset the impact of the exemption."
    }
  ],
