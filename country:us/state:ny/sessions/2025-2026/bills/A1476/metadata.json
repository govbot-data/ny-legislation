  "identifier": "A1476",
  "title": "Defines medically fragile young adults for certain purposes",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Defines medically fragile young adults as individuals who meet the definition of children with medical fragility, but for the fact such individuals are aged between twenty-one and thirty-five years old."
    }
  ],
