  "identifier": "A9141",
  "title": "Relates to the maintenance of certain sidewalks within a town",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that a town may not direct abutting property owners to maintain sidewalks which abut county highways or which are not directly accessible from such owner's property."
    }
