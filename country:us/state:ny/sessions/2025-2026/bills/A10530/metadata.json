  "identifier": "A10530",
  "title": "Enacts the \"statewide building energy disclosure act\"",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides for reporting by utilities and owners of buildings meeting certain thresholds regarding energy consumption data; requires NYSERDA to create a list of buildings subject to such requirements; provides exemptions; requires public reporting on the information collected; makes related provisions."
    }
