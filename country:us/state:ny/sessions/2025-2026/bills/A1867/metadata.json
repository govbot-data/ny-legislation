  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to requirements for a building owner to refuse to renew a lease under the real estate industry stabilization code; requires the owner of a building to be demolished to prove that such owner has the financial ability to complete demolition of the building."
    }
