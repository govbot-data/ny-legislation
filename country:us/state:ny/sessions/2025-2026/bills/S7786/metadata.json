  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the Department of Veterans' Services to consult and collaborate with relevant offices in the federal department of veterans affairs, the department of health, the state office for the aging and other HCBS experts to develop educational materials for veterans and their families about the accessibility to home and community-based services."
    }
