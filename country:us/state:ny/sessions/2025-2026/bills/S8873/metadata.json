  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"first responders assault prevention act\" which increases the offense classification for assault on a peace officer, police officer, firefighter or emergency medical services professional from a class C felony to a class B felony."
    }
