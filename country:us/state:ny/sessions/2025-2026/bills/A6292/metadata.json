  "identifier": "A6292",
  "title": "Relates to certain mandatory disclosures for job advertisements",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires certain mandatory disclosures for printed or digital job advertisements by an employer or third-party job posting entity; provides for the imposition of a fine of $2,500 for violations."
    }
  ],
