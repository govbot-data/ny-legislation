  "identifier": "S2346",
  "title": "Enacts the \"gas tax holiday act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"gas tax holiday act\"; provides that from the first of the month after the effective date of the section until December 31, 2027 the taxes imposed on retail sales of fuel gas, motor fuel and diesel motor fuel shall be exempt from certain taxes."
    }
  ],
