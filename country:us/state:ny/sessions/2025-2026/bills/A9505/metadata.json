  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the issuance of violations or tickets during certain weekend hours to residential occupants for violations of the sanitation department regulations regarding placing trash or garbage out for collection earlier than allowed under the city routing system designated hours."
    }
