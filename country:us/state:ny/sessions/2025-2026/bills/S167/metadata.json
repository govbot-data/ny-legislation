  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that the commissioner of labor shall notify the chairperson of the state liquor authority of certain violations of the labor law relating to wages and hours of labor; provides that the chairperson of the state liquor authority shall suspend certain liquor licenses of such employers in violation of such provisions."
    }
