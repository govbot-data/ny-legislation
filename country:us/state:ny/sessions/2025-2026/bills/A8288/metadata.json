  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts \"Ella's law\"; requires care managers employed by or under contract with a care coordination organization to provide care management services to an individual unless such care manager has completed all training requirements."
    }
