{
  "legislative_session": "2025-2026",
  "identifier": "A9331",
  "title": "Requires slow-moving traffic, trucks, buses, and other certain vehicles use the right two lanes of a multilane roadway",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires slow-moving traffic, trucks, buses, and other certain vehicles use the right two lanes of a multilane roadway and requires all lanes other than the right most two lanes on a multilane highway to be marked with \"NO TRUCKS OR BUSES\"."
    }
  ],
