{
  "legislative_session": "2025-2026",
  "identifier": "A10833",
  "title": "Relates to disability benefits for certain individuals employed by the Nassau county police department",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides a performance of duty presumption for diseases of the heart for members who serve as an ambulance medical technician, ambulance medical coordinator, ambulance medical technician/supervisor or a member who performs ambulance medical technician related services, or a police medic, police medic coordinator, police medic supervisor, bureau director police emergency ambulance services - county, assistant bureau director police emergency ambulance services - county, or a member who performs police medic or police emergency ambulance related services and is employed in the Nassau county police department."
    }
  ],
