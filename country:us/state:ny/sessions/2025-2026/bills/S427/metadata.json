{
  "legislative_session": "2025-2026",
  "identifier": "S427",
  "title": "Requires chain restaurants to label menu items that have a high content of added sugars",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires chain restaurants to display an added sugars warning next to or directly under the name of each food item with high added sugars content wherever such food item is listed on a menu, menu board, or food tag, and by any self-serve dispensing point at which such food item is dispensed."
    }
  ],
