  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a statewide advance care planning public awareness campaign and a community based advance care planning outreach grant program to fund not-for-profit community-based organizations, faith-based organizations, immigrant-serving organizations, senior-serving agencies, housing-based organizations, and other trusted community partners to conduct advance care planning education, outreach, and navigation."
    }
