{
  "legislative_session": "2025-2026",
  "identifier": "A9319",
  "title": "Exempts retail food stores from various state and local taxes",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Exempts retail food stores from various state and local taxes provided such store derives at least seventy percent of its annual gross sales from staple foods and food products for off-premises consumption."
    }
  ],
