  "identifier": "S3999",
  "title": "Enacts the \"New York accountability in reporting act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"New York accountability in reporting act\"; establishes the crimes of offering a false report for filing in the second degree and offering a false report for filing in the first degree; requires the creation of public databases for false reporting; provides for a civil remedy for convictions of such crimes."
    }
  ],
