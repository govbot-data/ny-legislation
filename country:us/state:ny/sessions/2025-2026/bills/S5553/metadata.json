{
  "legislative_session": "2025-2026",
  "identifier": "S5553",
  "title": "Enacts the \"rate hike notice act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"rate hike notice act\" which requires utilities in the state of New York to provide notice of a proposed rate hike to a customer via text, email and via such customer's monthly billing statement."
    }
  ],
