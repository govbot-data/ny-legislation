  "identifier": "S7618",
  "title": "Relates to food safety and quality date labeling requirements",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires certain labeling to be used to indicate the safety dates and quality dates of food products; requires the department of agriculture and markets to educate consumers about such provisions."
