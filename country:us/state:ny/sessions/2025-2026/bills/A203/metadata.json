{
  "legislative_session": "2025-2026",
  "identifier": "A203",
  "title": "Requires hospitals to develop a violence prevention program",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires hospitals to establish a violence prevention program which includes a workplace safety and security assessment and develop a safety and security plan that addresses identified workplace violence threats or hazards."
    }
  ],
