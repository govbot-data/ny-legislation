  "legislative_session": "2025-2026",
  "identifier": "S1287",
  "title": "Establishes the rare disease advisory council",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the rare disease advisory council to identify best practices, raise awareness regarding rare diseases, evaluate barriers to access to care, and to make recommendations to the legislature and the governor."
    }
  ],
