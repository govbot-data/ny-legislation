  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that the department of taxation and finance shall be permitted to share with the office of the state comptroller a person's address, based on such person's most recently filed tax return, for the purpose of returning unclaimed funds to such person."
    }
