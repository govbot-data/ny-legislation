  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"anti-slumlord act\" which prohibits the acquisition of residential property by property owners with outstanding immediate hazardous violations; defines terms; establishes and requires a compliance certification form; sets forth recording requirements; provides for enforcement of provisions by the attorney general."
    }
  ],
