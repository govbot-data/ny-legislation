  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Codifies certain regulations of the workers' compensation board relating to access to prescription medication and coordination with workers' compensation board regulations governing network pharmacy use; requires the workers' compensation board to file a report on out-of-network pharmacy use within 3 years of the effective date."
    }
  ],
