{
  "legislative_session": "2025-2026",
  "identifier": "S4927",
  "title": "Requires third-party food delivery services and third-party grocery delivery services to provide the ability to include a gratuity at the same point in the online order process when the underlying order is placed",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires third-party food delivery services and third-party grocery delivery services to provide the ability to include a gratuity at the same point in the online order process when the underlying order is placed; provides that customers shall not be required to pay a gratuity; provides that third-party food delivery services and third-party grocery delivery services shall not reduce the compensation of any worker as a result of gratuities; establishes penalties for violations of such provisions."
    }
  ],
