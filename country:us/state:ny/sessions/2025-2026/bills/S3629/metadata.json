{
  "legislative_session": "2025-2026",
  "identifier": "S3629",
  "title": "Prohibits the participation of certain animals in traveling animal acts",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the participation of certain animals in traveling animal acts; prohibits the department of environmental conservation from issuing permits or licenses allowing participation of certain animals in traveling animal acts; excludes certain permanent performing institutions; imposes a civil penalty not to exceed $1000 for a violation."
    }
  ],
