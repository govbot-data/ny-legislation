  "identifier": "A9389",
  "title": "Creates interagency placement committees to recommend treatment and rehabilitation programs or strategies for youths with co-existing mental disabilities",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Creates 10 interagency placement committees throughout the state to recommend treatment and rehabilitation programs or strategies for youths with co-existing mental disabilities; directs such committees to establish a process by which youths can be referred to such committees; directs such committees to submit a report annually to the governor and legislature identifying gaps in treatment and rehabilitation options, and any plans or recommendations to increase such options."
    }
  ],
