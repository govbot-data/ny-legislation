  "title": "Directs the department of motor vehicles to create a plan to increase the availability of wheelchair accessible vehicles in New York state outside of the city of New York",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the department of motor vehicles to develop a plan to increase the availability of wheelchair accessible vehicles, by county, in New York state outside of the city of New York; defines accessibility; requires a report to identify any existing local guidelines for accessible vehicles; directs development of benchmarks for increasing wheelchair accessible vehicles."
    }
  ],
