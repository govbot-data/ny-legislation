  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Limits the identification of individuals who provide face-to-face care to or direct observation of a patient to their employee identification number, first name and first initial of last name when full name identification may place the personal safety of such individual in jeopardy."
    }
  ],
