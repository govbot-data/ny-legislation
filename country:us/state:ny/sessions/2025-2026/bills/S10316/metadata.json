  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the results of any outage management system stress test conducted in the state by a utility company to be posted online and such results to be sent to the temporary president of the senate, the speaker of the assembly and the chairs of the senate and assembly standing committees on energy."
    }
