  "identifier": "A7001",
  "title": "Requires manufacturers of synthetic braiding hair, weaves, and extensions to disclose all ingredients used in the manufacturing of such products",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires manufacturers of synthetic braiding hair, weaves, and extensions to disclose all ingredients used in the manufacturing of such products and identify by label which products contain carcinogens and/or reproductive toxicants."
    }
  ],
