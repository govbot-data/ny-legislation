{
  "legislative_session": "2025-2026",
  "identifier": "S9370",
  "title": "Relates to centralized contracts for services",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Amends provisions of law from making it mandatory to optional that where the purchase of services by state agencies be conducted in a manner that accords second priority to centralized contracts meeting form, function and utility required by such agency, third priority to agency or multi-agency contracts and fourth priority to other means of contracting."
    }
  ],
