  "legislative_session": "2025-2026",
  "identifier": "A8017",
  "title": "Increases the weight limits for vehicles powered primarily by electric battery power and other fuels",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that a vehicle or a combination of vehicles operated by an engine fueled primarily by means of natural gas, propane gas, or hydrogen or powered primarily by means of electric battery power may exceed certain weight limits by up to two thousand pounds."
    }
  ],
