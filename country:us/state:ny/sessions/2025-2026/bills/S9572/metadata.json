  "abstracts": [
    {
      "note": "",
      "abstract": "Requires at least one director on a board of directors of a residential cooperative housing corporation be a primary resident of such residential cooperative housing corporation; prohibits the charging of payments, fees or charges by cooperative housing corporations without thirty days written notice to such cooperative housing corporation's shareholders."
