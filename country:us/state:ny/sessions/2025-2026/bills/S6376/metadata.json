  "legislative_session": "2025-2026",
  "identifier": "S6376",
  "title": "Prohibits insurance carriers and employers from withholding certain benefits from injured workers based on attachment to the labor market",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits insurance carriers and employers from withholding certain benefits from injured workers based on a claim that such workers have voluntarily withdrawn from the labor market by not seeking alternate employment that their injury or illness does not preclude them from performing."
    }
  ],
