  "identifier": "S9534",
  "title": "Relates to limiting rate increases that entail a return on equity for capital projects",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the public service commission from approving a rate increase that entails a return on equity for capital projects that is above the prevailing ten-year treasury rate plus one percent."
    }
  ],
