{
  "legislative_session": "2025-2026",
  "identifier": "A10247",
  "title": "Relates to the excelsior research and development tax credit",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"empire innovation act\"; provides that a participant in the excelsior jobs program shall be eligible to claim a credit equal to the portion of the full cost of the participant's research and development expenses incurred that relates to the participant's research and development expenditures in New York state during the taxable year; provided however, if the participant receives a federal research and development tax credit calculated on the full cost of the participant's research and development expenses that relates to the participant's research and development expenditures in New York state during the taxable year, then said participant shall only be eligible to claim a credit equal to fifty percent of the portion of the participant's federal research and development tax credit that relates to the participant's research and development expenditures in New York state during the taxable year."
    }
  ],
