  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the state university trustees to promulgate rules or regulations relating to late fees and exceptions for students submitting certificate of residence forms, and a reconciliation process for such forms received after the list of non-resident students was sent to a county."
    }
