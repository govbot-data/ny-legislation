  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires landlords of non-owner occupied, one-six family dwellings in the city of New York to provide fire extinguishers in all rented apartments; authorizes the promulgation of standards related thereto."
    }
