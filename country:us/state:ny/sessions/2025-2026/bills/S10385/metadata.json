  "identifier": "S10385",
  "title": "Establishes a sales tax exemption for the purchase of electric wheelchair accessible vehicles",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a sales tax exemption for the purchase of electric vehicles that are designed for the purpose of transporting persons in wheelchairs or containing any physical device or alteration designed to permit access to and enable the transportation of persons in wheelchairs."
    }
  ],
