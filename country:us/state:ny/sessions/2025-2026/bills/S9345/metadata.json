  "identifier": "S9345",
  "title": "Authorizes the Holland central school district to establish an insurance reserve fund",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the Holland central school district to establish an insurance reserve fund for any loss, claim, action or judgment for which such school district is authorized or required to purchase or maintain insurance for the kinds of risks for which insurance is authorized."
    }
  ],
