  "identifier": "S9644",
  "title": "Relates to charter schools",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides additional requirements for approval of charter school applications; applies additional prohibitions to charter schools; requires certain financial disclosures by charter schools; requires charter schools to comply with provisions relating to construction, repair or demolition of school facilities; relates to admission of students."
    }
  ],
