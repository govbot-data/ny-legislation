{
  "legislative_session": "2025-2026",
  "identifier": "S8106",
  "title": "Establishes the office of chief medical examiner; repealer",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes an independent office of chief medical examiner in the state commission of correction; requires that every death of an incarcerated individual in a correctional facility immediately be reported to the office of the chief medical examiner; establishes duties and responsibilities of the office; repeals certain provisions relating thereto."
    }
  ],
