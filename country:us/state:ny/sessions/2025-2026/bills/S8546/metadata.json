  "identifier": "S8546",
  "title": "Establishes a grid modernization surcharge",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the public service commission establish a grid modernization surcharge imposed on utilities for the energy use of data centers and high-intensity data centers which meet a specified threshold of electricity or information-technology load; establishes the grid modernization fund to finance investments in system reliability, capacity expansion, and integration of clean energy resources."
    }
  ],
