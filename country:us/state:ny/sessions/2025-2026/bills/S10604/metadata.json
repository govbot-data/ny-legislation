  "identifier": "S10604",
  "title": "Provides additional protection to judges and their family members under the Judicial Security Act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides additional protection to judges and their family members under the Judicial Security Act; expands protection to domestic partners and adult children; relates to records to be kept private; relates to the continuation of the prohibition against the public disclosure of personal information; authorizes the chief administrator of the courts to develop procedures necessary to prevent the disclosure of personal information in the possession of the unified court system."
    }
  ],
