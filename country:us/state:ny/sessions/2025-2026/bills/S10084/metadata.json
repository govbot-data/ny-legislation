  "legislative_session": "2025-2026",
  "identifier": "S10084",
  "title": "Authorizes the town of Hamburg to extend the Big Tree fire protection district to include the village of Blasdell",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that once the board of trustees of the village of Blasdell abolishes its fire department, the town of Hamburg may extend the Big Tree fire protection district to include such village."
    }
  ],
