{
  "legislative_session": "2025-2026",
  "identifier": "A8642",
  "title": "Enacts the \"NYS health care tax reform act\"",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"NYS health care tax reform act\"; establishes a public goods and medicaid subsidy surcharge on insurance corporations; establishes a public goods and medicaid subsidy surcharge on business corporations; establishes a public goods and medicaid subsidy surcharge on pass-through entities; relates to filing fee surcharges; relates to revenues to be included in the health care reform act resources fund; establishes a public goods and medicaid surcharge on misclassified workers."
    }
  ],
