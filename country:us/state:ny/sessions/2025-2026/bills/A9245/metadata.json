  "legislative_session": "2025-2026",
  "identifier": "A9245",
  "title": "Requires epinephrine devices for anaphylaxis and staff trained to use them at child day care centers",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires child day care centers to have epinephrine devices and staff trained to use them on site in case of anaphylaxis or other severe allergic reaction."
    }
  ],
