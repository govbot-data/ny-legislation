  "identifier": "S10630",
  "title": "Relates to other post-employment benefits reserve funds for counties, cities, villages and towns",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the governing board of any county, city, village or town to establish one or more other post-employment benefits reserve funds for the financing of all or part of the cost of providing other post-employment benefits to eligible retired employees and their dependents."
    }
  ],
