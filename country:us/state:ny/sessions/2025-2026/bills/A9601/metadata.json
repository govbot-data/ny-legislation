  "legislative_session": "2025-2026",
  "identifier": "A9601",
  "title": "Prohibits the use of automated systems to make employment decisions unless there is a meaningful human review of the output of such automated system prior to the final employment decision",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the use of automated systems to make employment decisions unless there is a meaningful human review of the output of such automated system prior to the final employment decision; requires employers that use an automated system in the hiring process to notify applicants of the use of such system; provides that an applicant who has received an adverse employment decision may request a human-conducted review of such decision."
    }
  ],
