{
  "legislative_session": "2025-2026",
  "identifier": "S9568",
  "title": "Relates to the approval of applications of charter schools",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that charter school applicants shall first apply to the community district education council or the board of education of the school district for approval for renewal of a charter within a certain amount of time and public hearings shall be conducted on such proposed application."
    }
  ],
