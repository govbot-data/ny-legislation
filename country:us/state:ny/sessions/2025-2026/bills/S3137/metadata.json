{
  "legislative_session": "2025-2026",
  "identifier": "S3137",
  "title": "Relates to criminal possession of stolen property",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the court where there is criminal possession of stolen property to, in its discretion release the principal pending trial on the principal's own recognizance or under non-monetary conditions, fix bail, or order non-monetary conditions in conjunction with fixing bail, or, where the defendant is charged with a qualifying offense which is a felony, the court may commit the principal to the custody of the sheriff; makes related provisions."
    }
  ],
