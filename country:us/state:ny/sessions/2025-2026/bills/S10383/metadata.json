{
  "legislative_session": "2025-2026",
  "identifier": "S10383",
  "title": "Requires arrested individuals to be given a mental health evaluation form",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the office of mental health to create a mental health evaluation form to determine whether arrested individuals have the proper mental capacity to make decisions regarding their arrest; requires arrested individuals to be given such mental health evaluation form; directs that if an individual fails such mental health evaluation, a representative will be appointed for such individual regarding arrest proceedings."
    }
  ],
