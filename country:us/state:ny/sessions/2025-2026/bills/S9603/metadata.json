  "identifier": "S9603",
  "title": "Requires members of a public body to complete a minimum level of training on the state's open meetings law and freedom of information law",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires members of a public body to complete a minimum of two hours of training, with one hour on the state's open meetings law and one hour on freedom of information law; requires certain local, city, county, town and village public body members to complete such training as well."
    }
  ],
