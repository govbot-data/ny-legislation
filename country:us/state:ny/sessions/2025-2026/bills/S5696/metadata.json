  "title": "Relates to increasing penalties for assault, obstruction and harassment of an election officer",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Includes within the class D felony of assault in the second degree, the intentional causing of physical injury to an election officer while such person is performing their assigned duties; amends aggravated harassment and obstruction of governmental administration to include election officers."
    }
