  "identifier": "S8719",
  "title": "Establishes a tax credit for food service establishment donations to food pantries",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a tax credit for food service establishment donations to food pantries, in the amount of fifty percent of the marketed value of each of the taxpayer's qualified donations up to six dollars per qualified donation, beginning with the 2027 tax year."
    }
  ],
