  "identifier": "A8809",
  "title": "Requires that certain land which was conveyed to the town of Riverhead in 2011 be leased to the YMCA of Long Island for the provision of recreational and community services",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires that land formerly used as an armory which was conveyed to the town of Riverhead, county of Suffolk by the state in 2011, to be leased to the YMCA of Long Island for the provision of recreational and educational programs."
    }
  ],
