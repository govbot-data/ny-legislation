  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the clear and conspicuous disclosure of pricing changes for online grocery delivery and online pick-up services; imposes a fine of not more than one hundred dollars for the first offense and not more than two hundred fifty dollars for a second and each subsequent offense for violations."
    }
