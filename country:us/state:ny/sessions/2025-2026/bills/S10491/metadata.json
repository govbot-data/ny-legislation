  "identifier": "S10491",
  "title": "Relates to the computation of sales tax on new mobile homes",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that sales and compensating use taxes on a new mobile home purchased as a primary residence shall be computed on thirty-five percent of the receipts or consideration given therefor by the purchaser or user."
    }
  ],
