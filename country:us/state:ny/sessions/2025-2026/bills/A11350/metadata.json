  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides a filing extension for the \"enhanced\" STAR exemption to initial applicants provided that such applicants have not been granted such extension before and such applicants are otherwise entitled to the exemption."
