  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes municipalities to fund training of firefighters; allows a municipality to recoup the cost of sending a firefighter to training school from another municipality that hires that firefighter within three years of their training."
    }
