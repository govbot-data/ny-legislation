{
  "legislative_session": "2025-2026",
  "identifier": "S3154",
  "title": "Creates Dolly Parton's statewide imagination library program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the office of children and family services to establish Dolly Parton's statewide imagination library program for encouraging children from birth to five years of age, inclusive, to develop a love of reading and learning; directs the office of children and family services to promote the statewide development of local Dolly Parton's Imagination Library programs; advance and strengthen local Dolly Parton's Imagination Library programs with the goal of increasing enrollment; recruit volunteers to assist in the development, promotion, and coordination of local Dolly Parton's Imagination Library programs; solicit donations, gifts, and other funding to financially support local Dolly Parton's Imagination Library programs; develop community engagement; develop, promote, and coordinate a public awareness campaign to make donors aware of the opportunity to donate to the affiliate programs and make the public aware of the opportunity to register eligible children to receive books through the program; administer the local match requirement and coordinate the collection and remittance of local program costs for books and mailing; and develop statewide marketing and communication plans; establishes the imagination library of New York fund."
    }
  ],
