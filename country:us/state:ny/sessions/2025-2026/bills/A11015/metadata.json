  "identifier": "A11015",
  "title": "Establishes state composting programs",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires all state agencies to establish a composting program in buildings owned, occupied or operated by such agencies; allows such agencies to arrange for collection of compostable waste by a private carter, transport such waste itself or process such waste on-site; requires reports on the costs and effectiveness of such programs."
    }
  ],
