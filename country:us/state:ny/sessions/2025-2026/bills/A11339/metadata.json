{
  "legislative_session": "2025-2026",
  "identifier": "A11339",
  "title": "Relates to establishing the crime of voyeurism",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the crime of voyeurism in the first and second degree which is defined as when someone for their own amusement, entertainment, profit, sexual arousal or sexual gratification trespasses or uses an instrument to observe for the purpose of viewing a person dressing or undressing or the sexual or other intimate parts of such person at a place and time when such person has a reasonable expectation of privacy, without such person's knowledge or consent."
    }
  ],
