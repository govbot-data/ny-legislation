  "title": "Relates to reforming the industrial development authority program and adding a tax clearance process",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to reforming the industrial development authority program, authorizing the commissioner of taxation and finance to audit IDA projects and IDA agents and project operators with regard to the requirements and restrictions, requiring IDAs to post certain information on their websites, and requiring IDA members to comply with certain provisions of the public officers law; adds a tax clearance process."
    }
  ],
