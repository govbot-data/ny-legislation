  "identifier": "S2586",
  "title": "Relates to providing translators at certain polling place locations",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to providing translators at certain polling place locations if fifteen percent of the number of voting age citizens who speak the same language other than English at home reside in the district where such polling place is located."
    }
  ],
