  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the buy American, buy union grant program and the buy American, buy union grant fund for the purpose of providing grants to municipal subdivisions to reimburse such municipal subdivisions for the costs of procuring consumer or commercial vehicles which are union-made."
    }
