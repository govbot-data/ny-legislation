  "identifier": "S4121",
  "title": "Relates to protecting people from civil arrest at certain locations",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Protects people from civil arrest while within one thousand feet of a sensitive location, unless such civil arrest is supported by a judicial warrant or judicial order authorizing such civil arrest."
    }
