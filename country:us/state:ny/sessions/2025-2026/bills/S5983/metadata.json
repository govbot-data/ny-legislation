  "identifier": "S5983",
  "title": "Prohibits the application of pesticides to certain local freshwater wetlands",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the application of pesticides to certain local freshwater wetlands for local governments that have implemented a freshwater wetlands protection law; provides that any local law or ordinance adopted pursuant to this section shall take effect on the first day of January after it shall have been adopted."
    }
  ],
