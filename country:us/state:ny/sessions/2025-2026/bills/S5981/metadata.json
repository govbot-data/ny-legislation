{
  "legislative_session": "2025-2026",
  "identifier": "S5981",
  "title": "Establishes the comprehensive sexual and reproductive health program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the comprehensive sexual and reproductive health program to provide funding to providers whose primary function is to facilitate access to comprehensive sexual and reproductive health care services and information for low-income, uninsured and underinsured individuals and provide support to providers to facilitate access to care, fund uncompensated care, and support community awareness of comprehensive sexual and reproductive health care services across New York state."
    }
  ],
