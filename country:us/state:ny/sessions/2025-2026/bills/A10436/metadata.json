  "title": "Authorizes university faculty practice corporations for the practice of occupational therapy",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes licensed occupational therapists who are members of the faculty of a college or university with an accredited occupational therapy program to create a university faculty practice corporation for occupational therapy students to receive clinical instruction."
    }
