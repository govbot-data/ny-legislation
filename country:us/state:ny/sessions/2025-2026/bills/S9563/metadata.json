  "identifier": "S9563",
  "title": "Relates to payment for work by a personal care aide or a home health aide with temporary protected status or other visa status",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires insurers to pay a licensed home care services agency for work provided by a personal care aide or a home health aide with temporary protected status or other visa status; requires the licensed home services agency to have made a good faith effort to establish the employment eligibility of personal care aide or a home health aide consistent with federal regulation and statutes."
    }
  ],
