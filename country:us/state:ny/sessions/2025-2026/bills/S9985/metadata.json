  "identifier": "S9985",
  "title": "Enhances transparency in the prescription drug supply chain",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"foreign drug transparency act\" to provide information on the origin, manufacture and distribution of prescription drugs; requires a pharmacy benefit manager to maintain, and make available to pharmacies, health plans, and patients upon request, supply chain information for prescription drugs covered under its network."
    }
  ],
