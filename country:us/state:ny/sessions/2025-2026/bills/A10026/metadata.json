  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the completion of training requirements for sheriffs and undersheriffs; directs the municipal police training council to promulgate rules and regulations relating to qualification for municipal police forces for persons who were previously sworn members of the state police and to provide certificates to such persons who meet such qualifications."
    }
