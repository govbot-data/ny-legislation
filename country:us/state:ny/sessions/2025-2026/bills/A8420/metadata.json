{
  "legislative_session": "2025-2026",
  "identifier": "A8420",
  "title": "Relates to the produce security fund",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that any time the produce security fund exceeds six million dollars on the one hundred twentieth day prior to the commencement of the next licensing year, the commissioner of agriculture and markets shall suspend the collection of the security fund fee; makes related provisions."
    }
  ],
