  "identifier": "S4881",
  "title": "Requires contractors and subcontractors performing construction work for covered renewable energy systems to use apprenticeship agreements",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires contractors and subcontractors performing construction work for covered renewable energy systems to use apprenticeship agreements; requires thermal energy networks to require contractors and subcontractors to use pre-apprenticeship direct entry providers registered with the department of labor."
    }
  ],
