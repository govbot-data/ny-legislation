  "identifier": "S10481",
  "title": "Relates to preventative safety tools at certain establishments which hold a liquor license",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires an applicant for a new license to sell liquor and the holder of an existing liquor license to offer preventative safety tools, including drink covers, to customers and to post a related notice containing certain specified language."
    }
