  "identifier": "A11486",
  "title": "Provides notice regarding the timeliness of the receipt by the board of elections of ballots capable of return by mail",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides notice regarding the timeliness of the receipt by the board of elections of ballots capable of return by mail to advise voters that such ballot should be returned to the board of elections as soon as possible by any approved method, and further recommend the use of alternative methods of return besides domestic mail services if the voter will be returning their ballot within several days of the election."
    }
  ],
