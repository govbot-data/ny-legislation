  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Clarifies that leases entered into by the commissioner of general services shall be subject to prevailing wage requirements for public work; requires prevailing wage for leasehold or capital improvements in such leases."
