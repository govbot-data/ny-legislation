  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires NYCHA to provide information and trainings to all residents regarding the formation of resident management corporations, the requirements of such resident management corporations and the potential benefits of creating such resident management corporations."
    }
  ],
