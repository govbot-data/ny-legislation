  "identifier": "S9618",
  "title": "Relates to cemetery desecration; repealer",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Removes the $250 amount of damage from cemetery desecration in the second degree; makes cemetery desecration in the second degree a class E felony to apply to any damage or theft regardless of value; adds crime of cemetery desecration in the first degree and makes such crime a class D felony."
    }
  ],
