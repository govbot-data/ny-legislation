{
  "legislative_session": "2025-2026",
  "identifier": "S5612",
  "title": "Authorizes occupational therapy services to be provided in school to certain students",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes occupational therapy services to be provided in school to students in grades pre-kindergarten through twelve with occupational impairments of a severity that does not adversely affect the student's educational performance but does present a barrier to functioning at home or in the community; directs the commissioner to promulgate rules and regulations for the provision of such occupational therapy services."
    }
  ],
