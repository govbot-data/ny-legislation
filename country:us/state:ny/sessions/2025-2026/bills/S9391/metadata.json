{
  "legislative_session": "2025-2026",
  "identifier": "S9391",
  "title": "Raises daily room and board rates at adult homes proportionally to increases in the minimum wage in New York City",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that admission agreements at adult homes include language providing that daily room and board rates at adult homes shall be increased when the minimum wage in New York City increases in an amount equal to the percentage of such minimum wage increase; states that such adjustment applies solely to room, board and non-medical supportive services and shall not affect Medicaid reimbursement rates."
    }
  ],
