  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to certifying instructors in small arms practice; provides that after December 31, 2028 individuals certified as an instructor in small arms practice shall seek recertification subject to the standards and curriculum promulgated by the division of criminal justice services."
    }
  ],
