{
  "legislative_session": "2025-2026",
  "identifier": "S8762",
  "title": "Relates to the removal of actions to certain courts in an adjoining county",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Allows the removal of criminal actions to a mental health court in an adjoining county and provides for the reversion to the original court of record where the defendant fails to comply with or complete the mental health court program."
    }
  ],
