{
  "legislative_session": "2025-2026",
  "identifier": "S8109",
  "title": "Relates to the motor vehicle exemption and the homestead exemption for certain money judgments and bankruptcy proceedings",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the calculation of the homestead exemption amount; relates to the indexing of the homestead exemption for housing value changes; increases the amount of the motor vehicle exemption; limits the homestead exemption available to bankruptcy debtors to one exemption per household; increases the motor vehicle exemption available in bankruptcy proceedings."
    }
  ],
