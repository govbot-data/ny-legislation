{
  "legislative_session": "2025-2026",
  "identifier": "S8512",
  "title": "Relates to portable solar generation devices",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Defines \"portable solar generation device\"; exempts portable solar generation devices from interconnection or net metering requirements; requires the state energy conservation construction code to allow for portable solar generation devices to be connected to a building's wiring through an electrical outlet."
    }
  ],
