{
  "legislative_session": "2025-2026",
  "identifier": "S9500",
  "title": "Establishes the New York State grid reliability and energy affordability transition (GREAT) act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the New York State grid reliability and energy affordability transition (GREAT) act; establishes the virtual power plant program to help reduce energy costs and grid reliability risks; provides incentives to participants for supporting the grid by investing in distributed energy resources and reducing net energy costs."
    }
  ],
