{
  "legislative_session": "2025-2026",
  "identifier": "A3148",
  "title": "Relates to cost sharing fees for outpatient treatment at a substance use treatment program",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that for a substance use disorder outpatient treatment episode of care by a provider licensed, certified or otherwise authorized by the office of addiction services and supports, an insured shall only be responsible for a cost sharing fee not to exceed two hundred fifty dollars."
    }
  ],
