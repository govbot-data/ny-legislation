  "identifier": "S8536",
  "title": "Prohibits electric corporations and gas corporations from increasing charges due to the building or operation of a data center",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits electric corporations and gas corporations from passing along costs or increasing charges to ratepayers as a result of increased costs incurred due to the building or operation of a data center except to those ratepayers involved with or associated with the building or operation of such data center or semiconductor fabrication plant."
    }
