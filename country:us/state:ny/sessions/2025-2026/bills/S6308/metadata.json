  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires reporting and verification of scope 1, 2 and 3 greenhouse gas emissions by a business with total annual revenues in excess of one billion dollars ($1,000,000,000) that does business in New York; requires regulations and disclosures."
    }
