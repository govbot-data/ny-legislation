  "identifier": "S8722",
  "title": "Prohibits the sale or lease of certain types of real property in the state to foreign countries of concern and foreign principals",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the sale or lease of agricultural and forest property and real property on or within ten miles of any military installation or critical infrastructure facility in the state to foreign countries of concern and foreign principals."
    }
