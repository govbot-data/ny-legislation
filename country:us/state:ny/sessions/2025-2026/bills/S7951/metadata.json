  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the native/pollinator planting fund and the pollinator highway program; creates a distinctive native plant and pollinator license plate with the goal of promoting the cultivation and maintenance of native flowering plants, grasses and shrubs on land bordering state highways and on other public lands."
    }
  ],
