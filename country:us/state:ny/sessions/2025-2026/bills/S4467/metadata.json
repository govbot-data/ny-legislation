  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides for the enrollment of a surviving spouse, a surviving domestic partner, a dependent child or children, or any other person entitled to a death benefit in direct deposit for compensation payments."
