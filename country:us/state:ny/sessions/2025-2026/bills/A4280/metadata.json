  "identifier": "A4280",
  "title": "Requires mobile sports wagering operators to establish default betting limits on their platforms and to notify authorized sports bettors of their ability to opt-out of the default betting limits",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
