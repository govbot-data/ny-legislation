  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"choice in responsible gaming act\"; requires mobile sports wagering operators to establish default betting limits on their platform and to notify authorized sports bettors of their ability to opt-out of the default betting limits."
    }
  ],
