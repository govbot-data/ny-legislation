  "identifier": "A619",
  "title": "Relates to additional state payment assistance",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to additional state payment assistance; provides that where there is no agreement in effect for federal administration of additional state payments the commissioner of the office of temporary and disability assistance is responsible for providing assistance to applicants for or recipients of such payments as it relates to applying for, modifying or maintaining such benefits."
    }
  ],
