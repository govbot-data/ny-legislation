  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the metropolitan transportation authority to establish a city university of New York student fare program for trains and buses which provides a full fare reduction for five train and/or bus fares each weekday equal to the standard pay-per-ride fare."
    }
