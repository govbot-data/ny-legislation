  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a digital legal mail program for the delivery of privileged correspondences to incarcerated individuals housed at correctional facilities; requires law offices sending legal mail via digital platforms to incarcerated individuals to register with the department of corrections."
    }
