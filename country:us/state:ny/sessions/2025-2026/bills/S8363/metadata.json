  "legislative_session": "2025-2026",
  "identifier": "S8363",
  "title": "Enacts the individual counseling rate enhancement act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires a rate enhancement for reimbursement of individual psychotherapy services provided by a mental health counselor, a clinical social worker, or a psychologist where such services are provided in an outpatient substance use disorder clinic."
    }
  ],
