  "identifier": "A4286",
  "title": "Relates to comptroller oversight of tribal-state compacts prior to federal approval",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the comptroller to review and provide a recommendation of approval or modifications, for submission for federal approval of any tribal-state compact approved or executed between the state of New York, the governor, or their designee and an Indian nation or tribe."
    }
  ],
