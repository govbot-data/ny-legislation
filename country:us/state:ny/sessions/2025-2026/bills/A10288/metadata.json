  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes SUNY and CUNY to provide emergency aid grants to certain students; provides that the state shall reimburse half of all such grants provided; requires the higher education services corporation to provide an annual report on such programs."
    }
