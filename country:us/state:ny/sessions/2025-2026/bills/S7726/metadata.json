{
  "legislative_session": "2025-2026",
  "identifier": "S7726",
  "title": "Establishes interschool robotics competitions for certain schools",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the commissioner of education to promulgate and review as necessary rules and regulations allowing trustees and boards of education of schools with a robotics program to conduct interschool robotics competitions for grades nine through twelve equivalent to the interschool athletic competitions conducted by such schools."
    }
  ],
