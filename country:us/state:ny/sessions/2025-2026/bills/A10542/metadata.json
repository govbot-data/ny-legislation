{
  "legislative_session": "2025-2026",
  "identifier": "A10542",
  "title": "Relates to sexual offense evidence collection kit procedures",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires that all sexual offense evidence shall be kept in a locked, separate and secure area for twenty years from the date of collection or until the victim's fortieth birthday, whichever is later; makes other sexual offense evidence collection kit procedures."
    }
  ],
