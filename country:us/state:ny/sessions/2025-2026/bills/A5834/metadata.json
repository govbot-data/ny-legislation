{
  "legislative_session": "2025-2026",
  "identifier": "A5834",
  "title": "Relates to early voting for certain special elections",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that early voting for any special election held on April 29, 2025 shall begin on April 21, 2025 and end on April 27, 2025; provides that the duration for early voting hours for any special election held on April 29, 2025 shall be equal to or greater than the minimum number of total hours otherwise required."
    }
  ],
