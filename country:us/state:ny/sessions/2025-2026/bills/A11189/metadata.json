  "identifier": "A11189",
  "title": "Relates to the reporting and remediation of certain sites following municipal notification to the department of environmental conservation",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires a municipality to notify the department of environmental conservation about certain sites containing illegal or hazardous substances; requires the department of environmental conservation to notify the United States environmental protection agency and create a remediation plan for the affected site."
    }
