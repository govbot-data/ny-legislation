  "identifier": "S10663",
  "title": "Relates to reporting of certain independent expenditures",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to reporting of certain independent expenditures and penalties for failing to report such expenditures; includes certain communications which use language or imagery substantially associated with a candidate's campaign, platform, background, or publicly stated positions, such that a reasonable viewer would understand the communication as designed to influence the outcome of such general, special, or primary election in the definition of independent expenditure."
    }
  ],
