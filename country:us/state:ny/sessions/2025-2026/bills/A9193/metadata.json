  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires entities which operate a system of shared electric bicycles or scooters to impose penalties for failure of an operator or borrower to return a shared electric scooter or bicycle to a proper location."
    }
