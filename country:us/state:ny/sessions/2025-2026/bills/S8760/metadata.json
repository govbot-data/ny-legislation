  "title": "Requires the modification of restrictive covenants prior to the sale of real property",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the modification of restrictive covenants prior to the sale of real property when covenants, conditions and restrictions exist which discriminate on the basis of a protected class in violation of state or federal law."
    }
