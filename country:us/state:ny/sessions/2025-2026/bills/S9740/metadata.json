  "identifier": "S9740",
  "title": "Requires fashion sellers to be accountable to standardized environmental and social due diligence policies, and establishes a fashion remediation fund",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires fashion sellers to carry out environmental due diligence for the portions of their business related to wearing apparel, footwear or fashion bags, including wearing apparel, footwear or fashion bags produced as a private label; establishes a fashion remediation fund."
    }
  ],
