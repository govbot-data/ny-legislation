{
  "legislative_session": "2025-2026",
  "identifier": "S7922",
  "title": "Relates to limitations on interest on taxes imposed by cities with a population of one million or more",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that no interest shall accrue on taxes imposed by a city with a population of one million or more unless a tax appeals tribunal shall have made a determination within one year from the date a petition is filed."
    }
  ],
