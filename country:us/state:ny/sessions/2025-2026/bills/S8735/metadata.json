  "identifier": "S8735",
  "title": "Enacts the \"billing transparency act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"billing transparency act\"; provides that every utility corporation, energy services corporation and municipality shall provide an itemized breakdown of customers' bills each month; provides that electric utility corporations, energy services companies and municipalities shall maintain a dedicated and easily accessible customer website that explains customer charges."
    }
  ],
