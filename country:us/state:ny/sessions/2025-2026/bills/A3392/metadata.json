{
  "legislative_session": "2025-2026",
  "identifier": "A3392",
  "title": "Allows for no fault separation",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Allows for no fault separation where the relationship between the spouses has broken down irretrievably for a period of at least six months; requires that issues of support and custody or visitation have been resolved."
    }
  ],
