  "identifier": "S9746",
  "title": "Clarifies who may sue an insurer for violations related to misrepresentations, misleading statements and incomplete comparisons",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Clarifies that residents of the state and any policyholder, contract holder, certificate holder, or beneficiary of a policy, contract, or certificate of life, accident and health insurance may sue an insurer for violations related to misrepresentations, misleading statements and incomplete comparisons."
    }
  ],
