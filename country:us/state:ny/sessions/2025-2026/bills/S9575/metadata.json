  "identifier": "S9575",
  "title": "Relates to the recovery of attorneys fees in certain summary proceedings between a cooperative housing corporation and a shareholder or occupant of such corporation",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that fees may be sought in certain summary proceedings between a cooperative housing corporation and a shareholder or occupant when the lease or occupancy agreement provides for the recovery of fees, legal fees, charges, surcharges, penalties, or assessments other than rent."
    }
  ],
