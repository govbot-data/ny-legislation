  "identifier": "S9547",
  "title": "Relation to the state's liability for damages caused by defects on state roads",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Imposes liability on the state for injuries or damage sustained by persons while traveling on state highways, if the same are caused by a defect or dangerous condition that the state had notice of, but did not repair."
    }
  ],
