  "abstracts": [
    {
      "note": "",
      "abstract": "Requires SUNY and CUNY institutions which offer a master of social work degree program to offer a maternal mental health elective course to students to provide comprehensive training in perinatal mood and anxiety disorders and instruct students how to apply best practices in screening, referral and treatment."
    }
