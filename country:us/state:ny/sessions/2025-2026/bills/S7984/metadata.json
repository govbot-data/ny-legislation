  "legislative_session": "2025-2026",
  "identifier": "S7984",
  "title": "Relates to exemptions from the recipient restriction program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Exempts any covered substance use disorder and mental health treatment services and all FDA approved medications for the treatment of substance use disorder, HIV, hepatitis C and mental health conditions, from all recipient restriction program coverage and payment restrictions."
    }
  ],
