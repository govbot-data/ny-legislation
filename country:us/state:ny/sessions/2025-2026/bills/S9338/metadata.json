{
  "legislative_session": "2025-2026",
  "identifier": "S9338",
  "title": "Establishes a waiting period before a firearm, shotgun or rifle may be delivered to a person",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a three calendar day waiting period from contact of the New York State National Instant Background Check System (NYS NICS) before a firearm, shotgun or rifle may be delivered to a person; provides exceptions where a person possesses a license to purchase, carry or possess a pistol, revolver, or semiautomatic rifle."
    }
  ],
