  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that insurance policies which provide hospital, surgical or medical coverage shall provide coverage for hysterectomies; provides that such coverage shall include inpatient hospital coverage for a minimum period of seventy-two hours after surgery."
    }
