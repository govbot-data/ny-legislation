  "identifier": "S6913",
  "title": "Establishes the 2-1-1 essential community services hotline system",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the 2-1-1 essential community services hotline system; designates the office of children and family services to oversee the hotline system; establishes the availability and scope of information to be provided by the hotline system and requirements of call centers; requires the office of children and family services to collect certain data relating to the hotline system and to make annual reports to the governor and the legislature."
    }
  ],
