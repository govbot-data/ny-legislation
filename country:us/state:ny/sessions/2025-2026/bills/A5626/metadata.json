  "identifier": "A5626",
  "title": "Relates to permits and financial security for reclamation for salt mining beneath a lake; repealer",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to permits and financial security for reclamation for salt mining beneath a lake; requires such permits to be subject to environmental quality review procedures; requires financial security to cover any damages directly or indirectly resulting from salt mining activities beneath a lake, including, but not limited to, those resulting from collapse or water contamination."
    }
  ],
