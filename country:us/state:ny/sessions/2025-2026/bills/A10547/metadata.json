  "identifier": "A10547",
  "title": "Relates to certain requirements for new tobacco business locations",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits retail dealers from opening a tobacco business within 500 feet of an already existing licensed tobacco business; provides an exception if it is determined to be in the public interest by the municipality or community board."
    }
