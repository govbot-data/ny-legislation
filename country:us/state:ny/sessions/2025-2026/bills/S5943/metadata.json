  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires every sheriff, county or city commissioner of correction and head of every state, county, or local police department to report instances and occurrences of hate crimes; requires the division to promulgate rules and regulations for such reporting."
