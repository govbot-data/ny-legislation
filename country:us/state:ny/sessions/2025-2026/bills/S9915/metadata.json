  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires battery energy storage system owners and operators to demonstrate compliance with workforce reliability standards as a condition of state financial assistance; extends prevailing wage requirements and whistleblower protections to operations and maintenance employees at covered battery energy storage systems; directs the public service commission to promulgate implementing regulations; and requires a periodic review of implementation."
    }
  ],
