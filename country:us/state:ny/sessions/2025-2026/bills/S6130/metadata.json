{
  "legislative_session": "2025-2026",
  "identifier": "S6130",
  "title": "Relates to the consumer protection division in the department of state",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the consumer protection division to establish a process by which any state agency or third party, pursuant to an interagency agreement with the division for the purposes of fraud prevention, identity verification, and ensuring the integrity or security of individual identities, to grant access to verify New York resident identities via a secure comparison process against state systems."
    }
  ],
