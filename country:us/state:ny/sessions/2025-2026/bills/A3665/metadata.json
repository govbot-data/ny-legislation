{
  "legislative_session": "2025-2026",
  "identifier": "A3665",
  "title": "Repeals certain provisions regarding adoption of new or revised city charter proposed by charter commission which limit submission of questions to city's electors",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Repeals certain provisions regarding the adoption of a new or revised city charter proposed by a charter commission which limits the submission of questions to a city's qualified electors; eliminates the rule that provides that whenever a city charter commission puts a proposal on the local ballot, all other local referendum proposals are barred from the ballot."
    }
  ],
