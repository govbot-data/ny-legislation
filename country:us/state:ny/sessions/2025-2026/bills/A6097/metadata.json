  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the town of Orangetown to establish community preservation funds; establishes a real estate transfer tax with revenues therefrom to be deposited in said community preservation fund; provides for the repeal of such provisions upon the expiration thereof."
    }
  ],
