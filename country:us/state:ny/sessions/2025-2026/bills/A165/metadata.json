  "legislative_session": "2025-2026",
  "identifier": "A165",
  "title": "Relates to outdoor restraints of dogs",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to outdoor restraints of dogs; prohibits inhumane tethering, including during dangerous weather conditions when a weather alert, advisory or warning is in effect; provides for civil penalties for violations."
    }
  ],
