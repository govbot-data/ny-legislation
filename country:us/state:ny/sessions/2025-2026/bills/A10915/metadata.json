{
  "legislative_session": "2025-2026",
  "identifier": "A10915",
  "title": "Authorizes the designation of active recovery zones within municipalities",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the chief executive of a responding law enforcement agency to designate an area within a municipality as an active recovery zone in response to certain natural or man-made disasters or emergencies; limits access to such zones to residents and other affected persons, first responders, and certain authorized personnel; imposes a penalty of a class B misdemeanor for knowing unauthorized access to such zones; makes related provisions."
    }
  ],
