  "identifier": "S9039",
  "title": "Establishes a competitive emergency mapping grant program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a competitive emergency mapping grant program which will provide grants to school districts or boards of cooperative educational services to upgrade their floor plans, blueprints, schematics or other maps of their school interior, school grounds and road maps of the immediate surrounding area included in their building level emergency response plans."
    }
  ],
