{
  "legislative_session": "2025-2026",
  "identifier": "S3852",
  "title": "Prohibits the sale of playground surfacing materials that contain PFAS, PAHs or more than ninety parts per million of lead; and provides penalties for violations",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the sale of playground surfacing materials that contain PFAS, PAHs or lead; prevents sellers of playground surfacing materials that contain PFAS, PAHs or lead from being held in violation when relying in good faith on a certificate of compliance provided by the manufacturer; provides penalties for violations."
    }
  ],
