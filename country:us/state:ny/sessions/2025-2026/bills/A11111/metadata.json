  "title": "Directs the department of health to conduct a study of recreational activity programming in nursing homes",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the department of health to conduct a study and prepare a report of recreational activity programming in nursing homes examining the accessibility and inclusivity of programming, including accommodations for residents with physical or cognitive impairments, availability of multilingual services, transportation for off-site programming, and scheduling considerations."
    }
  ],
