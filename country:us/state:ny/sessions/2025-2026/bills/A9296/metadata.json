  "abstracts": [
    {
      "note": "",
      "abstract": "Requires catalytic converters to be indelibly marked or engraved with the vehicle identification number of the vehicle on which such catalytic converter is installed; requires junk dealers to obtain and record certain information and documentation when receiving a motor vehicle catalytic converter that is not attached to the motor vehicle."
    }
  ],
