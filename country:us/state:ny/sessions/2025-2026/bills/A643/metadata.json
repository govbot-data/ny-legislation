  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the purchase of claims by corporations or collection agencies; relates to the inference of an assignee's intent and purpose in taking an assignment of a claim against an obligor that is not an eligible obligor."
    }
