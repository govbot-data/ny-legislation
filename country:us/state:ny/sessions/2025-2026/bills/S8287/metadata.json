  "title": "Requires rip current, rip tide and undertow curriculum or instruction",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts \"Alexandra's law\" to require school districts and charter schools to include in the curriculum or instruction teaching students how to recognize and react to rip currents, rip tides and undertows."
    }
