{
  "legislative_session": "2025-2026",
  "identifier": "S642",
  "title": "Relates to employer liability for on-duty assaults of employees",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that if any employee, engaged in the service of any commuter rail service owned or operated by the authority or its subsidiaries, shall suffer a physical and/or mental injury that is caused by a passenger, customer or member of the public while the employee is performing an assigned duty, the employer shall be held liable for any health care costs attributable to such injury; makes related provisions."
    }
  ],
