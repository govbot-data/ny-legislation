{
  "legislative_session": "2025-2026",
  "identifier": "S7680",
  "title": "Relates to mandating the development and approval of operational safety plans",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the office of parks, recreation and historic preservation to develop and approve operational safety plans prior to the deployment of any employee in hazardous conditions; requires the plan to include a comprehensive risk assessment identifying potential hazards associated with the deployment, mitigation measures to address identified risks, detailed information on team composition, identification of an on-site authorized person responsible for overseeing operations, a clear chain of command, emergency contact information for all team members, and evacuation procedures."
    }
  ],
