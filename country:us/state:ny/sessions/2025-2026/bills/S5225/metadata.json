  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the collection and reporting of sexual offense evidence on the statewide electronic tracking system within seven days of permission to release the evidence by the alleged sexual offense victim; relates to additional rules and guidelines."
    }
