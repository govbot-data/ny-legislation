{
  "legislative_session": "2025-2026",
  "identifier": "S8450",
  "title": "Allows certain campaign funds to be used for accessibility services",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Allows public campaign funds to be used for disability access services including but not limited to captioning, sign language interpretation, assistive listening device, Braille, large print, communication access real-time translation and accessible transportation services and to be used for language interpretation and translation services."
    }
  ],
