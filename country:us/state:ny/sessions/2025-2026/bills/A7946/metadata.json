  "identifier": "A7946",
  "title": "Relates to airport noise studies metrics",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the commissioner of health to undertake a study utilizing a uniform metric for measuring noise impacts that will be used by airports for the purpose of noise exposure maps and noise compatibility programs."
    }
  ],
