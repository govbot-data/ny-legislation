{
  "legislative_session": "2025-2026",
  "identifier": "S4763",
  "title": "Ensures that parents and guardians of youth are notified when their child is arrested",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the issuance of arrest warrants upon a youth who is still in high school; provides for the police officer to make a reasonable effort to notify the parent or other person legally responsible for the care of such youth or with whom the youth is domiciled that the youth has been arrested; provides that the police officer need not notify the parent or other person legally responsible when such youth is not also a juvenile offender and the notification would endanger the health and safety of such youth; amends provisions relating to sexually exploited children to include persons under the age of nineteen."
    }
  ],
