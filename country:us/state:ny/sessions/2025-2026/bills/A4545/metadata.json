  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides expanded enrollment through New York state of health through tax returns (Part A); allows for enrollment through the New York state of health at any time for first-time enrollees; expands New York state of health navigator program (Part B); creates the New York health benefit and cost commission (Part C); establishes New York health care savings accounts to expand and incentivize purchasing private health insurance (Part D)."
    }
  ],
