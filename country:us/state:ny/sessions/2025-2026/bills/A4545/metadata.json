  "identifier": "A4545",
  "title": "Provides expanded enrollment through New York state of health through tax returns, expands New York state of health navigator program; creates the New York health benefit and cost commission; repealer",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
