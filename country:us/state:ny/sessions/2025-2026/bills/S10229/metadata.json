{
  "legislative_session": "2025-2026",
  "identifier": "S10229",
  "title": "Establishes a process for when a tenant dies and leaves an apartment unoccupied",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a process for when a tenant dies and leaves an apartment unoccupied, no representative or person has taken possession of the premises, no administrator or executor has been appointed, and more than sixty days have elapsed since the date of death, a summary proceeding under this article may be commenced against the public administrator seeking a possessory judgment."
    }
  ],
