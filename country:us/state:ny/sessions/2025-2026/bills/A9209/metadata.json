{
  "legislative_session": "2025-2026",
  "identifier": "A9209",
  "title": "Relates to lights for bicycles with electric assist and electric scooters",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires any person, firm, association or corporation selling or leasing bicycles with electric assist and electric scooters in NYS to affix front and rear lights."
    }
  ],
