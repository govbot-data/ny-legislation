{
  "legislative_session": "2025-2026",
  "identifier": "S10157",
  "title": "Enacts the \"utility fair acquisition act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"utility fair acquisition act\", providing that in any acquisition by a municipal corporation or a public benefit corporation created pursuant to article 5 of the public authorities law of infrastructure operated by a public utility company or private energy provider, the appraised value shall be reduced by the value of infrastructure that was financed through customer user fees, ratepayer surcharges, or other non-investor-funded mechanisms as determined by the public service commission."
    }
  ],
