{
  "legislative_session": "2025-2026",
  "identifier": "S7966",
  "title": "Authorizes the village of Atlantic Beach to impose a hotel, motel and beach club tax",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the village of Atlantic Beach, county of Nassau to impose a three percent hotel, motel and beach club tax; defines \"beach club\" as a facility formed, organized or operated by any person, firm or corporation, located on or contiguous to an ocean beach, permitting sunbathing, swimming and other allied recreation activities, including such uses operated by a hotel, cooperative complex or other entity; makes related provisions."
    }
  ],
