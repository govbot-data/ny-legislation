  "legislative_session": "2025-2026",
  "identifier": "S9093",
  "title": "Establishes a lesbian, gay, bisexual, transgender, queer or questioning plus crisis hotline",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a twenty-four hour, toll-free hotline and website for lesbian, gay, bisexual, transgender, queer or questioning plus (LGBTQ+) individuals who are experiencing emotional distress, suicidal ideation, or crisis-related challenges, which shall provide immediate support, referrals, resource lists, and other information."
    }
  ],
