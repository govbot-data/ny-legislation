  "identifier": "S9705",
  "title": "Lowers quorum requirements for meetings of community boards held by videoconferencing",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that, for a quorum, an advisory board may require that at a minimum, one quarter of the members and the presiding officer of a community board physically be present at a location where the public can attend for such board to conduct videoconferencing."
    }
  ],
