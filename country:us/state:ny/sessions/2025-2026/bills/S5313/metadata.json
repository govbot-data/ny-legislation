{
  "legislative_session": "2025-2026",
  "identifier": "S5313",
  "title": "Relates to addressing non-covered dental services",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Addresses non-covered dental services by requiring all policies providing coverage of and all contracts for dental services issued to include a disclosure stating that a participating provider may charge their normal fee for services that are not covered; requires a cost estimate to be provided."
    }
  ],
