  "title": "Enacts the \"stopping abuse and fraud enabled by (SAFE) platforms act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"stopping abuse and fraud enabled by (SAFE) platforms act\"; requires a mechanism for users to report fraudulent content; prohibits platforms recommending, promoting, curating, prioritizing, or displaying fraudulent content for delivery to a user if it knows or has reason to know that the content is fraudulent."
    }
  ],
