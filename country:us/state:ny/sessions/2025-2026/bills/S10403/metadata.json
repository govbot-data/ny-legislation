  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to prohibiting the exclusion of coverage for losses or damages caused by exposure to lead-based paint; provides that no insurer licensed or permitted by the superintendent to provide liability coverage to rental property owners shall exclude coverage for losses or damages caused by exposure to lead-based paint."
    }
