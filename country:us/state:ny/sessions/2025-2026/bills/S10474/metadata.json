{
  "legislative_session": "2025-2026",
  "identifier": "S10474",
  "title": "Enacts the Creating Lasting Access to Supported and Inclusive Careers for New York (CLASSIC NY) act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a disability employment innovation fund; authorizes the issuance of \"Classic NY\" series license plates consisting of reissued historical license plate designs; authorizes the commissioner of motor vehicles to identify, reserve, and auction certain license plate configurations that are determined to have elevated market value; directs proceeds of \"Classic NY\" series plates and any auctioned plates to be deposited into the disability employment innovation fund."
    }
  ],
