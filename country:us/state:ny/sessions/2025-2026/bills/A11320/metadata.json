{
  "legislative_session": "2025-2026",
  "identifier": "A11320",
  "title": "Prohibits the department of corrections and community supervision from using artificial intelligence in parole determinations",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the department of corrections and community supervision from using artificial intelligence in evaluating the risk and needs principles used to measure rehabilitation of a person, in determining which incarcerated individuals may be released on parole or the level of supervision for individuals on parole; prohibits the department from using artificial intelligence when developing transitional accountability plans."
    }
  ],
