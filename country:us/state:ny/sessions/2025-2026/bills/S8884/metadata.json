{
  "legislative_session": "2025-2026",
  "identifier": "S8884",
  "title": "Directs the superintendent of state police develop a critical incident policy for members of the state police",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the superintendent of state police to develop, maintain and disseminate to all members of the division of state police a critical incident leave policy requiring critical incident paid leave for any members directly involved in a critical incident; prohibits such superintendent from taking any punitive administrative action against any member of the division of state police granted critical incident leave solely on the basis of the provision of such leave."
    }
  ],
