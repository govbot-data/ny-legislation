  "identifier": "S7842",
  "title": "Directs the state civil service commission to design and implement a pilot location pay compensation program for state employees designated managerial or confidential",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the state civil service commission to design and implement a pilot location pay compensation program for state employees designated managerial or confidential that is based upon cost-of-living factors in different geographic areas of the state consistent with methodologies used by the federal government in its general schedule locality pay plan."
    }
  ],
