{
  "legislative_session": "2025-2026",
  "identifier": "A9649",
  "title": "Relates to special franchise assessments and requires any reduction of the tax burden of certain utilities to pass-through to ratepayers",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Exempts certain utilities from special franchise assessments in New York city; requires that any reduction in special franchise taxes imposed on ConEd and National Grid shall be passed-through to rates charged to its ratepayers so that the full economic benefit of such reduction accrues to their ratepayers."
    }
  ],
