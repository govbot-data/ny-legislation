{
  "legislative_session": "2025-2026",
  "identifier": "S9086",
  "title": "Relates to service animals and emotional support animals",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Distinguishes the terms \"service animal\" and \"emotional support animal\"; provides that persons with a disability shall be entitled to reasonable housing accommodations for a service animal or emotional support animal, provided that they obtain documentation from a qualified practitioner; provides that certain privileges are restricted to persons with a service animal; provides that a person who fraudulently obtains documentation for a reasonable housing accommodation shall be guilty of a misdemeanor and subject to a fine and community service."
    }
  ],
