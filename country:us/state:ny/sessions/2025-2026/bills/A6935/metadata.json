  "identifier": "A6935",
  "title": "Relates to requiring Medicaid to cover a wearable medical device to treat certain forms of cancer",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires Medicaid to cover a wearable medical device that uses low-intensity, alternating electric fields delivered to the tumor site to treat glioblastoma and other cancers as recommended by medical and scientific evidence."
    }
  ],
