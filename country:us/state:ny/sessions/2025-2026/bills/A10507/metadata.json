{
  "legislative_session": "2025-2026",
  "identifier": "A10507",
  "title": "Enacts the \"living wage for all act\"; repealer",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"living wage for all act\" in relation to raising the minimum wage to $30 by January 1, 2030 for large employers and by January 1, 2035 for small employers, and by a percentage based on inflation thereafter, providing for minimum wage requirements for miscellaneous industry workers, and minimum wage for incarcerated individuals working in correctional facilities; repeals provisions of law relating to minimum wage increases."
    }
  ],
