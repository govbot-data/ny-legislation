{
  "legislative_session": "2025-2026",
  "identifier": "S7807",
  "title": "Expands the definition of epinephrine devices to include epinephrine nasal sprays",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Defines epinephrine device as a single-use device or nasal spray device used for the automatic injection or administration of a premeasured dose of epinephrine into the human body for the purpose of emergency treatment of a person appearing to experience anaphylactic symptoms."
    }
  ],
