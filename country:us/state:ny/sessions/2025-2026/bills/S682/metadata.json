{
  "legislative_session": "2025-2026",
  "identifier": "S682",
  "title": "Increases the penalties for stopping, standing, or parking in handicapped spaces without a handicapped permit",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Increases the penalties for stopping, standing, or parking in handicapped spaces without a handicapped permit to not less than one hundred fifty dollars nor more than three hundred dollars for the first offense and three hundred to five hundred fifty dollars for the second offense occurring within a period of five years within the state."
    }
  ],
