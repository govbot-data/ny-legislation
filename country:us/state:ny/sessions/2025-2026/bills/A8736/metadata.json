  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the commissioner of corrections and community supervision to promulgate rules and regulations for requirements for vendors who make products available for order and delivery to incarcerated individuals and provide for safe food storage for incarcerated individuals in their cells."
