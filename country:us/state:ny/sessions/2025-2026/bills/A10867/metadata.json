  "identifier": "A10867",
  "title": "Relates to qualifications to hold the positions of village treasurer, deputy village treasurer, village clerk, deputy clerk and building inspector in the village of Briarcliff Manor",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes the village of Briarcliff Manor to provide that the positions of village treasurer, deputy village treasurer, village clerk, deputy clerk and building inspector may be held by residents of Westchester county, or an adjoining county within the state of New York."
    }
  ],
