  "identifier": "S10423",
  "title": "Enacts Alexa and Lindsey's law",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts Alexa and Lindsey's law; prohibits disabling safety features in motor vehicles; provides enhanced penalties where it causes an accident that harms or kills another person; provides that if multiple people are harmed or killed as a result of an unsafe vehicle modification a consecutive sentence may be imposed."
    }
  ],
