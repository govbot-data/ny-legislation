  "title": "Relates to a license to sell liquor at retail for consumption on certain premises",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Allows the state liquor authority to issue a retail license for on-premises consumption for a premises which shall be located within two hundred feet of a building occupied as a school, church, synagogue or other place of worship."
    }
