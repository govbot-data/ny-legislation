{
  "legislative_session": "2025-2026",
  "identifier": "S8787",
  "title": "Relates to welfare, medical, and retirement plans provided by a horsemen's organization in the absence of contractual obligations",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to welfare, medical, and retirement plans provided by a horsemen's organization in the absence of contractual obligations; provides that in the absence of a contract between the licensed harness racing corporation or association and the representative horsemen's organization, the previous contract shall be automatically extended for a one-time period of twelve months commencing from the date that the previously negotiated contract expired."
    }
  ],
