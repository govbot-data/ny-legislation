  "identifier": "A4978",
  "title": "Relates to the visitation rights of great-grandparents",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that a great-grandparent may apply to the supreme court for visitation rights with respect to certain minor great-grandchildren where either or both of the parents of such child is or are deceased."
    }
  ],
