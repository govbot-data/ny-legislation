  "title": "Enacts \"India's law\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts \"India's law\" under which an incarcerated individual's next of kin shall be notified and allowed visitation by a local correctional facility when such individual is experiencing a serious medical event or demonstrating behavior that is likely to result in serious harm to themselves or others."
    }
  ],
