{
  "legislative_session": "2025-2026",
  "identifier": "S8943",
  "title": "Relates to missing and exploited women and children",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a missing persons unit within the division of state police; adds women to the responsibility of the missing and exploited children clearinghouse; provides that by January first, two-thousand twenty-seven included in the curriculum for the training of law enforcement shall be missing and exploited women and missing and exploited women and children of color and indigenous descent; requires the reporting duties of law enforcement departments to include missing women, in addition to missing children and vulnerable adults; relates to the missing and exploited women and children clearinghouse fund; relates to the gift for missing and exploited women and children clearinghouse fund."
    }
  ],
