  "identifier": "A8712",
  "title": "Prohibits utility service terminations in multiple dwellings",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits utility service terminations in multiple dwellings; authorizes utility companies or municipalities to commence an action against the owner of the premises affected to seek the appointment of a receiver of rents or payments for use and occupancy or common charges."
    }
  ],
