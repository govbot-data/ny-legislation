  "identifier": "S9986",
  "title": "Relates to a review of filing with the department of state; relates to filing fees; and relates to administrative procedure to address fraudulent entity filings",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the department of state to review filings for fraud; provides that the department of state shall charge no fee for the dissolution or modification of a business corporation created by fraud; provides an administrative procedure to address fraudulent entity filings."
    }
  ],
