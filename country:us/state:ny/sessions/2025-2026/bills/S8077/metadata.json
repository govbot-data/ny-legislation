  "identifier": "S8077",
  "title": "Authorizes certain students attending the Syracuse Comprehensive Education and Workforce Training Center high school to be eligible for senior high school athletic competitions",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes students attending the Syracuse Science, Technology, Engineering, Arts and Mathematics high school, who participated in a high school athletic competition for a school district other than the Syracuse city school district in 7th and/or 8th grade, to be eligible for senior high school athletic competitions."
    }
  ],
