{
  "legislative_session": "2025-2026",
  "identifier": "A9463",
  "title": "Relates to the issuance of temporary elevator mechanic licenses during shortages, continuing education for certain elevator and accessibility lift licensees, and the use of unlicensed elevator mechanics; repealer",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the determination of a verifiable shortage of licensed mechanics by the commissioner of labor for purposes of the issuance of a temporary elevator mechanic license, continuing education requirements for elevator mechanic's and accessibility lift technician's licensees, and authorizing the commissioner of labor to impose civil penalties for the employment or use of unlicensed mechanics; repeals certain provisions of the labor law related to the inspection of elevators and conveyances; amends the effectiveness of such related provisions."
    }
  ],
