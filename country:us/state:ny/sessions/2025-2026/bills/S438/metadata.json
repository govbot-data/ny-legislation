{
  "legislative_session": "2025-2026",
  "identifier": "S438",
  "title": "Establishes the prescription drug supply chain transparency act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the prescription drug supply chain transparency act; requires pharmacy services administrative organizations, pharmacy switch companies and rebate aggregators to register with the insurance department and to provide certain disclosures relating to the ownership and activities of such entities; relates to deposits into the pharmacy benefit manager regulatory fund."
    }
  ],
