  "legislative_session": "2025-2026",
  "identifier": "S688",
  "title": "Relates to the real property tax exemption for surviving spouses of volunteer firefighters or volunteer ambulance workers killed in the line of duty",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Amends the real property tax exemption for surviving spouses of volunteer firefighters or volunteer ambulance workers killed in the line of duty to permit continuation of such exemption for volunteer members with service between two and five years."
    }
  ],
