  "identifier": "S2071",
  "title": "Requires the department of labor create and maintain a list of available careers and job openings for veterans in the state of New York",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the department of labor create and maintain a list of available careers and job openings for veterans in the state of New York and provide such list to the department of veterans' services; requires such list to be placed on the department of veterans' services website."
    }
  ],
