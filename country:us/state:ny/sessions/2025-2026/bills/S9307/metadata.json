{
  "legislative_session": "2025-2026",
  "identifier": "S9307",
  "title": "Relates to certain signal devices for railroad trains or other on-track equipment",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires whenever any person driving a vehicle approaches a railroad grade crossing where there is on-track equipment, the driver of such vehicle shall stop not less than fifteen feet from the nearest rail of such railroad, and shall not proceed until they can do so safely."
    }
  ],
