  "identifier": "S8812",
  "title": "Relates to the effectiveness of provisions of law relating to the provision of gas service to new customers",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the effectiveness of provisions of law relating to providing that in the case of any application for gas service to a building which is not supplied with gas, a utility corporation or municipality shall be obligated to provide gas service to such building."
    }
  ],
