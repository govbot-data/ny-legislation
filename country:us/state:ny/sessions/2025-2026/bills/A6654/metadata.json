  "legislative_session": "2025-2026",
  "identifier": "A6654",
  "title": "Relates to authorizing a reduction of taxes pursuant to shelter rent",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to authorizing a reduction of taxes pursuant to shelter rent; provides that upon consent of the local legislative body in a city with a population of one million or more such taxes may be reduced to five per centum or less, including a full reduction of the annual shelter rent or carrying charges of a project."
    }
  ],
