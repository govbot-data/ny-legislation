{
  "legislative_session": "2025-2026",
  "identifier": "S7689",
  "title": "Relates to voting of overseas military voters and special federal voters",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Authorizes electronic absentee ballot applications for military voters and special federal voters; removes requirements that the federal post card application form be included with certain ballot application and ballots; requires institutions of higher education to provide students studying abroad with information on how to vote from abroad."
    }
  ],
