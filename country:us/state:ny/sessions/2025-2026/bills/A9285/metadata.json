  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes a centralized mental health data reporting and integration platform to be utilized by all state-operated and county-administered mental health programs, as well as all providers licensed or funded by the office of mental health for the provision of mental health services."
    }
