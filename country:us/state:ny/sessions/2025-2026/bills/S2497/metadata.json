{
  "legislative_session": "2025-2026",
  "identifier": "S2497",
  "title": "Relates to the admissibility of certain testimony and evidence by a person alleging discrimination",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Permits the admissibility of testimony that a person reported acts of discrimination to another person in a civil trial under the human rights law, including the contents of such report."
    }
  ],
