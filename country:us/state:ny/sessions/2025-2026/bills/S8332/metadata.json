  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"small cannabis farmer relief act\" in relation to authorizing certain licensees who qualify as distressed farmer licensees and who legally cultivated cannabis during the two thousand twenty-two or two thousand twenty-three calendar year to expand their cultivation canopy."
    }
