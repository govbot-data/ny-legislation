  "abstracts": [
    {
      "note": "",
      "abstract": "Extends the reporting deadline of the advisory panel on employee-owned enterprises from June 30, 2026 to June 30, 2027; extends for one year the advisory panel on employee-owned enterprises which is tasked with reporting and making recommendations on how best to support such businesses and promote the formation and growth of new employee-owned enterprises in New York state."
    }
  ],
