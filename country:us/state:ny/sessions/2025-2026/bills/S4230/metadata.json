{
  "legislative_session": "2025-2026",
  "identifier": "S4230",
  "title": "Relates to the payment of restitution by registered and unregistered repair shops",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes that if financial loss has been made and a registrant or unregistered repair shop fails to comply with an order to pay restitution, the commissioner shall, by order, increase the amount of the penalty assessed."
    }
  ],
