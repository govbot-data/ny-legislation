  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the commissioner of the New York state division of housing and community renewal to promulgate rules and regulations to provide a taxpayer or entity having applied for the low-income housing tax credit and certified by the division of housing and community renewal with a notice of placement on a waiting list upon the submission of a completed application."
    }
