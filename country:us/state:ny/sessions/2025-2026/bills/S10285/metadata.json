  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"New York state buy American cement act\" to require the use of American materials when soliciting for a contract for the purchase of cement by any department or agency of the state, municipality, public authority and the commissioner of transportation."
    }
