  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that full escalation date means the first day of the month following the date on which a member completes or would have completed twenty-three years of credited service, with respect to service retirement benefits for uniformed members of the New York city fire department pension fund."
    }
