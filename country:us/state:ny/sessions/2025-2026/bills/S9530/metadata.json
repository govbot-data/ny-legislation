{
  "legislative_session": "2025-2026",
  "identifier": "S9530",
  "title": "Enacts the crash victims bill of rights",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"crash victims bill of rights\"; requires accident reports to be delivered to victims of accidents or their next of kin; requires victim impact statements to be delivered at traffic infraction hearings by injured parties or their next of kin; requires employers to grant leave of absence to employees delivering a victim impact statement at a traffic infraction hearing; directs the superintendent of financial services to conduct a study and complete a report on certain automobile crash information."
    }
  ],
