{
  "legislative_session": "2025-2026",
  "identifier": "S7141",
  "title": "Establishes the crime of aggravated criminal sale of a controlled substance resulting in serious physical injury",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Amends the offense of murder in the second degree to include when a person knowingly distributes fentanyl or any substance containing fentanyl and as a result of such distribution causes the death of another person; establishes the crime of aggravated criminal sale of a controlled substance resulting in serious physical injury."
    }
  ],
