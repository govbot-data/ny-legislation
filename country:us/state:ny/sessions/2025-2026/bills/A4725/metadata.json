  "legislative_session": "2025-2026",
  "identifier": "A4725",
  "title": "Prohibits the use of drilling fluids and flowback water from wells, pools or fields on any highway",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits the use of drilling fluids, brine and flowback water from gas or oil wells, pools, or fields on any highway for any purpose including but not limited to de-icing or dust suppression."
    }
