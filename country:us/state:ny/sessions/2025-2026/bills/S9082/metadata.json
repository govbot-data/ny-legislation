  "identifier": "S9082",
  "title": "Prohibits public adjusters from contacting certain persons regarding a property that has sustained damage from a damaging event within forty-eight hours of such damaging event",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Prohibits public adjusters from initiating contact with, soliciting, or approaching owners, occupants, tenants, or other affected parties regarding commercial or residential property that has sustained damage from a damaging event within forty-eight hours following such damaging event; establishes reimbursement and written notice requirements for such adjusters."
    }
  ],
