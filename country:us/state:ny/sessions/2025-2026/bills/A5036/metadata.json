{
  "legislative_session": "2025-2026",
  "identifier": "A5036",
  "title": "Requires elections and terms of certain officials occur on even-numbered years except in the city of New York",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires certain elections take place in even-numbered years for certain municipal and judicial officials except in the city of New York."
    }
