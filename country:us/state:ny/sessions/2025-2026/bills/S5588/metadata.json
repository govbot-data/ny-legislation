  "identifier": "S5588",
  "title": "Expands the Gold Star exemption",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Expands the Gold Star exemption by including the War on Terror as a qualifying period of war and allows for the exemption where the Gold Star Parent's child has died in the United States from a service-connected disability."
    }
  ],
