  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the housing development fund company fairness, preservation, and affordability act to clarify certain provisions relating to the dissolution and reincorporation of housing development fund companies; provides for tax exemptions and abatements for housing development fund companies."
    }
