  "title": "Relates to permits and financial security for reclamation for mining on state-owned lands occurring below or beneath navigable waters; repealer",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to permits and financial security for reclamation for mining on state-owned lands occurring below or beneath navigable waters; requires such permits to be subject to environmental quality review procedures; requires financial security to cover any damages directly or indirectly resulting from mining activities on state-owned lands occurring below or beneath navigable waterways, including, but not limited to, those resulting from collapse or water contamination."
    }
  ],
