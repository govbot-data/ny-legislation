{
  "legislative_session": "2025-2026",
  "identifier": "S10076",
  "title": "Authorizes a discontinuance without an order in actions where an unrepresented party has not responded to a request for a stipulation",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Allows a party asserting a claim to discontinue an action without procedural delays when the discontinuance would benefit an unrepresented party and that party has not responded to a request to stipulate to a discontinuance in a reasonable period of time."
    }
  ],
