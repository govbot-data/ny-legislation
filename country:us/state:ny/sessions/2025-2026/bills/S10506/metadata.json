{
  "legislative_session": "2025-2026",
  "identifier": "S10506",
  "title": "Provides enhanced building aid for school construction projects in municipalities that meet transit-oriented development or housing growth benchmarks",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that for any school district located wholly or partially within a municipality that meets transit-oriented development or housing growth benchmarks, the approved building aid ratio for any eligible capital construction project shall be increased by five percentage points."
    }
  ],
