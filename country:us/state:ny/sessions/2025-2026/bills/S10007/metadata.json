{
  "legislative_session": "2025-2026",
  "identifier": "S10007",
  "title": "Relates to the submission of requests to the committee on special education for the educational services mandated by an individualized education services program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the school district of location shall annually provide written notice to all parents or persons in parental relation to students with disabilities attending nonpublic schools within their district regarding the process for requesting special education services; relates to the denial of services in a city having a population of one million or more for the 2024--2025 school year."
    }
  ],
