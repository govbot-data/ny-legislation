  "identifier": "S10092",
  "title": "Enacts the \"no gambling ads for kids act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"no gambling ads for kids act\" under which certain covered platforms and social media platforms are prohibited from advertising a service permitting gaming-related gambling, predictive market wagering, online sweepstakes gaming, sports-related gambling, and/or traditional online gambling to minors."
    }
  ],
