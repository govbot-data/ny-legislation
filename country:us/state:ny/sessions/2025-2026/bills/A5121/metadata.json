{
  "legislative_session": "2025-2026",
  "identifier": "A5121",
  "title": "Requires certain public residential buildings to maintain a supply of naloxone",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires public residential buildings that receive funding through the department of housing and urban development or the division of housing and community renewal to have a supply of at least one dose of naloxone readily accessible for residential use as provided by OASAS."
    }
  ],
