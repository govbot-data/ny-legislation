  "identifier": "S2345",
  "title": "Relates to verification of voter qualifications",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires the state board of elections to participate in the systematic alien verification for entitlements (SAVE) program, administered by the United States citizenship and immigration services agency, to verify that a person who is either registered or registering to vote is a United States citizen."
    }
  ],
