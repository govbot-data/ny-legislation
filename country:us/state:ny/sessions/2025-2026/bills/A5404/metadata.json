  "legislative_session": "2025-2026",
  "identifier": "A5404",
  "title": "Relates to the municipal sustainable energy loan program",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Relates to the municipal sustainable energy loan program regarding qualifying water improvements, qualifying resiliency improvements and, in a city with a population of one million or more, the use of low carbon intensity building components."
    }
  ],
