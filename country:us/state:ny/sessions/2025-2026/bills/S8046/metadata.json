{
  "legislative_session": "2025-2026",
  "identifier": "S8046",
  "title": "Relates to audit of individual apartment improvements (IAIs) for rent stabilized apartments outside of the city of New York",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires an annual inspection and audit process which shall review five percent of individual apartment improvement notifications for rent stabilized apartments outside of the city of New York; requires additional audits where violations are found."
    }
  ],
