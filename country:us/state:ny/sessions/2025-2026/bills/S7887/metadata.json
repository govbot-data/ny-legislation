  "abstracts": [
    {
      "note": "",
      "abstract": "Amends the list of persons eligible to succeed the governor in the event that the governor is unable to discharge the powers and duties of the office of governor as a result of an attack or a natural or peacetime disaster and the lieutenant governor, the temporary president of the senate and the speaker of the assembly are unable to discharge such duties."
    }
  ],
