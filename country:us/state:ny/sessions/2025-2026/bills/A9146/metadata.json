{
  "legislative_session": "2025-2026",
  "identifier": "A9146",
  "title": "Prohibits mobile sports wagering operators from providing counseling, therapy, and treatment services for bettors in New York",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires mobile sports wagering operators when providing information regarding compulsive play, all links and referrals for counseling, therapy or treatment services shall direct account holders to the problem gambling services webpage maintained by the office of addiction services and supports."
    }
  ],
