{
  "legislative_session": "2025-2026",
  "identifier": "S4903",
  "title": "Directs the creation of a document giving certain notice to parents and guardians of school age students who are diagnosed with a life-threatening medical condition or a certain medical condition",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"Shepherd Patterson notification act\"; requires a physician who treats a minor patient with a medical condition that may cause a disability to provide certain educational information to such patient's parents or guardians indicating such minor is entitled to a free and appropriate public education as defined under section five hundred four of the federal rehabilitation act of nineteen hundred seventy-three; makes related provisions."
    }
  ],
