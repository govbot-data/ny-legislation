  "identifier": "S2056",
  "title": "Enacts the student voter empowerment act",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Enacts the \"student voter empowerment act\"; requires each institution of higher education to designate a staff member to act as a student voting coordinator; requires such coordinator to develop and implement a student voting action plan to increase student voter registration and voting and democratic participation among students."
    }
  ],
