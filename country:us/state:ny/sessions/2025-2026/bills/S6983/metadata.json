  "identifier": "S6983",
  "title": "Establishes the New York dignity in pregnancy and childbirth act and requires hospitals and other facilities that provide perinatal care to implement an evidence-based implicit bias program",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Establishes the New York dignity in pregnancy and childbirth act; requires hospitals and other facilities that provide perinatal care to implement an evidence-based implicit bias program for all health care providers involved in the perinatal care of patients within those facilities; requires the department of health to publish reports on maternal morbidity and pregnancy related deaths."
    }
  ],
