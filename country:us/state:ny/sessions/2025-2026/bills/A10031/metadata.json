  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Creates a volunteer firefighter scholarship program and a volunteer firefighter scholarship fund; rewards volunteer firefighters who respond to twenty-five percent of emergency calls for eight years with a student loan award equal to four times the SUNY tuition rate; makes an appropriation therefor."
    }
