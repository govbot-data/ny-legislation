  "identifier": "S10390",
  "title": "Requires covered lenders to report to the department of financial services certain information on covered loans",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Requires covered lenders to report to the department of financial services certain information on covered loans; requires the superintendent of financial services to collect and maintain such data and to annually publish a report containing aggregated information regarding covered loans; requires the superintendent of financial services to promulgate rules and regulations to implement such provisions."
    }
  ],
