  "identifier": "S2543",
  "title": "Relates to notifying voters of the candidates and upcoming elections",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Instructs the state board of elections to create and distribute voting guides to voters containing information about the candidates; mandates that voters receive postcards to notify them of upcoming elections and that television and radio stations also notify their audience of upcoming elections."
    }
  ],
