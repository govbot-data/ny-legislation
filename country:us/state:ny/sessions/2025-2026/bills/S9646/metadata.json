{
  "legislative_session": "2025-2026",
  "identifier": "S9646",
  "title": "Enacts the \"New York Determining Obligations and Guaranteeing Enforcement (DOGE) in Government Contracting Act\"",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Directs the department of economic development, in conjunction with the empire state development corporation, to review all contracts entered into or overseen or enforced by the department of economic development and/or the empire state development corporation relating to the leasing of state-owned premises to private parties for the production, manufacture and/or development of solar shingle products, electric vehicle charging networks, advanced driver-assistance systems, and/or supercomputer hardware and to identify and eliminate fraud, abuse or waste by private parties."
    }
  ],
