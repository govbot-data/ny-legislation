{
  "legislative_session": "2025-2026",
  "identifier": "S9455",
  "title": "Includes a dependent allowance with unemployment benefits",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Provides that a claimant for unemployment benefits may claim an additional dependent allowance in an amount equal to 5% of the state average weekly wage for the current benefit year multiplied by the number of dependents claimed in the preceding tax year."
    }
  ],
