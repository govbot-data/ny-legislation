{
  "legislative_session": "2025-2026",
  "identifier": "S9548",
  "title": "Relates to the identification of individuals who provide face-to-face care to or direct observation of a patient and information required to be submitted by complainants in offenses against a health care worker",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "",
      "abstract": "Limits the identification of individuals who provide face-to-face care to or direct observation of a patient to their first name and first initial of their last name; requires complainants to only submit the address of the health care facility at which they were providing services at the time of the offense in cases involving an alleged offense against a hospital worker health care practitioner."
    }
  ],
